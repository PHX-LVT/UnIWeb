    "Title": {},
    "Content": {
      "en": "<div class=\"sc-detail-risk-intro\"><span class=\"sc-detail-eyebrow\">Risk Landscape</span><h2>Customs Clearance Is No Longer an Administrative Task</h2><p class=\"sc-detail-lead\">Customs brokerage has evolved into a strategic risk layer - where minor errors can create delays, penalties, inspections and downstream supply-chain disruption.</p><div class=\"sc-detail-stats\"><div class=\"sc-detail-stat\"><strong>20+</strong><span>years local customs expertise</span></div><div class=\"sc-detail-stat\"><strong>99.3%</strong><span>on-time release performance</span></div></div></div>",
      "vi": "<div class=\"sc-detail-risk-intro\"><span class=\"sc-detail-eyebrow\">Risk Landscape</span><h2>Customs Clearance Is No Longer an Administrative Task</h2><p class=\"sc-detail-lead\">Customs brokerage has evolved into a strategic risk layer - where minor errors can create delays, penalties, inspections and downstream supply-chain disruption.</p><div class=\"sc-detail-stats\"><div class=\"sc-detail-stat\"><strong>20+</strong><span>years local customs expertise</span></div><div class=\"sc-detail-stat\"><strong>99.3%</strong><span>on-time release performance</span></div></div></div>",
      "cn": "<div class=\"sc-detail-risk-intro\"><span class=\"sc-detail-eyebrow\">Risk Landscape</span><h2>Customs Clearance Is No Longer an Administrative Task</h2><p class=\"sc-detail-lead\">Customs brokerage has evolved into a strategic risk layer - where minor errors can create delays, penalties, inspections and downstream supply-chain disruption.</p><div class=\"sc-detail-stats\"><div class=\"sc-detail-stat\"><strong>20+</strong><span>years local customs expertise</span></div><div class=\"sc-detail-stat\"><strong>99.3%</strong><span>on-time release performance</span></div></div></div>"
    }
