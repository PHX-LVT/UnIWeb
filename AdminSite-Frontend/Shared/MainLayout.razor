@inherits LayoutComponentBase
@using AdminSite.Services
@using SharedComponents.Helpers
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@using Blazored.Toast
@using Blazored.Toast.Configuration
@inject AdminAuthService Auth
@inject AdminLanguageService AdminLanguage
@inject AdminSettingsService SettingsService
@inject NavigationManager Nav
@implements IDisposable

@if (!_ready)
{
    <div class="loading-screen">
        <div class="spinner"></div>
    </div>
}
else if (Auth.IsAuthenticated)
{
    <BlazoredToasts Position="ToastPosition.TopRight"
    Timeout="4"
    ShowProgressBar="true" />

    <div class="ez-layout" style="@_appearanceCss">
        <div class="ez-contain">

            <aside class="ez-sidebar">

                @* Logo *@
                <a class="ez-sidebar-brand" href="/" @onclick="GoToDashboard" @onclick:preventDefault>
                    <i class="fas fa-layer-group"></i>
                    <span>MySite CMS</span>
                </a>

                <div class="ez-sidebar-language">
                    <label for="admin-language-select">@AdminUiLocalizer.T("AdminLanguage", _adminLang)</label>
                    <select id="admin-language-select"
                            value="@_adminLang"
                            @onchange="ChangeAdminLanguage">
                        @foreach (var lang in AdminLanguage.SupportedLanguageOptions)
                        {
                            <option value="@lang.Code">@lang.NativeName</option>
                        }
                    </select>
                </div>

                @* NEW: Nav links wrapped in a scroll-isolated container *@
                <div class="ez-sidebar-nav">
                    <CascadingValue Name="AdminLanguage" Value="_adminLang">
                        @if (_sidebarMode == SidebarMode.ThemeSettings)
                        {
                            <button type="button" class="ez-theme-close" @onclick="CloseThemeSettings">
                                <i class="fas fa-arrow-left"></i>
                                <span>@AdminUiLocalizer.T("CloseThemeSettings", _adminLang)</span>
                            </button>
                            <ThemeSettingsPanel />
                        }
                        else
                        {
                            <NavMenu OnThemeSettingsRequested="OpenThemeSettings" />
                        }
                    </CascadingValue>
                </div>

                @* User + logout pinned to bottom - safely outside the scroll box *@
                <div class="ez-sidebar-footer">

                    <button type="button" class="ez-user-btn" @onclick="ToggleMenu">
                        <i class="fas fa-user-circle"></i>
                        <span>@Auth.CurrentUser?.Email</span>
                        <i class="fas fa-caret-up" style="font-size:.7rem;margin-left:auto"></i>
                    </button>

                    @if (_menuOpen)
                    {
                        <div style="position:fixed;inset:0;z-index:998;"
                             @onclick="() => _menuOpen = false"></div>

                        <div class="ez-dropdown-menu" style="z-index:999;">
                            <button type="button" class="ez-dropdown-item" @onclick="GoToAccount">
                                <i class="fas fa-user-cog"></i>
                                @AdminUiLocalizer.T("AccountManagement", _adminLang)
                            </button>
                            <button type="button" class="ez-dropdown-item" @onclick="Logout">
                                <i class="fas fa-sign-out-alt"></i>
                                @AdminUiLocalizer.T("SignOut", _adminLang)
                            </button>
                        </div>
                    }

                </div>


            </aside>

            <main class="ez-wrapper">
                <CascadingValue Name="AdminLanguage" Value="_adminLang">
                    @if (_accessDenied)
                    {
                        <div class="admin-card" style="max-width:680px;margin:2rem auto">
                            <div class="admin-card-title">
                                <i class="fas fa-lock"></i>
                                @AdminUiLocalizer.T("AccessDenied", _adminLang)
                            </div>
                            <p class="text-muted" style="margin:.5rem 0 0">
                                @AdminUiLocalizer.T("AccessDeniedHint", _adminLang)
                            </p>
                        </div>
                    }
                    else
                    {
                        @Body
                    }
                </CascadingValue>
            </main>

        </div>
    </div>
}

@code {
    private bool _ready = false;
    private bool _menuOpen = false;
    private bool _disposed = false;
    private bool _accessDenied = false;
    private string _adminLang = "en";
    private string _appearanceCss = AdminAppearancePresets.ToCssVariables("navy-gold");
    private SidebarMode _sidebarMode = SidebarMode.Normal;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Auth.InitializeAsync();
        if (Auth.IsAuthenticated)
            await Auth.RefreshSessionAsync();

        await AdminLanguage.LoadSettingsAsync();
        var appearanceRes = await SettingsService.GetAdminAppearanceAsync();
        _appearanceCss = AdminAppearancePresets.ToCssVariables(appearanceRes.Data?.Preset);
        SettingsService.AppearanceChanged += OnAppearanceChanged;
        StyleHelper.SetFallbackLanguage(AdminLanguage.FallbackLanguage);
        _adminLang = await AdminLanguage.GetAsync();

        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: false);
            return;
        }

        Nav.LocationChanged += OnLocationChanged;
        UpdateRouteAccess();

        if (_disposed) return;
        _ready = true;
        StateHasChanged();
    }

    public void Dispose()
    {
        _disposed = true;
        Nav.LocationChanged -= OnLocationChanged;
        SettingsService.AppearanceChanged -= OnAppearanceChanged;
    }

    private void OnAppearanceChanged()
    {
        _appearanceCss = AdminAppearancePresets.ToCssVariables(SettingsService.CurrentAppearance.Preset);
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateRouteAccess();
        _menuOpen = false;
        _sidebarMode = SidebarMode.Normal;
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateRouteAccess()
    {
        var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrWhiteSpace(path)) path = "/";
        _accessDenied = !CanAccessPath(path);
    }

    private bool CanAccessPath(string path)
    {
        if (string.Equals(path, "/login", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(path, "/account", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(path, "/", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/preview", StringComparison.OrdinalIgnoreCase))
            return Auth.IsAuthenticated;

        if (path.StartsWith("/content/types", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/templates", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/deleted", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/published", StringComparison.OrdinalIgnoreCase))
            return Auth.CanManageAllContent;

        if (path.StartsWith("/content/new", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/edit", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/my", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/submitted", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/content/preview", StringComparison.OrdinalIgnoreCase))
            return Auth.CanManageContent;

        if (path.StartsWith("/content", StringComparison.OrdinalIgnoreCase))
            return Auth.CanViewContent;

        if (path.StartsWith("/global", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/settings", StringComparison.OrdinalIgnoreCase))
            return Auth.CanManageSettings;

        if (path.StartsWith("/forms", StringComparison.OrdinalIgnoreCase))
            return Auth.CanViewLogs;

        if (path.StartsWith("/users/sessions", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/users/audit", StringComparison.OrdinalIgnoreCase))
            return Auth.CanViewLogs;

        if (path.StartsWith("/users", StringComparison.OrdinalIgnoreCase))
            return Auth.CanManageUsers;

        return true;
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private void OpenThemeSettings()
    {
        if (!Auth.CanManageSettings)
        {
            _accessDenied = true;
            return;
        }

        _sidebarMode = SidebarMode.ThemeSettings;
    }

    private void CloseThemeSettings()
    {
        _sidebarMode = SidebarMode.Normal;
    }

    private void GoToDashboard()
    {
        _menuOpen = false;
        _sidebarMode = SidebarMode.Normal;
        Nav.NavigateTo("/");
    }

    private void GoToAccount()
    {
        _menuOpen = false;
        _sidebarMode = SidebarMode.Normal;
        Nav.NavigateTo("/account");
    }

    private async Task ChangeAdminLanguage(ChangeEventArgs e)
    {
        var next = e.Value?.ToString() ?? "en";
        await AdminLanguage.SetAsync(next);
        _adminLang = await AdminLanguage.GetAsync();
        StateHasChanged();
    }


    private async Task OnFooterFocusOut()
    {
        await Task.Delay(150);
        _menuOpen = false;
    }

   
    private async Task Logout()
    {
        _menuOpen = false;
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private enum SidebarMode
    {
        Normal,
        ThemeSettings
    }
}

