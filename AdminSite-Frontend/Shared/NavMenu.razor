@using Microsoft.AspNetCore.Components.Routing
@using AdminSite.Services
@inject NavigationManager Nav

<nav class="ez-nav-section">
    <NavLink class="ez-nav-link" href="/" Match="NavLinkMatch.All" @onclick="CollapseGroups">
        <i class="fas fa-tachometer-alt"></i>
        <span>@T("Dashboard")</span>
    </NavLink>
    <button class="ez-nav-link" type="button" @onclick="OpenThemeSettings">
        <i class="fas fa-palette"></i>
        <span>@T("Theme")</span>
    </button>
</nav>

<nav class="ez-nav-section">
    <button class="ez-nav-toggle @ToggleClass("global")" type="button" @onclick='() => ToggleGroup("global")'>
        <span>@T("Global")</span>
        <i class="fas fa-chevron-down"></i>
    </button>

    @if (_expandedGroup == "global")
    {
        <NavLink class="ez-nav-link ez-nav-child" href="/global/branding" @onclick='() => ExpandGroup("global")'>
            <i class="fas fa-paint-brush"></i>
            <span>@T("Branding")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/global/buttons" @onclick='() => ExpandGroup("global")'>
            <i class="fas fa-hand-pointer"></i>
            <span>@T("GlobalButtons")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/global/footer" @onclick='() => ExpandGroup("global")'>
            <i class="fas fa-grip-horizontal"></i>
            <span>@T("Footer")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/global/social" @onclick='() => ExpandGroup("global")'>
            <i class="fas fa-share-alt"></i>
            <span>@T("Social")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/forms" @onclick='() => ExpandGroup("global")'>
            <i class="fas fa-envelope-open-text"></i>
            <span>@T("FormSubmissions")</span>
        </NavLink>
    }
</nav>

<nav class="ez-nav-section">
    <button class="ez-nav-toggle @ToggleClass("content")" type="button" @onclick="OpenContentManagement">
        <span>@T("ContentManagement")</span>
        <i class="fas fa-chevron-down"></i>
    </button>

    @if (_expandedGroup == "content")
    {
        <NavLink class="ez-nav-link ez-nav-child" href="/content/all" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-newspaper"></i>
            <span>@T("AllContent")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/content/my" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-user-edit"></i>
            <span>@T("MyContent")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/content/submitted" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-inbox"></i>
            <span>@T("Submitted")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/content/published" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-check-circle"></i>
            <span>@T("Published")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/content/deleted" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-trash-alt"></i>
            <span>@T("Deleted")</span>
        </NavLink>
        <div class="ez-nav-label ez-nav-sublabel">@T("Configure")</div>
        <NavLink class="ez-nav-link ez-nav-child" href="/content/types" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-tags"></i>
            <span>@T("ContentTypes")</span>
        </NavLink>
        <NavLink class="ez-nav-link ez-nav-child" href="/content/templates" @onclick='() => ExpandGroup("content")'>
            <i class="fas fa-layer-group"></i>
            <span>@T("Templates")</span>
        </NavLink>
    }
</nav>

<nav class="ez-nav-section">
    <div class="ez-nav-label">@T("System")</div>
    <NavLink class="ez-nav-link" href="/settings" @onclick="CollapseGroups">
        <i class="fas fa-cog"></i>
        <span>@T("Settings")</span>
    </NavLink>
</nav>

@code {
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";
    [Parameter] public EventCallback OnThemeSettingsRequested { get; set; }

    private string? _expandedGroup;

    protected override void OnInitialized()
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        if (path.StartsWith("/global", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("/forms", StringComparison.OrdinalIgnoreCase))
        {
            _expandedGroup = "global";
        }
        else if (path.StartsWith("/content", StringComparison.OrdinalIgnoreCase))
        {
            _expandedGroup = "content";
        }
    }

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    private void ToggleGroup(string group)
    {
        _expandedGroup = _expandedGroup == group ? null : group;
    }

    private void ExpandGroup(string group)
    {
        _expandedGroup = group;
    }

    private async Task OpenThemeSettings()
    {
        CollapseGroups();
        await OnThemeSettingsRequested.InvokeAsync();
    }

    private void OpenContentManagement()
    {
        _expandedGroup = "content";
        Nav.NavigateTo("/content/all");
    }

    private void CollapseGroups()
    {
        _expandedGroup = null;
    }

    private string ToggleClass(string group) => _expandedGroup == group ? "is-expanded" : string.Empty;
}
