@page "/forms"
@inject NavigationManager Nav
@inject AdminAuthService Auth

@code {
    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Auth.RefreshSessionAsync();

        var target = Auth.CanViewFormSubmissions
            ? "/forms/submissions"
            : Auth.CanViewFormDefinitions || Auth.CanEditFormDefinitions
                ? "/forms/definitions"
                : "/";
        Nav.NavigateTo(target, replace: true);
    }
}
