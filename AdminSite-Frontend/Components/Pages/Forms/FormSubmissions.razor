@page "/forms/submissions"
@inject AdminFormSubmissionService FormService
@inject IHttpService Http
@inject IJSRuntime JS
@inject AdminAuthService Auth

<div class="page-header">
    <h1 class="page-title">@T("FormSubmissions")</h1>
</div>

@if (!_hasAccess)
{
    <div class="admin-data-empty">
        <strong>@T("NoPermission")</strong>
        <div>@T("AccessDeniedHint")</div>
    </div>
}
else
{

<div class="admin-data-stats form-submissions__stats">
    <div class="admin-data-stat form-stat form-stat--total">
        <span class="admin-data-stat__label"><span class="admin-data-stat__marker"></span>@T("Total")</span>
        <strong class="admin-data-stat__value">@_submissions.Count</strong>
    </div>
    <div class="admin-data-stat form-stat form-stat--new">
        <span class="admin-data-stat__label"><span class="admin-data-stat__marker"></span>@T("New")</span>
        <strong class="admin-data-stat__value">@Count(FormSubmissionStatusModel.New)</strong>
    </div>
    <div class="admin-data-stat form-stat form-stat--inprogress">
        <span class="admin-data-stat__label"><span class="admin-data-stat__marker"></span>@T("InProgress")</span>
        <strong class="admin-data-stat__value">@Count(FormSubmissionStatusModel.InProgress)</strong>
    </div>
    <div class="admin-data-stat form-stat form-stat--resolved">
        <span class="admin-data-stat__label"><span class="admin-data-stat__marker"></span>@T("Resolved")</span>
        <strong class="admin-data-stat__value">@Count(FormSubmissionStatusModel.Resolved)</strong>
    </div>
</div>

<div class="admin-data-toolbar">
    <div class="admin-data-toolbar__row form-submissions__filters">
        <label class="form-filter form-filter--search">
            <span>@T("Search")</span>
            <input class="form-control"
                   value="@_search"
                   @oninput="OnSearchChanged"
                   placeholder="@T("SearchFormSubmissionsPlaceholder")" />
        </label>
        <label class="form-filter">
            <span>@T("Form")</span>
            <select class="form-control" @bind="_formId" @bind:after="OnFilterChanged">
                <option value="">@T("AllForms")</option>
                @foreach (var definition in _definitions)
                {
                    <option value="@definition.Id">@Text(definition.Name, definition.Key)</option>
                }
            </select>
        </label>
        <label class="form-filter">
            <span>@T("Status")</span>
            <select class="form-control" @bind="_statusFilter" @bind:after="OnFilterChanged">
                <option value="">@T("AllStatuses")</option>
                @foreach (var status in Enum.GetValues<FormSubmissionStatusModel>())
                {
                    <option value="@status">@StatusLabel(status)</option>
                }
            </select>
        </label>
        <label class="form-filter">
            <span>@T("DateFrom")</span>
            <input type="date" class="form-control" value="@_fromDate" @onchange="OnFromDateChanged" />
        </label>
        <label class="form-filter">
            <span>@T("DateTo")</span>
            <input type="date" class="form-control" value="@_toDate" @onchange="OnToDateChanged" />
        </label>
        <div class="form-submissions__filter-actions">
            <button class="btn-admin btn-primary" disabled="@_loading" @onclick="ApplyFilters">@T("Apply")</button>
            <button class="btn-admin btn-ghost" disabled="@_loading" @onclick="ResetFilters">@T("ResetFilters")</button>
            @if (Auth.CanExportFormSubmissions)
            {
                <button class="btn-admin btn-secondary" disabled="@(_loading || _exporting)" @onclick="ExportAsync">
                    @(_exporting ? T("Exporting") : T("ExportExcel"))
                </button>
            }
        </div>
    </div>
</div>

@if (_selectedIds.Count > 0 && Auth.CanManageFormSubmissions)
{
    <div class="admin-data-bulkbar">
        <strong>@string.Format(T("SelectedCount"), _selectedIds.Count)</strong>
        <div class="admin-data-bulkbar__actions">
            <button class="btn-admin btn-secondary" @onclick="() => BulkStatus(FormSubmissionStatusModel.Archived)">@T("Archive")</button>
            <button class="btn-admin btn-secondary" @onclick="() => BulkStatus(FormSubmissionStatusModel.Spam)">@T("MarkSpam")</button>
            <button class="btn-admin btn-danger" @onclick="BulkDelete">@T("DeletePermanently")</button>
        </div>
    </div>
}

<div class="admin-data-table-card">
    @if (_loading)
    {
        <div class="admin-data-empty">@T("Loading")</div>
    }
    else if (!_filteredSubmissions.Any())
    {
        <div class="admin-data-empty">@T("NoSubmissionsFound")</div>
    }
    else
    {
        <div class="admin-data-table-scroll">
            <table class="table form-submissions-table">
                <thead>
                    <tr>
                        @if (Auth.CanManageFormSubmissions)
                        {
                            <th style="width:42px">
                                <input type="checkbox" checked="@AllPagedSelected" @onchange="ToggleAllPaged" />
                            </th>
                        }
                        <th>@T("SubmittedTime")</th>
                        <th>@T("Form")</th>
                        <th>@T("SenderSummary")</th>
                        <th>@T("Status")</th>
                        <th>@T("AssignedTo")</th>
                        <th>@T("Source")</th>
                        <th>@T("Updated")</th>
                        <th style="width:96px">@T("Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in PagedSubmissions)
                    {
                        <tr class="@(!sub.IsRead ? "submission-row--unread" : null)">
                            @if (Auth.CanManageFormSubmissions)
                            {
                                <td>
                                    <input type="checkbox"
                                           checked="@_selectedIds.Contains(sub.Id)"
                                           @onchange="e => ToggleSelected(sub.Id, e.Value)" />
                                </td>
                            }
                            <td>
                                <strong>@sub.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy")</strong>
                                @if (!sub.IsRead)
                                {
                                    <span class="unread-dot" title="@T("Unread")"></span>
                                }
                                <span class="form-submissions-table__time">@sub.SubmittedAt.ToLocalTime().ToString("HH:mm")</span>
                            </td>
                            <td>
                                <strong>@DisplayFormName(sub)</strong>
                                <span class="form-submissions-table__muted">@sub.FormKey</span>
                            </td>
                            <td>
                                <strong>@PrimarySender(sub)</strong>
                                <span class="form-submissions-table__summary">@Summary(sub)</span>
                            </td>
                            <td><span class="status-pill @StatusPillClass(sub.Status)">@StatusLabel(sub.Status)</span></td>
                            <td>@EmptyFallback(sub.AssignedToAdminName)</td>
                            <td><span class="form-submissions-table__source">@EmptyFallback(sub.SourcePage)</span></td>
                            <td>@sub.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <button class="btn-admin btn-secondary" @onclick="() => OpenDetail(sub)">@T("View")</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-data-footer">
            <span class="text-muted">@ShowingText</span>
            <div class="admin-data-footer__actions">
                @for (var page = 1; page <= TotalPages; page++)
                {
                    var pageNumber = page;
                    <button class="btn-admin @(_page == pageNumber ? "btn-primary" : "btn-ghost")"
                            @onclick="() => SetPage(pageNumber)">
                        @pageNumber
                    </button>
                }
            </div>
        </div>
    }
</div>

@if (_detail is not null)
{
    <div class="modal-backdrop" @onclick="CloseDetail">
        <div class="modal-box form-submission-detail" @onclick:stopPropagation="true">
            <div class="modal-header">@T("SubmissionDetail")</div>
            <div class="modal-body">
                <div class="submission-detail__header">
                    <div>
                        <strong>@DisplayFormName(_detail)</strong>
                        <div class="text-muted">@EmptyFallback(_detail.SourcePage)</div>
                    </div>
                    <label class="form-filter">
                        <span>@T("Status")</span>
                        <select class="form-control" @bind="_detail.Status" disabled="@(!Auth.CanManageFormSubmissions)">
                            @foreach (var status in Enum.GetValues<FormSubmissionStatusModel>())
                            {
                                <option value="@status">@StatusLabel(status)</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="submission-detail__meta">
                    <div>
                        <span>@T("SubmittedTime")</span>
                        <strong>@_detail.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</strong>
                    </div>
                    <div>
                        <span>@T("Updated")</span>
                        <strong>@_detail.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</strong>
                    </div>
                    <div>
                        <span>@T("Language")</span>
                        <strong>@EmptyFallback(_detail.Language)</strong>
                    </div>
                    <div>
                        <span>@T("FormKey")</span>
                        <strong>@EmptyFallback(_detail.FormKey)</strong>
                    </div>
                    <div>
                        <span>@T("AssignedTo")</span>
                        <strong>@EmptyFallback(_detail.AssignedToAdminName)</strong>
                    </div>
                    <div>
                        <span>@T("ReadStatus")</span>
                        <strong>@(_detail.IsRead ? T("Read") : T("Unread"))</strong>
                    </div>
                </div>

                @if (Auth.CanManageFormSubmissions)
                {
                    <label class="form-filter" style="margin-bottom:1rem">
                        <span>@T("AssignedTo")</span>
                        <select class="form-control" @bind="_detail.AssignedToAdminId">
                            <option value="">@T("Unassigned")</option>
                            @foreach (var assignee in _assignees)
                            {
                                <option value="@assignee.Id">@assignee.DisplayName (@assignee.Email)</option>
                            }
                        </select>
                    </label>
                }

                <section>
                    <h3 class="submission-detail__section-title">@T("SubmissionValues")</h3>
                    <div class="submission-detail__fields">
                        @foreach (var field in _detail.Fields.OrderBy(f => f.Order))
                        {
                            <div class="detail-field">
                                <strong>
                                    @EmptyFallback(field.Label)
                                    @if (IsDeletedField(field))
                                    {
                                        <span class="deleted-field-badge">@T("OldDeletedField")</span>
                                    }
                                </strong>
                                <span>@EmptyFallback(field.Value)</span>
                            </div>
                        }
                    </div>
                </section>

                <label class="form-filter">
                    <span>@T("InternalNotes")</span>
                    <textarea class="form-control" rows="4" @bind="_detail.InternalNotes" disabled="@(!Auth.CanManageFormSubmissions)"></textarea>
                </label>

                <section class="submission-timeline">
                    <h3 class="submission-detail__section-title">@T("SubmissionActivity")</h3>
                    @if (_detail.Timeline.Count == 0)
                    {
                        <div class="text-muted">@T("NoActivityYet")</div>
                    }
                    else
                    {
                        @foreach (var item in _detail.Timeline.OrderByDescending(item => item.CreatedAt))
                        {
                            <div class="submission-timeline__item">
                                <span class="submission-timeline__dot"></span>
                                <div>
                                    <strong>@TimelineLabel(item)</strong>
                                    <p>@item.Message</p>
                                    <small>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") - @EmptyFallback(item.ActorName)</small>
                                </div>
                            </div>
                        }
                    }
                </section>
            </div>
            <div class="modal-footer">
                <button class="btn-admin btn-ghost" @onclick="CloseDetail">@T("Close")</button>
                @if (Auth.CanManageFormSubmissions)
                {
                    <button class="btn-admin btn-primary" @onclick="SaveDetail">@T("Save")</button>
                }
            </div>
        </div>
    </div>
}
}

<style>
    .form-submissions__stats { margin-bottom:1rem; }
    .form-submissions__filters { grid-template-columns:minmax(260px,1.2fr) minmax(150px,.65fr) minmax(150px,.65fr) minmax(140px,.45fr) minmax(140px,.45fr) auto; align-items:end; }
    .form-submissions__filter-actions { display:flex; gap:.5rem; flex-wrap:wrap; justify-content:flex-end; }
    .form-stat--total { --admin-data-color:#0d47a1; }
    .form-stat--new { --admin-data-color:#2563eb; }
    .form-stat--inprogress { --admin-data-color:#d97706; }
    .form-stat--resolved { --admin-data-color:#16a34a; }
    .form-filter span { font-size:.78rem; color:#64748b; }
    .form-filter { display:flex; flex-direction:column; gap:.25rem; }
    .form-control { border:1px solid #cbd5e1; border-radius:6px; padding:.55rem .65rem; background:#fff; min-height:38px; }
    .form-submissions-table th { white-space:nowrap; }
    .form-submissions-table td { vertical-align:middle; }
    .submission-row--unread { background:#f8fbff; }
    .submission-row--unread td:first-child { box-shadow:inset 4px 0 #2563eb; }
    .unread-dot { display:inline-block; width:8px; height:8px; border-radius:999px; background:#2563eb; margin-left:.35rem; vertical-align:middle; }
    .form-submissions-table__time,
    .form-submissions-table__muted,
    .form-submissions-table__summary { display:block; color:#64748b; font-size:.8rem; margin-top:.15rem; }
    .form-submissions-table__summary { max-width:420px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .form-submissions-table__source { display:inline-block; max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .status-pill { display:inline-flex; border-radius:999px; padding:.22rem .55rem; font-size:.78rem; font-weight:700; background:#e2e8f0; color:#0f172a; }
    .status-new { background:#dbeafe; color:#1d4ed8; }
    .status-inprogress { background:#fef3c7; color:#92400e; }
    .status-resolved { background:#dcfce7; color:#166534; }
    .status-spam { background:#fee2e2; color:#991b1b; }
    .status-archived { background:#e2e8f0; color:#475569; }
    .form-submission-detail { max-width:820px; width:min(820px, calc(100vw - 2rem)); }
    .submission-detail__header { display:grid; grid-template-columns:1fr 200px; gap:1rem; margin-bottom:1rem; align-items:start; }
    .submission-detail__meta { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:.75rem; margin-bottom:1rem; }
    .submission-detail__meta div { border:1px solid #e2e8f0; border-radius:8px; padding:.65rem; background:#f8fafc; }
    .submission-detail__meta span { display:block; color:#64748b; font-size:.78rem; margin-bottom:.2rem; }
    .submission-detail__meta strong { display:block; color:#0f172a; font-size:.86rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .submission-detail__section-title { font-size:.95rem; margin:0 0 .5rem; color:#0f172a; }
    .submission-detail__fields { display:grid; gap:.25rem; margin-bottom:1rem; }
    .detail-field { display:grid; grid-template-columns:190px 1fr; gap:.75rem; border-bottom:1px solid #e2e8f0; padding:.5rem 0; }
    .detail-field strong { display:flex; align-items:center; gap:.35rem; flex-wrap:wrap; }
    .detail-field span { overflow-wrap:anywhere; }
    .deleted-field-badge { display:inline-flex; border-radius:999px; padding:.12rem .38rem; background:#f1f5f9; color:#64748b; font-size:.68rem; font-weight:700; }
    .submission-timeline { margin-top:1rem; }
    .submission-timeline__item { position:relative; display:grid; grid-template-columns:18px 1fr; gap:.55rem; padding:.55rem 0; border-top:1px solid #e2e8f0; }
    .submission-timeline__dot { width:9px; height:9px; margin-top:.35rem; border-radius:999px; background:#b99a4a; box-shadow:0 0 0 4px rgba(185,154,74,.16); }
    .submission-timeline__item p { margin:.15rem 0; color:#334155; }
    .submission-timeline__item small { color:#64748b; }
    @@media (max-width: 1100px) {
        .form-submissions__filters { grid-template-columns:1fr 1fr; }
        .form-filter--search { grid-column:1 / -1; }
        .form-submissions__filter-actions { justify-content:flex-start; }
    }
    @@media (max-width: 760px) {
        .form-submissions__filters,
        .submission-detail__header,
        .submission-detail__meta,
        .detail-field { grid-template-columns:1fr; }
    }
</style>

@code {
    private const int PageSize = 20;

    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private List<FormSubmissionModel> _submissions = new();
    private List<FormSubmissionModel> _filteredSubmissions = new();
    private List<FormDefinitionModel> _definitions = new();
    private List<FormSubmissionAssigneeModel> _assignees = new();
    private HashSet<string> _selectedIds = new();
    private FormSubmissionModel? _detail;
    private bool _hasAccess = true;
    private bool _loading = true;
    private bool _exporting;
    private int _page = 1;
    private string _search = string.Empty;
    private string _formId = string.Empty;
    private string _statusFilter = string.Empty;
    private string _fromDate = string.Empty;
    private string _toDate = string.Empty;

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    private IEnumerable<FormSubmissionModel> PagedSubmissions =>
        _filteredSubmissions.Skip((_page - 1) * PageSize).Take(PageSize);

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(_filteredSubmissions.Count / (double)PageSize));

    private bool AllPagedSelected =>
        PagedSubmissions.Any() && PagedSubmissions.All(submission => _selectedIds.Contains(submission.Id));

    private string ShowingText
    {
        get
        {
            if (_filteredSubmissions.Count == 0)
                return string.Format(T("ShowingRange"), 0, 0, 0);

            var start = ((_page - 1) * PageSize) + 1;
            var end = Math.Min(_page * PageSize, _filteredSubmissions.Count);
            return string.Format(T("ShowingRange"), start, end, _filteredSubmissions.Count);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Auth.RefreshSessionAsync();
        _hasAccess = Auth.CanViewFormSubmissions;
        if (!_hasAccess)
        {
            _loading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync(bool resetPage = true)
    {
        _loading = true;
        if (resetPage) _page = 1;

        var status = Enum.TryParse<FormSubmissionStatusModel>(_statusFilter, out var parsed)
            ? parsed
            : (FormSubmissionStatusModel?)null;
        var submissions = await FormService.GetAllAsync(
            null,
            status,
            _search,
            ParseDate(_fromDate),
            ParseDate(_toDate),
            _formId);
        var definitions = Auth.CanViewFormDefinitions
            ? await FormService.GetDefinitionsAsync()
            : new ApiResponse<List<FormDefinitionModel>> { Success = true, Data = new() };
        var assignees = Auth.CanManageFormSubmissions
            ? await FormService.GetAssigneesAsync()
            : new ApiResponse<List<FormSubmissionAssigneeModel>> { Success = true, Data = new() };

        if (!submissions.Success)
        {
            Http.Toast(submissions.Message, submissions.StatusCode);
            if (submissions.StatusCode is 401 or 403)
                _hasAccess = false;
        }

        if (!definitions.Success)
            Http.Toast(definitions.Message, definitions.StatusCode);
        if (!assignees.Success)
            Http.Toast(assignees.Message, assignees.StatusCode);

        _submissions = submissions.Data ?? new();
        _filteredSubmissions = _submissions;
        _definitions = definitions.Data ?? new();
        _assignees = assignees.Data ?? new();
        _page = Math.Clamp(_page, 1, TotalPages);
        _selectedIds.Clear();
        _loading = false;
    }

    private async Task ApplyFilters() => await LoadAsync();

    private async Task ResetFilters()
    {
        _search = string.Empty;
        _formId = string.Empty;
        _statusFilter = string.Empty;
        _fromDate = string.Empty;
        _toDate = string.Empty;
        await LoadAsync();
    }

    private void OnFilterChanged()
    {
        _page = 1;
        _selectedIds.Clear();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _page = 1;
        _selectedIds.Clear();
    }

    private void OnFromDateChanged(ChangeEventArgs e)
    {
        _fromDate = e.Value?.ToString() ?? string.Empty;
        _page = 1;
        _selectedIds.Clear();
    }

    private void OnToDateChanged(ChangeEventArgs e)
    {
        _toDate = e.Value?.ToString() ?? string.Empty;
        _page = 1;
        _selectedIds.Clear();
    }

    private async Task ExportAsync()
    {
        _exporting = true;
        try
        {
            var status = Enum.TryParse<FormSubmissionStatusModel>(_statusFilter, out var parsed)
                ? parsed
                : (FormSubmissionStatusModel?)null;

            var result = await FormService.ExportAsync(
                null,
                status,
                _search,
                ParseDate(_fromDate),
                ParseDate(_toDate),
                _formId,
                AdminLanguage);

            if (result.Success)
            {
                await JS.InvokeVoidAsync(
                    "adminDownloads.downloadBase64",
                    result.FileName,
                    result.ContentType,
                    Convert.ToBase64String(result.Bytes));
            }
            else
            {
                Http.Toast(result.Message, result.StatusCode);
            }
        }
        finally
        {
            _exporting = false;
        }
    }

    private int Count(FormSubmissionStatusModel status) =>
        _submissions.Count(s => s.Status == status);

    private void ToggleSelected(string id, object? value)
    {
        var selected = value is bool b && b;
        if (selected) _selectedIds.Add(id);
        else _selectedIds.Remove(id);
    }

    private void ToggleAllPaged(ChangeEventArgs e)
    {
        var selected = e.Value is bool b && b;
        foreach (var submission in PagedSubmissions)
        {
            if (selected) _selectedIds.Add(submission.Id);
            else _selectedIds.Remove(submission.Id);
        }
    }

    private async Task BulkStatus(FormSubmissionStatusModel status)
    {
        var res = await FormService.BulkStatusAsync(_selectedIds.ToList(), status);
        Http.Toast(res.Message, res.StatusCode);
        await LoadAsync(false);
    }

    private async Task BulkDelete()
    {
        var res = await FormService.BulkDeleteAsync(_selectedIds.ToList());
        Http.Toast(res.Message, res.StatusCode);
        await LoadAsync(false);
    }

    private async Task OpenDetail(FormSubmissionModel sub)
    {
        var res = await FormService.GetAsync(sub.Id);
        if (res.Success && res.Data is not null)
        {
            _detail = Clone(res.Data);
            UpsertSubmission(res.Data);
            return;
        }

        Http.Toast(res.Message, res.StatusCode);
        _detail = Clone(sub);
    }

    private void CloseDetail() => _detail = null;

    private async Task SaveDetail()
    {
        if (_detail is null) return;
        var res = await FormService.UpdateAsync(_detail.Id, new FormSubmissionUpdateRequest
        {
            Status = _detail.Status,
            InternalNotes = _detail.InternalNotes,
            AssignedToAdminId = string.IsNullOrWhiteSpace(_detail.AssignedToAdminId) ? null : _detail.AssignedToAdminId
        });
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null)
            UpsertSubmission(res.Data);
        _detail = null;
        await LoadAsync(false);
    }

    private void SetPage(int page)
    {
        _page = Math.Clamp(page, 1, TotalPages);
        _selectedIds.Clear();
    }

    private string Summary(FormSubmissionModel sub) =>
        string.Join(" - ", sub.Fields
            .Where(field => !string.IsNullOrWhiteSpace(field.Value))
            .Take(4)
            .Select(field => $"{EmptyFallback(field.Label)}: {field.Value}"));

    private static string PrimarySender(FormSubmissionModel sub)
    {
        var preferred = sub.Fields.FirstOrDefault(field =>
            !string.IsNullOrWhiteSpace(field.Value) &&
            (field.Key.Contains("email", StringComparison.OrdinalIgnoreCase) ||
             field.Key.Contains("name", StringComparison.OrdinalIgnoreCase) ||
             field.Key.Contains("phone", StringComparison.OrdinalIgnoreCase)));

        return preferred?.Value
               ?? sub.Fields.FirstOrDefault(field => !string.IsNullOrWhiteSpace(field.Value))?.Value
               ?? "-";
    }

    private string DisplayFormName(FormSubmissionModel sub) =>
        string.IsNullOrWhiteSpace(sub.FormName) ? EmptyFallback(sub.FormKey) : sub.FormName;

    private bool IsDeletedField(FormSubmissionFieldModel field)
    {
        if (field.IsDeletedField)
            return true;

        if (_detail is null || _definitions.Count == 0)
            return false;

        var definition = ResolveDefinitionForSubmission(_detail);
        if (definition is null)
            return false;

        return !definition.Fields.Any(activeField =>
            string.Equals(activeField.Key, field.Key, StringComparison.OrdinalIgnoreCase));
    }

    private FormDefinitionModel? ResolveDefinitionForSubmission(FormSubmissionModel submission)
    {
        if (!string.IsNullOrWhiteSpace(submission.FormId))
        {
            var byId = _definitions.FirstOrDefault(item =>
                string.Equals(item.Id, submission.FormId, StringComparison.Ordinal));
            if (byId is not null)
                return byId;
        }

        return _definitions.FirstOrDefault(item =>
            string.Equals(item.Key, submission.FormKey, StringComparison.OrdinalIgnoreCase));
    }

    private void UpsertSubmission(FormSubmissionModel updated)
    {
        Replace(_submissions, updated);
        Replace(_filteredSubmissions, updated);
    }

    private static void Replace(List<FormSubmissionModel> list, FormSubmissionModel updated)
    {
        var index = list.FindIndex(item => item.Id == updated.Id);
        if (index >= 0) list[index] = updated;
    }

    private string StatusLabel(FormSubmissionStatusModel status) => status switch
    {
        FormSubmissionStatusModel.InProgress => T("InProgress"),
        FormSubmissionStatusModel.New => T("New"),
        FormSubmissionStatusModel.Resolved => T("Resolved"),
        FormSubmissionStatusModel.Archived => T("Archived"),
        FormSubmissionStatusModel.Spam => T("Spam"),
        _ => status.ToString()
    };

    private static string StatusPillClass(FormSubmissionStatusModel status) =>
        $"status-{status.ToString().ToLowerInvariant()}";

    private string Text(Dictionary<string, string>? values, string fallback) =>
        values?.GetValueOrDefault(AdminLanguage) is { Length: > 0 } localized
            ? localized
            : values?.GetValueOrDefault("en") is { Length: > 0 } english
                ? english
                : values?.Values.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v)) ?? fallback;

    private static DateTime? ParseDate(string value) =>
        DateTime.TryParse(value, out var parsed) ? parsed.Date : null;

    private static string EmptyFallback(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();

    private string TimelineLabel(FormSubmissionTimelineEventModel item) => item.EventType switch
    {
        "created" => T("TimelineCreated"),
        "viewed" => T("TimelineViewed"),
        "status-changed" => T("TimelineStatusChanged"),
        "note-updated" => T("TimelineNoteUpdated"),
        "assigned" => T("TimelineAssigned"),
        "unassigned" => T("TimelineUnassigned"),
        _ => item.EventType
    };

    private static FormSubmissionModel Clone(FormSubmissionModel source) => new()
    {
        Id = source.Id,
        FormId = source.FormId,
        FormKey = source.FormKey,
        FormName = source.FormName,
        Language = source.Language,
        SourcePage = source.SourcePage,
        Status = source.Status,
        Fields = source.Fields.Select(f => new FormSubmissionFieldModel
        {
            Key = f.Key,
            Label = f.Label,
            Type = f.Type,
            Value = f.Value,
            Order = f.Order,
            IsDeletedField = f.IsDeletedField
        }).ToList(),
        InternalNotes = source.InternalNotes,
        AssignedToAdminId = source.AssignedToAdminId,
        AssignedToAdminName = source.AssignedToAdminName,
        IsRead = source.IsRead,
        ViewedAt = source.ViewedAt,
        ViewedByAdminId = source.ViewedByAdminId,
        Timeline = source.Timeline.Select(item => new FormSubmissionTimelineEventModel
        {
            EventType = item.EventType,
            Message = item.Message,
            ActorId = item.ActorId,
            ActorName = item.ActorName,
            CreatedAt = item.CreatedAt
        }).ToList(),
        SubmittedAt = source.SubmittedAt,
        UpdatedAt = source.UpdatedAt
    };
}
