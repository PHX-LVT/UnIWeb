@inject AdminSectionService SectionService
@inject IHttpService Http
@inject AdminFormSubmissionService FormService

<div class="form-group">
    <label class="form-label">@T("Layout")</label>
    <DxComboBox Data="_layouts" @bind-Value="_layout" CssClass="w-100" />
</div>

<div class="form-group">
    <label class="form-label">@T("HeadingSize")</label>
    <DxComboBox Data="_sizes" @bind-Value="_headingSize" CssClass="w-100" />
</div>

<div class="form-group">
    <label class="form-label">@T("ContentAlignment")</label>
    <DxComboBox Data="_alignments" @bind-Value="_alignment" CssClass="w-100" />
</div>

<div class="form-group">
    <label class="form-label">@T("Eyebrow")</label>
    <LangField @bind-Value="_eyebrow" Languages="Languages" />
</div>

<div class="form-group">
    <label class="form-label">@T("Heading")</label>
    <LangField @bind-Value="_heading" Languages="Languages" />
</div>

<div class="form-group">
    <label class="form-label">@T("Subheading")</label>
    <LangField @bind-Value="_subheading" Languages="Languages" Multiline="true" />
</div>

<div class="form-group">
    <label class="form-label">@T("HeroImage")</label>
    @if (!string.IsNullOrEmpty(_imageUrl))
    {
        <div style="margin-bottom:.75rem">
            <img src="@_imageUrl"
                 style="max-height:120px;border-radius:6px;
                        border:1px solid var(--border)" />
            <button class="btn-admin btn-ghost" style="margin-left:.5rem"
                    @onclick="RemoveImage">
                <i class="fas fa-times"></i> @T("Remove")
            </button>
        </div>
    }
    <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
        <InputFile id="hero-section-image-upload"
                   OnChange="OnImageSelected"
                   accept="image/*"
                   style="display:none" />
        <label class="btn-admin btn-ghost" for="hero-section-image-upload">
            <i class="fas fa-image"></i> @T("UploadNew")
        </label>
        <button type="button" class="btn-admin btn-ghost" @onclick="OpenResourcePicker">
            <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
        </button>
    </div>
</div>

<ResourcePickerModal Open="_resourcePickerOpen"
                     Kind="image"
                     ResourceSelected="SelectResourceImage"
                     Closed="CloseResourcePicker" />

<div class="form-group">
    <label class="form-label">@T("Buttons")</label>
    @foreach (var (btn, i) in _buttons.Select((b, i) => (b, i)))
    {
        <div class="section-button-editor">
            <div class="section-button-cell section-button-cell--label">
                <span class="section-button-cell__label">@T("Label")</span>
                <LangField Value="@(btn.Label ?? new())"
                           ValueChanged="@(v => btn.Label = v)"
                           Languages="Languages"
                           NullText="@T("ButtonLabel")" />
            </div>
            <ButtonActionFields @bind-Action="btn.Action"
                                @bind-Href="btn.Href"
                                @bind-FormDefinitionId="btn.FormDefinitionId"
                                FormDefinitions="_formDefinitions"
                                AdminLanguage="AdminLanguage" />
            <div class="section-button-editor__footer">
                <div class="section-button-cell">
                    <span class="section-button-cell__label">@T("Style")</span>
                    <DxComboBox Data="_btnStyles" @bind-Value="btn.Style"
                                CssClass="w-100" />
                </div>
                <button class="btn-admin btn-danger"
                        @onclick="() => _buttons.RemoveAt(i)">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        </div>
    }
    @if (_buttons.Count < 4)
    {
        <button class="btn-admin btn-outline"
                @onclick="AddButton">
            <i class="fas fa-plus"></i> @T("AddButton")
        </button>
    }
</div>

<div style="display:flex;justify-content:flex-end;margin-top:.75rem">
    <button class="btn-admin btn-primary" @onclick="Save" disabled="@_saving">
        <i class="fas fa-save"></i> @(_saving ? T("Saving") : T("Save"))
    </button>
</div>

<style>
    .section-button-editor {
        display: grid;
        grid-template-columns: 1fr;
        gap: .55rem;
        align-items: stretch;
        margin-bottom: .6rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: .6rem;
    }

    .section-button-editor__footer {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 42px;
        gap: .5rem;
        align-items: end;
    }

    .section-button-cell {
        min-width: 0;
        display: grid;
        gap: 6px;
    }

    .section-button-cell__label {
        min-height: 18px;
        font-size: .75rem;
        color: var(--text-muted);
    }

    .section-button-editor .btn-danger {
        min-width: 42px;
        width: 42px;
        padding-inline: 0;
        justify-content: center;
        align-self: end;
    }

    @@media (max-width: 720px) {
        .section-button-editor {
            grid-template-columns: 1fr;
        }

        .section-button-editor__footer {
            grid-template-columns: 1fr;
        }

        .section-button-editor .btn-danger {
            width: 100%;
        }
    }
</style>

@code {
    [Parameter] public SectionModel  Section   { get; set; } = new();
    [Parameter] public string        PageId    { get; set; } = string.Empty;
    [Parameter] public List<string>  Languages { get; set; } = new() { "en" };
    [Parameter] public EventCallback OnSaved   { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string   _layout      = "centered";
    private string   _headingSize = "large";
    private string   _alignment   = "center";
    private string?  _imageUrl;
    private Dictionary<string, string> _eyebrow    = new();
    private Dictionary<string, string> _heading    = new();
    private Dictionary<string, string> _subheading = new();
    private List<SectionButtonModel>   _buttons    = new();
    private bool _saving;
    private string? _loadedSectionId;
    private bool _resourcePickerOpen;
    private List<FormDefinitionModel> _formDefinitions = new();

    private List<string> _layouts = new() { "centered", "split-left", "split-right" };
    private List<string> _sizes = new() { "small", "medium", "large", "xl" };
    private List<string> _alignments = new() { "left","center","right" };
    private List<string> _btnStyles = new() { "filled", "outline", "ghost" };
    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    protected override async Task OnInitializedAsync()
    {
        var forms = await FormService.GetDefinitionsAsync();
        _formDefinitions = forms.Data ?? new();
    }

    protected override void OnParametersSet()
    {
        if (_saving || _loadedSectionId == Section.Id) return;
        _loadedSectionId = Section.Id;

        _layout       = Section.Layout       ?? "centered";
        _headingSize  = Section.HeadingSize  ?? "large";
        _alignment    = Section.ContentAlignment ?? "center";
        _imageUrl = Section.ImageUrl;
        _eyebrow      = new(Section.Eyebrow    ?? new());
        _heading      = new(Section.Heading    ?? new());
        _subheading   = new(Section.Subheading ?? new());
        _buttons      = Section.Buttons?.Select(b => new SectionButtonModel
        {
            Id = b.Id, Label = b.Label, Action = NormalizeButtonAction(b.Action), Href = b.Href,
            FormDefinitionId = b.FormDefinitionId, Style = b.Style, Visible = b.Visible, Order = b.Order
        }).ToList() ?? new();
    }

    private void AddButton() => _buttons.Add(new SectionButtonModel
    {
        Label = new() { ["en"] = "Learn More" },
        Action = "linkToPage",
        Style = "filled",
        Visible = true,
        Order = _buttons.Count
    });

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 5 * 1024 * 1024) return;

        var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=hero", file, maxBytes: 5 * 1024 * 1024);
        if (res.Success && res.Data is not null)
        {
            _imageUrl = res.Data.Url;
            Http.Toast("Hero image uploaded.", res.StatusCode);
        }
        else
        {
            Http.Toast(res.Message ?? "Hero image upload failed.", res.StatusCode);
        }
    }

    private void RemoveImage()
    {
        _imageUrl = string.Empty;
    }

    private void OpenResourcePicker()
    {
        _resourcePickerOpen = true;
    }

    private void CloseResourcePicker()
    {
        _resourcePickerOpen = false;
    }

    private void SelectResourceImage(ManagedResourceModel resource)
    {
        _imageUrl = resource.Url;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var dto = new HeroSectionUpdateDto
            {
                Layout = _layout,
                HeadingSize = _headingSize,
                ContentAlignment = _alignment,
                Eyebrow = _eyebrow,
                Heading = _heading,
                Subheading = _subheading,
                ImageUrl = _imageUrl,
                Buttons = _buttons.Select(MapButton).ToList(),
                Visible = Section.Visible
            };
            var res = await SectionService.UpdateAsync(PageId, Section.Id, dto);
            Http.Toast(res.Message, res.StatusCode);
            if (res.Success) await OnSaved.InvokeAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private static string NormalizeButtonAction(string? action) => IsOpenFormAction(action) ? "openForm" : "linkToPage";

    private static bool IsOpenFormAction(string? action) =>
        string.Equals(action, "openForm", StringComparison.OrdinalIgnoreCase)
        || string.Equals(action, "OpenForm", StringComparison.OrdinalIgnoreCase)
        || string.Equals(action, "OpenModal", StringComparison.OrdinalIgnoreCase);

    private static SectionButtonDto MapButton(SectionButtonModel button) => new()
    {
        Label = button.Label ?? new(),
        Action = NormalizeButtonAction(button.Action),
        Href = IsOpenFormAction(button.Action) ? null : button.Href,
        FormDefinitionId = IsOpenFormAction(button.Action) ? button.FormDefinitionId : null,
        Style = button.Style ?? "filled",
        Visible = button.Visible,
        Order = button.Order
    };
}

