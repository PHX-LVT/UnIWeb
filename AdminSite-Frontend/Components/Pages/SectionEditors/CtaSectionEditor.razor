@inject AdminSectionService SectionService
@inject IHttpService Http
@inject AdminFormSubmissionService FormService

<div class="form-group">
    <label class="form-label">@T("Layout")</label>
    <DxComboBox Data="_layouts" @bind-Value="_layout" CssClass="w-100" />
</div>

<div class="form-group">
    <label class="form-label">@T("Heading")</label>
    <LangField @bind-Value="_heading" Languages="Languages" />
</div>

<div class="form-group">
    <label class="form-label">@T("Subtext")</label>
    <LangField @bind-Value="_subtext" Languages="Languages" Multiline="true" />
</div>

<div class="form-group">
    <label class="form-label">@T("Buttons")</label>
    @foreach (var (button, i) in _buttons.Select((x, i) => (x, i)))
    {
        <div class="section-button-editor">
            <div class="section-button-cell section-button-cell--label">
                <span class="section-button-cell__label">@T("Label")</span>
                <LangField Value="@(button.Label ?? new())"
                           ValueChanged="@(v => button.Label = v)"
                           Languages="Languages"
                           NullText="@T("ButtonLabel")" />
            </div>
            <ButtonActionFields @bind-Action="button.Action"
                                @bind-Href="button.Href"
                                @bind-FormDefinitionId="button.FormDefinitionId"
                                FormDefinitions="_formDefinitions"
                                AdminLanguage="AdminLanguage" />
            <div class="section-button-editor__footer">
                <div class="section-button-cell">
                    <span class="section-button-cell__label">@T("Style")</span>
                    <DxComboBox Data="_btnStyles" @bind-Value="button.Style" CssClass="w-100" />
                </div>
                <button class="btn-admin btn-danger" @onclick="() => RemoveButton(i)"><i class="fas fa-trash"></i></button>
            </div>
        </div>
    }
    <button class="btn-admin btn-outline" @onclick="AddButton"><i class="fas fa-plus"></i> @T("AddButton")</button>
</div>

<style>
    .section-button-editor {
        display: grid;
        grid-template-columns: 1fr;
        gap: .55rem;
        align-items: stretch;
        margin-bottom: .6rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: .65rem;
    }

    .section-button-editor__footer {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 42px;
        gap: .5rem;
        align-items: end;
    }

    .section-button-cell {
        min-width: 0;
        display: grid;
        gap: 6px;
    }

    .section-button-cell__label {
        min-height: 18px;
        font-size: .75rem;
        color: var(--text-muted);
    }

    .section-button-editor .btn-danger {
        min-width: 42px;
        width: 42px;
        padding-inline: 0;
        justify-content: center;
        align-self: end;
    }

    @@media (max-width: 720px) {
        .section-button-editor {
            grid-template-columns: 1fr;
        }

        .section-button-editor__footer {
            grid-template-columns: 1fr;
        }

        .section-button-editor .btn-danger {
            width: 100%;
        }
    }
</style>

<div style="display:flex;justify-content:flex-end;margin-top:.75rem">
    <button class="btn-admin btn-primary" @onclick="Save" disabled="@_saving">
        <i class="fas fa-save"></i> @(_saving ? T("Saving") : T("Save"))
    </button>
</div>

@code {
    [Parameter] public SectionModel Section { get; set; } = new();
    [Parameter] public string PageId { get; set; } = string.Empty;
    [Parameter] public List<string> Languages { get; set; } = new() { "en" };
    [Parameter] public EventCallback OnSaved { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string _layout = "center";
    private Dictionary<string, string> _heading = new();
    private Dictionary<string, string> _subtext = new();
    private List<SectionButtonModel> _buttons = new();
    private bool _saving;
    private string? _loadedSectionId;
    private List<FormDefinitionModel> _formDefinitions = new();

    private List<string> _layouts = new() { "center", "left", "right", "final-card" };
    private List<string> _btnStyles = new() { "filled", "outline", "ghost" };
    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    protected override async Task OnInitializedAsync()
    {
        var forms = await FormService.GetDefinitionsAsync();
        _formDefinitions = forms.Data ?? new();
    }

    protected override void OnParametersSet()
    {
        if (_saving || _loadedSectionId == Section.Id) return;
        _loadedSectionId = Section.Id;

        _layout = NormalizeLegacyLayout(Section.Layout);
        _heading = new(Section.Heading ?? new());
        _subtext = new(Section.Subtext ?? new());

        var sourceButtons = Section.Buttons is { Count: > 0 }
            ? Section.Buttons
            : Section.Button is not null ? new() { Section.Button } : new List<SectionButtonModel>();

        _buttons = sourceButtons.Select((button, i) => new SectionButtonModel
        {
            Id = button.Id,
            Label = button.Label is null ? new() : new(button.Label),
            Action = NormalizeButtonAction(button.Action),
            Href = button.Href,
            FormDefinitionId = button.FormDefinitionId,
            Style = NormalizeButtonStyle(button.Style),
            Visible = button.Visible,
            Order = i
        }).ToList();
    }

    private void AddButton() => _buttons.Add(new SectionButtonModel
    {
        Label = new() { ["en"] = "Learn More" },
        Action = "linkToPage",
        Style = "filled",
        Visible = true,
        Order = _buttons.Count
    });

    private void RemoveButton(int index)
    {
        if (index < 0 || index >= _buttons.Count) return;
        _buttons.RemoveAt(index);
        for (var i = 0; i < _buttons.Count; i++) _buttons[i].Order = i;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var mappedButtons = _buttons.Select((button, i) => MapButton(button, i)).ToList();
            var res = await SectionService.UpdateAsync(PageId, Section.Id, new CtaSectionUpdateDto
            {
                Layout = _layout,
                Heading = _heading,
                Subtext = _subtext,
                Button = mappedButtons.FirstOrDefault(),
                Buttons = mappedButtons,
                Visible = Section.Visible
            });
            Http.Toast(res.Message, res.StatusCode);
            if (res.Success) await OnSaved.InvokeAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private static SectionButtonDto MapButton(SectionButtonModel button, int order) => new()
    {
        Label = button.Label ?? new(),
        Action = NormalizeButtonAction(button.Action),
        Href = IsOpenFormAction(button.Action) ? null : button.Href,
        FormDefinitionId = IsOpenFormAction(button.Action) ? button.FormDefinitionId : null,
        Style = NormalizeButtonStyle(button.Style),
        Visible = button.Visible,
        Order = order
    };

    private static string NormalizeButtonAction(string? action) => IsOpenFormAction(action) ? "openForm" : "linkToPage";

    private static bool IsOpenFormAction(string? action) =>
        string.Equals(action, "openForm", StringComparison.OrdinalIgnoreCase)
        || string.Equals(action, "OpenForm", StringComparison.OrdinalIgnoreCase)
        || string.Equals(action, "OpenModal", StringComparison.OrdinalIgnoreCase);

    private static string NormalizeButtonStyle(string? style) => style switch
    {
        "primary" => "filled",
        "secondary" => "outline",
        "outline" => "outline",
        "ghost" => "ghost",
        _ => "filled"
    };

    private static string NormalizeLegacyLayout(string? layout) => layout switch
    {
        "centered" => "center",
        "stacked" => "center",
        null or "" => "center",
        _ => layout
    };
}
