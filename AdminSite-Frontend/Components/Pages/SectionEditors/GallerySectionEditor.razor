@inject AdminSectionService SectionService
@inject IHttpService Http

<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem">
    <div class="form-group">
        <label class="form-label">@T("Layout")</label>
        <DxComboBox Data="_layouts" @bind-Value="_layout" CssClass="w-100" />
    </div>
    <div class="form-group">
        <label class="form-label">@T("Columns")</label>
        <DxSpinEdit @bind-Value="_columns" MinValue="1" MaxValue="4" CssClass="w-100" />
    </div>
    <div class="form-group">
        <label class="form-label">@T("Gap")</label>
        <DxComboBox Data="_gaps" @bind-Value="_gap" CssClass="w-100" />
    </div>
</div>

<div class="form-group">
    <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
        <DxCheckBox @bind-Checked="_showCaptions" /> @T("ShowCaptions")
    </label>
</div>

<div class="form-group">
    <label class="form-label">@T("Images") (@_images.Count)</label>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));
                gap:.75rem;margin-top:.5rem">
        @foreach (var (img, i) in _images.Select((x, i) => (x, i)))
        {
            var idx = i;
            <div style="border:1px solid var(--border);border-radius:6px;
                        overflow:hidden;position:relative">
                @if (!string.IsNullOrEmpty(img.ImageUrl))
                {
                    <img src="@img.ImageUrl"
                         style="width:100%;height:90px;object-fit:cover" />
                }
                <div style="padding:4px 6px">
                    <LangField Value="@(img.Caption ?? new())"
                               ValueChanged="@(v => img.Caption = v)"
                               Languages="Languages"
                               NullText="@T("Caption")" />
                </div>
                <button class="btn-admin btn-danger"
                        style="position:absolute;top:4px;right:4px;padding:2px 6px"
                   @onclick="() => _images.RemoveAt(idx)">
                        <i class="fas fa-times"></i>
                </button>
            </div>
        }
        <label style="border:2px dashed var(--border);border-radius:6px;
                      height:120px;display:flex;flex-direction:column;
                      align-items:center;justify-content:center;
                      cursor:pointer;color:var(--text-muted);gap:6px">
            <i class="fas fa-plus-circle" style="font-size:1.5rem"></i>
            <span style="font-size:.8rem">@T("AddImage")</span>
            <InputFile OnChange="OnImagesSelected" accept="image/*" multiple
                       style="display:none" />
        </label>
    </div>
</div>

<div style="display:flex;justify-content:flex-end;margin-top:.75rem">
    <button class="btn-admin btn-primary" @onclick="Save" disabled="@_saving">
        <i class="fas fa-save"></i> @(_saving ? T("Saving") : T("Save"))
    </button>
</div>

@code {
    [Parameter] public SectionModel  Section { get; set; } = new();
    [Parameter] public string        PageId  { get; set; } = string.Empty;
    [Parameter] public List<string> Languages { get; set; } = new() { "en" };
    [Parameter] public EventCallback OnSaved { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string _layout      = "grid";
    private int    _columns     = 3;
    private string _gap         = "medium";
    private bool   _showCaptions = false;
    private List<GalleryImageModel> _images = new();
    private bool _saving;
    private string? _loadedSectionId;

    private List<string> _layouts = new() { "grid","masonry","carousel" };
    private List<string> _gaps    = new() { "none","small","medium","large" };
    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    protected override void OnParametersSet()
    {
        if (_saving || _loadedSectionId == Section.Id) return;
        _loadedSectionId = Section.Id;

        _layout       = Section.Layout       ?? "grid";
        _columns      = Section.Columns      ?? 3;
        _gap          = Section.Gap          ?? "medium";
        _showCaptions = Section.ShowCaptions ?? false;
        _images       = Section.Images?.Select(img => new GalleryImageModel
        {
            Id = img.Id, ImageUrl = img.ImageUrl,
            Caption = img.Caption, Visible = img.Visible, Order = img.Order
        }).ToList() ?? new();
    }

    private async Task OnImagesSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(20))
        {
            if (file.Size > 5 * 1024 * 1024) continue;
            var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=gallery", file, maxBytes: 5 * 1024 * 1024);
            if (res.Success && res.Data is not null)
            {
                _images.Add(new GalleryImageModel
                {
                    ImageUrl = res.Data.Url,
                    Visible = true,
                    Order = _images.Count
                });
            }
            else
            {
                Http.Toast(res.Message ?? "Gallery image upload failed.", res.StatusCode);
            }
        }
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var res = await SectionService.UpdateAsync(PageId, Section.Id, new GallerySectionUpdateDto
            {
                Layout = _layout,
                Columns = _columns,
                Gap = _gap,
                ShowCaptions = _showCaptions,
                Images = _images.Select(MapImage).ToList(),
                Visible = Section.Visible
            });
            Http.Toast(res.Message, res.StatusCode);
            if (res.Success) await OnSaved.InvokeAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private static GalleryImageDto MapImage(GalleryImageModel image) => new()
    {
        ImageUrl = image.ImageUrl,
        Caption = image.Caption ?? new(),
        Visible = image.Visible,
        Order = image.Order
    };
}
