<div class="ez-modal-overlay" @onclick="OnCancel">
    <div class="ez-modal" @onclick:stopPropagation="true">
        <div class="ez-modal__header">
            <h2>@T("AddSection")</h2>
            <button class="ez-icon-btn" @onclick="OnCancel">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="ez-modal__body">
            @foreach (var group in _templates)
            {
                <div class="ez-picker-group">
                    <h4 class="ez-picker-group__label">@T(group.Key)</h4>
                    <div class="ez-picker-grid">
                        @foreach (var template in group.Value)
                        {
                            <button class="ez-picker-card"
                                    @onclick="() => OnPicked.InvokeAsync(template.Type)">
                                <div class="ez-picker-card__icon">
                                    <i class="fas @template.Icon"></i>
                                </div>
                                <div class="ez-picker-card__text">
                                    <span>@T(template.NameKey)</span>
                                    <small>@T(template.DescriptionKey)</small>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnPicked { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private Dictionary<string, List<SectionTemplate>> _templates = new()
    {
        ["SectionGroupPageStructure"] = new()
        {
            new("hero",    "SectionTemplateHeroName", "fa-image", "SectionTemplateHeroDesc"),
            new("cta",     "SectionTemplateCtaName",  "fa-bullhorn", "SectionTemplateCtaDesc"),
            new("html",    "SectionTemplateHtmlName", "fa-code", "SectionTemplateHtmlDesc")
        },
        ["SectionGroupStructuredContent"] = new()
        {
            new("columns", "SectionTemplateColumnsName", "fa-columns", "SectionTemplateColumnsDesc"),
            new("list",    "SectionTemplateListName",    "fa-th-large", "SectionTemplateListDesc"),
            new("gallery", "SectionTemplateGalleryName", "fa-images", "SectionTemplateGalleryDesc"),
            new("stats",   "SectionTemplateStatsName",   "fa-chart-line", "SectionTemplateStatsDesc")
        },
        ["SectionGroupRepeaters"] = new()
        {
            new("testimonial", "SectionTemplateTestimonialName", "fa-comments", "SectionTemplateTestimonialDesc"),
            new("carousel",    "SectionTemplateCarouselName",    "fa-window-restore", "SectionTemplateCarouselDesc")
        },
        ["SectionGroupConnectedData"] = new()
        {
            new("showcase",    "SectionTemplateShowcaseName", "fa-sitemap", "SectionTemplateShowcaseDesc"),
            new("library",     "SectionTemplateLibraryName",  "fa-newspaper", "SectionTemplateLibraryDesc"),
            new("network-map", "SectionTemplateMapName",      "fa-map-location-dot", "SectionTemplateMapDesc")
        },
        ["SectionGroupComposition"] = new()
        {
            new("canvas", "SectionTemplateCanvasName", "fa-object-group", "SectionTemplateCanvasDesc")
        }
    };

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    private record SectionTemplate(string Type, string NameKey, string Icon, string DescriptionKey);
}
