@inject AdminBlockService BlockService
@inject IHttpService Http
@using Contracts.Admin
@using SharedComponents.Helpers

<div class="form-group">
    <label class="form-label">@T("EmbedUrl")</label>
    <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;margin-bottom:.5rem">
        <button type="button" class="btn-admin btn-ghost" @onclick="OpenResourcePicker">
            <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
        </button>
    </div>
    <DxTextBox @bind-Text="_embedUrl" CssClass="w-100"
               NullText="https://www.youtube.com/embed/..." />
    <div class="form-hint">
        @T("EmbedUrlHint")
    </div>
</div>

<ResourcePickerModal Open="_resourcePickerOpen"
                     Kind="video"
                     ResourceSelected="SelectResourceVideo"
                     Closed="CloseResourcePicker" />

@if (!string.IsNullOrEmpty(PreviewUrl))
{
    <div style="margin-top:.75rem;border-radius:8px;overflow:hidden;
        aspect-ratio:16/9;background:#000">
        <iframe src="@PreviewUrl" style="width:100%;height:100%;border:none"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen></iframe>
    </div>
}

<div style="display:flex;justify-content:flex-end;margin-top:.75rem">
    <button class="btn-admin btn-primary" @onclick="Save" disabled="@_saving">
        <i class="fas fa-save"></i> @(_saving ? T("Saving") : T("Save"))
    </button>
</div>

@code {
    [Parameter] public BlockModel Block { get; set; } = new();
    [Parameter] public string PageId { get; set; } = string.Empty;
    [Parameter] public string SectionId { get; set; } = string.Empty;
    [Parameter] public EventCallback OnSaved { get; set; }

    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string? _embedUrl;
    private bool _saving;
    private bool _resourcePickerOpen;
    private string? PreviewUrl => VideoUrlHelper.ToEmbedUrl(_embedUrl);

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    protected override void OnParametersSet()
    {
        _embedUrl = Block.EmbedUrl;
    }

    private void OpenResourcePicker()
    {
        _resourcePickerOpen = true;
    }

    private void CloseResourcePicker()
    {
        _resourcePickerOpen = false;
    }

    private void SelectResourceVideo(ManagedResourceModel resource)
    {
        _embedUrl = resource.Url;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var res = await BlockService.UpdateAsync(PageId, SectionId, Block.Id, new VideoBlockUpdateDto
            {
                EmbedUrl = PreviewUrl ?? _embedUrl ?? string.Empty,
                Visible = Block.Visible
            });
            Http.Toast(res.Message, res.StatusCode);
            if (res.Success) await OnSaved.InvokeAsync();
        }
        finally
        {
            _saving = false;
        }
    }
}
