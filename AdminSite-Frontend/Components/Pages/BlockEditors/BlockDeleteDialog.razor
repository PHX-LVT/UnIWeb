@using AdminSite.Models

<DxWindow Visible="@(Block is not null)"
          VisibleChanged="OnVisibleChanged"
          Width="360px"
          MaxWidth="calc(100vw - 32px)"
          ShowCloseButton="false"
          CloseOnEscape="true"
          AllowResize="false"
          HorizontalAlignment="HorizontalAlignment.Center"
          VerticalAlignment="VerticalAlignment.Center">
    <BodyTemplate>
        <div class="block-delete-dialog">
            <div class="block-delete-dialog__header">@ConfirmTitle</div>
            <div class="block-delete-dialog__body">
                <p>@((MarkupString)string.Format(T("DeleteBlockPrompt"), $"<strong>{Block?.Type}</strong>"))</p>
            </div>
            <div class="block-delete-dialog__footer">
                <button class="btn-admin btn-ghost"
                        @onclick="OnCancel">@CancelText</button>
                <button class="btn-admin btn-danger"
                        @onclick="OnConfirm">@DeleteText</button>
            </div>
        </div>
    </BodyTemplate>
</DxWindow>

@code {
    [Parameter] public BlockModel? Block { get; set; }
    [Parameter] public string ConfirmTitle { get; set; } = "Confirm delete";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public string DeleteText { get; set; } = "Delete";
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    private async Task OnVisibleChanged(bool visible)
    {
        if (!visible && OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
