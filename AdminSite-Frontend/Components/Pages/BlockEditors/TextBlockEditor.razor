@inject AdminBlockService BlockService
@inject IHttpService Http
@using Contracts.Admin

<div class="form-group">
    <label class="form-label">@T("Title")</label>
    <LangField @bind-Value="_title" Languages="Languages" />
</div>

<div class="form-group">
    <label class="form-label">@T("Content")</label>
    <LangField @bind-Value="_content" Languages="Languages" Multiline="true" />
</div>

<div style="display:flex;justify-content:flex-end;margin-top:.75rem">
    <button class="btn-admin btn-primary" @onclick="Save" disabled="@_saving">
        <i class="fas fa-save"></i> @(_saving ? T("Saving") : T("Save"))
    </button>
</div>

@code {
    [Parameter] public BlockModel Block { get; set; } = new();
    [Parameter] public string PageId { get; set; } = string.Empty;
    [Parameter] public string SectionId { get; set; } = string.Empty;
    [Parameter] public List<string> Languages { get; set; } = new() { "en" };
    [Parameter] public EventCallback OnSaved { get; set; }

    private Dictionary<string, string> _title = new();
    private Dictionary<string, string> _content = new();
    private bool _saving;

    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    protected override void OnParametersSet()
    {
        _title = new(Block.Title ?? new());
        _content = new(Block.Content ?? new());
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var res = await BlockService.UpdateAsync(PageId, SectionId, Block.Id, new TextBlockUpdateDto
            {
                Title = _title,
                Content = _content,
                Visible = Block.Visible
            });
            Http.Toast(res.Message, res.StatusCode);
            if (res.Success) await OnSaved.InvokeAsync();
        }
        finally
        {
            _saving = false;
        }
    }
}
