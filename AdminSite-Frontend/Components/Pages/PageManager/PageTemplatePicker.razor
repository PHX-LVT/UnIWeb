<div class="ez-modal-overlay" @onclick="OnCancel">
    <div class="ez-modal" @onclick:stopPropagation="true">
        <div class="ez-modal__header">
            <h2>@T("NewPage")</h2>
            <button class="ez-icon-btn" @onclick="OnCancel">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="ez-modal__body">
            <div class="ez-picker-grid">
                @foreach (var template in _templates)
                {
                    <button class="ez-picker-card"
                            @onclick="() => OnPicked.InvokeAsync(template.Type)">
                        <div class="ez-picker-card__icon">
                            <i class="fas @template.Icon"></i>
                        </div>
                        <span>@T(template.NameKey)</span>
                        <small>@T(template.DescriptionKey)</small>
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnPicked { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private List<PageTemplate> _templates = new()
    {
        new("blank",     "PageTemplateBlankName",     "fa-file",           "PageTemplateBlankDesc"),
        new("landing",   "PageTemplateLandingName",   "fa-rocket",         "PageTemplateLandingDesc"),
        new("about",     "PageTemplateAboutName",     "fa-users",          "PageTemplateAboutDesc"),
        new("contact",   "PageTemplateContactName",   "fa-envelope",       "PageTemplateContactDesc"),
        new("services",  "PageTemplateServicesName",  "fa-concierge-bell", "PageTemplateServicesDesc"),
        new("portfolio", "PageTemplatePortfolioName", "fa-briefcase",      "PageTemplatePortfolioDesc"),
        new("faq",       "PageTemplateFaqName",       "fa-question-circle", "PageTemplateFaqDesc")
    };

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    private record PageTemplate(string Type, string NameKey, string Icon, string DescriptionKey);
}
