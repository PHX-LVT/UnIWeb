@page "/global/branding"
@inject BrandingService BrandingService
@inject IHttpService Http

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-paint-brush"></i> Branding</h1>
    <div class="page-actions">
        <button class="btn-admin btn-primary" @onclick="Save" disabled="@_saving">
            <i class="fas fa-save"></i> @(_saving ? "Saving..." : "Save")
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="admin-card" style="text-align:center;padding:2rem">
        <div class="spinner" style="margin:0 auto"></div>
    </div>
}
else if (_model is not null)
{
    <div class="admin-card">
        <div class="admin-card-title">Company Info</div>

        <div class="form-group">
            <label class="form-label">Company Name</label>
            <DxTextBox @bind-Text="_model.CompanyName" CssClass="w-100" />
        </div>

        <div class="form-group">
            <label class="form-label">URL or Slug</label>
            <DxTextBox @bind-Text="_model.Href" CssClass="w-100" NullText="https://yoursite.com" />
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">Logo</div>

        @if (!string.IsNullOrEmpty(_model.LogoUrl))
        {
            <div style="margin-bottom:1rem">
                <img src="@_model.LogoUrl"
                     style="max-height:80px;border:1px solid var(--border);border-radius:6px;padding:6px" />
            </div>
            <button class="btn-admin btn-danger" type="button" @onclick="ClearLogo">
                <i class="fas fa-trash"></i> Delete Logo
            </button>
        }

        <InputFile OnChange="OnLogoSelected" accept=".png,.svg,.jpg,.jpeg" />
        <div class="form-hint">PNG or SVG recommended. Max 2MB.</div>
    </div>
}

@code {
    private BrandingModel? _model;
    private bool _loading = true;
    private bool _saving = false;

    protected override async Task OnInitializedAsync()
    {
        var res = await BrandingService.GetAsync();
        _model = res.Data ?? new BrandingModel();
        _loading = false;
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024) return;

        var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=branding", file, maxBytes: 2 * 1024 * 1024);
        if (res.Success && res.Data is not null)
        {
            _model!.LogoUrl = res.Data.Url;
            Http.Toast("Logo uploaded.", res.StatusCode);
        }
        else
        {
            Http.Toast(res.Message ?? "Logo upload failed.", res.StatusCode);
        }
        StateHasChanged();
    }

    private void ClearLogo()
    {
        if (_model is null) return;
        _model.LogoUrl = string.Empty;
    }

    private async Task Save()
    {
        if (_model is null) return;
        _saving = true;
        StateHasChanged();
        var res = await BrandingService.UpdateAsync(_model);
        if (res.Data is not null) _model = res.Data;
        Http.Toast(res.Message ?? "Branding saved.", res.StatusCode);
        _saving = false;
        StateHasChanged();
    }
}
