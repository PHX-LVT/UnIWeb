@page "/content/types"
@inject AdminContentService ContentService
@inject IHttpService Http
@inject AdminLanguageService AdminLanguageState

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-tags"></i> @T("ContentTypes")</h1>
</div>

<div style="display:grid;grid-template-columns:minmax(280px,360px) minmax(0,1fr);gap:1rem;align-items:start">
    <div class="admin-card">
        <h2 style="font-size:1rem;margin:0 0 1rem">@T(_editingId is null ? "CreateType" : "EditType")</h2>

        <label>@T("Key")</label>
        <input class="form-control"
               disabled="@(_editingId is not null)"
               placeholder="Key will be autogenerated from name if left blank"
               value="@_edit.Key"
               @oninput="e => _edit.Key = e.Value?.ToString() ?? string.Empty" />

        <div style="border-top:1px solid #e5e7eb;padding-top:1rem;margin-top:1rem">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:.75rem">
                <h3 style="font-size:.95rem;margin:0">@T("Content")</h3>
                <span class="text-muted" style="font-size:.85rem">@T("EditingLanguage"): @CurrentLang.ToUpperInvariant()</span>
            </div>

            <label>@T("Name")</label>
            <input class="form-control"
                   value="@GetValue(_edit.Name, CurrentLang)"
                   @oninput="e => SetValue(_edit.Name, CurrentLang, e.Value?.ToString())" />

            <label style="margin-top:.75rem">@T("Description")</label>
            <textarea class="form-control"
                      rows="3"
                      value="@GetValue(_edit.Description, CurrentLang)"
                      @oninput="e => SetValue(_edit.Description, CurrentLang, e.Value?.ToString())"></textarea>
        </div>

        <label style="display:flex;align-items:center;gap:.5rem;margin-top:.75rem">
            <input type="checkbox" @bind="_edit.RequiresBody" />
            @T("RequiresBody")
        </label>
        <label style="display:flex;align-items:center;gap:.5rem;margin-top:.5rem">
            <input type="checkbox" @bind="_edit.RequiresHeroImage" />
            @T("RequiresHeroImage")
        </label>
        <label style="display:flex;align-items:center;gap:.5rem;margin-top:.5rem">
            <input type="checkbox" @bind="_edit.RequiresFile" />
            @T("RequiresFile")
        </label>
        <label style="display:flex;align-items:center;gap:.5rem;margin-top:.5rem">
            <input type="checkbox" @bind="_edit.RequiresVideoUrl" />
            @T("RequiresVideoUrl")
        </label>
        <label style="display:flex;align-items:center;gap:.5rem;margin-top:.5rem">
            <input type="checkbox" @bind="_edit.AllowsAttachments" />
            @T("AllowsAttachments")
        </label>
        <label style="margin-top:.75rem">@T("ClickBehavior")</label>
        <select class="form-control" @bind="_edit.ClickBehavior">
            <option value="detail">@T("DetailPage")</option>
            <option value="download">@T("FileDownload")</option>
            <option value="video">@T("VideoModal")</option>
            <option value="external">@T("ExternalLink")</option>
        </select>
        <label style="display:flex;align-items:center;gap:.5rem;margin-top:.5rem">
            <input type="checkbox" @bind="_edit.Visible" />
            @T("Visible")
        </label>

        <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem">
            <button class="btn-admin btn-primary" @onclick="Save">
                <i class="fas fa-save"></i> @T("Save")
            </button>
            @if (_editingId is not null)
            {
                <button class="btn-admin btn-danger" @onclick="Delete">
                    <i class="fas fa-trash"></i> @T("Delete")
                </button>
            }
            <button class="btn-admin btn-ghost" @onclick="NewType">@T("Cancel")</button>
        </div>
    </div>

    <div class="admin-card">
        @if (_loading)
        {
            <p class="text-muted">@T("Loading")</p>
        }
        else if (!_types.Any())
        {
            <p class="text-muted">@T("NoContentTypesYet")</p>
        }
        else
        {
            <div style="overflow:auto">
                <table class="table" style="width:100%">
                    <thead>
                        <tr>
                            <th>@T("Name")</th>
                            <th>@T("Key")</th>
                            <th>@T("RequiresBody")</th>
                            <th>@T("ClickBehavior")</th>
                            <th>@T("Visible")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var type in _types)
                        {
                            <tr>
                                <td>@GetLang(type.Name)</td>
                                <td>@type.Key</td>
                                <td>@(type.RequiresBody ? T("Yes") : T("No"))</td>
                                <td>@DisplayClickBehavior(type.ClickBehavior)</td>
                                <td>@(type.Visible ? T("Yes") : T("No"))</td>
                                <td style="text-align:right">
                                    <button class="btn-admin btn-ghost" @onclick="() => Edit(type)">
                                        <i class="fas fa-edit"></i> @T("Edit")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private List<string> _languages = new() { "en" };
    private List<ContentTypeModel> _types = new();
    private ContentTypeRequest _edit = new();
    private string? _editingId;
    private bool _loading = true;

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);
    private string CurrentLang => NormalizeLang(AdminLanguage);

    protected override async Task OnInitializedAsync()
    {
        await AdminLanguageState.LoadSettingsAsync();
        _languages = AdminLanguageState.SupportedLanguages.ToList();
        _edit = NewRequest();
        await LoadTypes();
    }

    private async Task LoadTypes()
    {
        _loading = true;
        var res = await ContentService.GetTypesAsync();
        _types = res.Data ?? new();
        _loading = false;
    }

    private void NewType()
    {
        _editingId = null;
        _edit = NewRequest();
    }

    private void Edit(ContentTypeModel type)
    {
        _editingId = type.Id;
        _edit = new ContentTypeRequest
        {
            Key = type.Key,
            Name = EnsureLangs(type.Name),
            Description = EnsureLangs(type.Description),
            RequiresBody = type.RequiresBody,
            RequiresHeroImage = type.RequiresHeroImage,
            RequiresFile = type.RequiresFile,
            RequiresVideoUrl = type.RequiresVideoUrl,
            AllowsAttachments = type.AllowsAttachments,
            ClickBehavior = type.ClickBehavior,
            Visible = type.Visible,
            Order = type.Order
        };
    }

    private async Task Save()
    {
        var res = _editingId is null
            ? await ContentService.CreateTypeAsync(_edit)
            : await ContentService.UpdateTypeAsync(_editingId, _edit);

        Http.Toast(res.Message, res.StatusCode);
        if (res.Success)
        {
            NewType();
            await LoadTypes();
        }
    }

    private async Task Delete()
    {
        if (_editingId is null) return;

        var res = await ContentService.DeleteTypeAsync(_editingId);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success)
        {
            NewType();
            await LoadTypes();
        }
    }

    private string GetLang(Dictionary<string, string> values) =>
        GetValue(values, AdminLanguage, fallback: true);

    private string DisplayClickBehavior(string? value) => (value ?? "detail").ToLowerInvariant() switch
    {
        "download" => T("FileDownload"),
        "video" => T("VideoModal"),
        "external" => T("ExternalLink"),
        _ => T("DetailPage")
    };

    private static string GetValue(Dictionary<string, string> values, string lang, bool fallback = false)
    {
        if (values.TryGetValue(lang, out var value) && !string.IsNullOrWhiteSpace(value))
            return value;
        return fallback && values.TryGetValue("en", out var en) ? en : string.Empty;
    }

    private static void SetValue(Dictionary<string, string> values, string lang, string? value)
    {
        values[lang] = value ?? string.Empty;
    }

    private Dictionary<string, string> EnsureLangs(Dictionary<string, string>? source)
    {
        var result = source is null ? new() : new Dictionary<string, string>(source, StringComparer.OrdinalIgnoreCase);
        foreach (var lang in _languages)
            result.TryAdd(lang, string.Empty);
        return result;
    }

    private static string NormalizeLang(string? lang)
    {
        lang = (lang ?? string.Empty).Trim().ToLowerInvariant();
        return string.IsNullOrWhiteSpace(lang)
            ? "en"
            : string.Concat(lang.Where(c => char.IsLetterOrDigit(c) || c == '-'));
    }

    private ContentTypeRequest NewRequest() => new()
    {
        Name = EnsureLangs(null),
        Description = EnsureLangs(null),
        RequiresBody = true,
        AllowsAttachments = true,
        ClickBehavior = "detail",
        Visible = true
    };
}
