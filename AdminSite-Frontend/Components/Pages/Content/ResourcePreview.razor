@page "/content/resource-preview"
@inject AdminContentService ContentService
@inject AdminAuthService Auth
@inject IHttpService Http

<div class="page-header content-resource-preview-header">
    <div>
        <h1 class="page-title"><i class="fas fa-photo-film"></i> @T("ResourcePreview")</h1>
        <p class="text-muted">@T("ResourcePreviewHint")</p>
    </div>
    <a class="btn-admin btn-ghost" href="/content/resources">
        <i class="fas fa-database"></i> @T("ResourceLibrary")
    </a>
</div>

@if (!Auth.CanManageAllContent)
{
    <div class="admin-card">
        <p class="text-muted">@T("NoPermission")</p>
    </div>
}
else
{
    <div class="admin-card content-resource-preview-controls">
        <div class="content-resource-preview-tabs" role="group" aria-label='@T("Type")'>
            <button type="button" class="@ImageButtonClass" @onclick="ChangeKindToImage">
                <i class="fas fa-image"></i> @T("ImageResource")
            </button>
            <button type="button" class="@FileButtonClass" @onclick="ChangeKindToFile">
                <i class="fas fa-file-lines"></i> @T("FileResource")
            </button>
            <button type="button" class="@VideoButtonClass" @onclick="ChangeKindToVideo">
                <i class="fas fa-play"></i> @T("VideoResource")
            </button>
        </div>
        <input class="form-control"
               placeholder="@T("SearchResources")"
               value="@_search"
               @oninput="OnSearchChanged" />
    </div>

    @if (_loading)
    {
        <div class="admin-card">
            <p class="text-muted">@T("Loading")</p>
        </div>
    }
    else
    {
        <div class="content-resource-preview-workspace">
            <aside class="admin-card content-resource-preview-list">
                <div class="content-resource-preview-list__header">
                    <strong>@DisplayKind(_kindFilter)</strong>
                    <span>@_resources.Count</span>
                </div>

                @if (!_resources.Any())
                {
                    <p class="text-muted">@T("NoResourcesYet")</p>
                }
                else
                {
                    <div class="content-resource-preview-list__items">
                        @foreach (var resource in _resources)
                        {
                            <button type="button"
                                    class="content-resource-preview-list__item @(resource.Id == _selected?.Id ? "is-active" : string.Empty)"
                                    @onclick="() => SelectResource(resource)">
                                <span class="content-resource-preview-list__thumb">
                                    @if (ResourceThumbnailUrl(resource) is { Length: > 0 } thumbnail)
                                    {
                                        <img src="@thumbnail" alt="" />
                                    }
                                    else
                                    {
                                        <i class="fas @ResourceIcon(resource)"></i>
                                    }
                                </span>
                                <span class="content-resource-preview-list__meta">
                                    <strong>@ResourceName(resource)</strong>
                                    <small>@UpdatedLabel(resource)</small>
                                </span>
                            </button>
                        }
                    </div>
                }
            </aside>

            <section class="admin-card content-resource-preview-stage">
                @if (_selected is null)
                {
                    <div class="content-resource-preview-empty">
                        <p class="text-muted">@T("NoResourcesYet")</p>
                    </div>
                }
                else
                {
                    <div class="content-resource-preview-stage__header">
                        <div>
                            <span class="content-behavior-pill">@DisplayKind(_selected.Kind)</span>
                            <h2>@ResourceName(_selected)</h2>
                            @if (!string.IsNullOrWhiteSpace(ResourceDescription(_selected)))
                            {
                                <p>@ResourceDescription(_selected)</p>
                            }
                        </div>
                        <a class="btn-admin btn-primary" href="@_selected.Url" target="_blank" rel="noopener">
                            <i class="fas fa-up-right-from-square"></i> @T("Open")
                        </a>
                    </div>

                    <div class="content-resource-preview-frame">
                        @switch (NormalizeKind(_selected.Kind))
                        {
                            case "image":
                                <img class="content-resource-preview-image" src="@_selected.Url" alt="@ResourceName(_selected)" />
                                break;
                            case "video":
                                var embedUrl = BuildYouTubeEmbedUrl(_selected.Url);
                                if (!string.IsNullOrWhiteSpace(embedUrl))
                                {
                                    <iframe class="content-resource-preview-video"
                                            src="@embedUrl"
                                            title="@ResourceName(_selected)"
                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                            allowfullscreen>
                                    </iframe>
                                }
                                else
                                {
                                    <div class="content-resource-preview-file-card">
                                        <i class="fas fa-play"></i>
                                        <p class="text-muted">@T("PreviewUnavailable")</p>
                                    </div>
                                }
                                break;
                            default:
                                if (IsPdf(_selected))
                                {
                                    <iframe class="content-resource-preview-file" src="@_selected.Url" title="@ResourceName(_selected)"></iframe>
                                }
                                else
                                {
                                    <div class="content-resource-preview-file-card">
                                        <i class="fas fa-file-lines"></i>
                                        <strong>@ResourceFileName(_selected)</strong>
                                        <span>@FormatBytes(_selected.SizeBytes)</span>
                                    </div>
                                }
                                break;
                        }
                    </div>

                    <dl class="content-resource-preview-details">
                        <div>
                            <dt>@T("Type")</dt>
                            <dd>@DisplayKind(_selected.Kind)</dd>
                        </div>
                        <div>
                            <dt>@T("FileName")</dt>
                            <dd>@ResourceFileName(_selected)</dd>
                        </div>
                        <div>
                            <dt>@T("Updated")</dt>
                            <dd>@_selected.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
                        </div>
                        <div>
                            <dt>@T("ResourceUrl")</dt>
                            <dd><a href="@_selected.Url" target="_blank" rel="noopener">@_selected.Url</a></dd>
                        </div>
                    </dl>
                }
            </section>
        </div>
    }
}

@code {
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private List<ManagedResourceModel> _resources = new();
    private ManagedResourceModel? _selected;
    private string _kindFilter = "image";
    private string _search = string.Empty;
    private bool _loading = true;

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);
    private string CurrentLang => NormalizeLang(AdminLanguage);

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Auth.RefreshSessionAsync();
        await LoadResourcesAsync();
    }

    private async Task ChangeKind(string kind)
    {
        _kindFilter = NormalizeKind(kind);
        _selected = null;
        await LoadResourcesAsync();
    }

    private async Task LoadResourcesAsync()
    {
        _loading = true;
        var res = await ContentService.GetResourcesAsync(_kindFilter, _search, includeInactive: false);
        if (res.Success)
        {
            _resources = (res.Data ?? new()).Where(r => r.Active).OrderByDescending(r => r.UpdatedAt).ToList();
            _selected ??= _resources.FirstOrDefault();
            if (_selected is not null && !_resources.Any(r => r.Id == _selected.Id))
                _selected = _resources.FirstOrDefault();
        }
        else
        {
            _resources = new();
            _selected = null;
            Http.Toast(res.Message, res.StatusCode);
        }
        _loading = false;
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _selected = null;
        await LoadResourcesAsync();
    }

    private void SelectResource(ManagedResourceModel resource)
    {
        _selected = resource;
    }

    private string KindButtonClass(string kind) =>
        string.Equals(_kindFilter, kind, StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-ghost";

    private string ImageButtonClass => $"btn-admin {KindButtonClass("image")}";
    private string FileButtonClass => $"btn-admin {KindButtonClass("file")}";
    private string VideoButtonClass => $"btn-admin {KindButtonClass("video")}";

    private Task ChangeKindToImage() => ChangeKind("image");
    private Task ChangeKindToFile() => ChangeKind("file");
    private Task ChangeKindToVideo() => ChangeKind("video");

    private string DisplayKind(string kind) => NormalizeKind(kind) switch
    {
        "image" => T("ImageResource"),
        "video" => T("VideoResource"),
        _ => T("FileResource")
    };

    private string ResourceName(ManagedResourceModel resource)
    {
        var name = GetValue(resource.Name, CurrentLang, fallback: true);
        if (!string.IsNullOrWhiteSpace(name)) return name;
        if (!string.IsNullOrWhiteSpace(resource.FileName)) return resource.FileName;
        return resource.Url.Split('/').LastOrDefault() ?? T("Resource");
    }

    private string ResourceDescription(ManagedResourceModel resource) =>
        GetValue(resource.Description, CurrentLang, fallback: true);

    private static string ResourceFileName(ManagedResourceModel resource) =>
        string.IsNullOrWhiteSpace(resource.FileName)
            ? resource.Url.Split('/').LastOrDefault() ?? string.Empty
            : resource.FileName;

    private static string ResourceThumbnailUrl(ManagedResourceModel resource) =>
        !string.IsNullOrWhiteSpace(resource.ThumbnailUrl)
            ? resource.ThumbnailUrl!
            : NormalizeKind(resource.Kind) == "image" ? resource.Url : string.Empty;

    private static string ResourceIcon(ManagedResourceModel resource) => NormalizeKind(resource.Kind) switch
    {
        "image" => "fa-image",
        "video" => "fa-play",
        _ => "fa-file-lines"
    };

    private string UpdatedLabel(ManagedResourceModel resource) =>
        $"{DisplayKind(resource.Kind)} - {resource.UpdatedAt.ToLocalTime():dd MMM yyyy}";

    private static bool IsPdf(ManagedResourceModel resource) =>
        resource.ContentType.Contains("pdf", StringComparison.OrdinalIgnoreCase) ||
        resource.Url.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);

    private static string BuildYouTubeEmbedUrl(string? url)
    {
        var id = ExtractYouTubeId(url);
        return string.IsNullOrWhiteSpace(id) ? string.Empty : $"https://www.youtube.com/embed/{id}";
    }

    private static string ExtractYouTubeId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri)) return string.Empty;

        var host = uri.Host.ToLowerInvariant();
        var path = uri.AbsolutePath.Trim('/');
        string id = string.Empty;

        if (host.Contains("youtu.be", StringComparison.OrdinalIgnoreCase))
            id = path.Split('/').FirstOrDefault() ?? string.Empty;
        else if (path.StartsWith("embed/", StringComparison.OrdinalIgnoreCase))
            id = path.Split('/').Skip(1).FirstOrDefault() ?? string.Empty;
        else
        {
            var query = uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
            foreach (var part in query)
            {
                var pieces = part.Split('=', 2);
                if (pieces.Length == 2 && pieces[0] == "v")
                {
                    id = Uri.UnescapeDataString(pieces[1]);
                    break;
                }
            }
        }

        return string.Concat(id.Where(c => char.IsLetterOrDigit(c) || c is '-' or '_'));
    }

    private static string GetValue(Dictionary<string, string> values, string lang, bool fallback = false)
    {
        if (values.TryGetValue(lang, out var value) && !string.IsNullOrWhiteSpace(value))
            return value;
        return fallback && values.TryGetValue("en", out var en) ? en : string.Empty;
    }

    private static string NormalizeKind(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "image" or "gallery" => "image",
        "video" or "webinar" => "video",
        _ => "file"
    };

    private static string NormalizeLang(string? lang)
    {
        lang = (lang ?? string.Empty).Trim().ToLowerInvariant();
        return string.IsNullOrWhiteSpace(lang)
            ? "en"
            : string.Concat(lang.Where(c => char.IsLetterOrDigit(c) || c == '-'));
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes <= 0) return string.Empty;
        string[] units = ["B", "KB", "MB", "GB"];
        double size = bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }
        return $"{size:0.#} {units[unit]}";
    }
}