@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="content-rich-editor">
    <div class="content-rich-toolbar" aria-label="Rich text toolbar">
        <label class="content-rich-size" title="Text size">
            <input type="number" min="10" max="72" step="1" value="@_fontSizePx" @onchange="SetFontSize" />
            <span>px</span>
        </label>
        <button type="button" class="content-rich-btn" @onclick='() => Exec("bold")' title="Bold"><i class="fas fa-bold"></i></button>
        <button type="button" class="content-rich-btn" @onclick='() => Exec("italic")' title="Italic"><i class="fas fa-italic"></i></button>
        <button type="button" class="content-rich-btn" @onclick='() => Exec("underline")' title="Underline"><i class="fas fa-underline"></i></button>
        <button type="button" class="content-rich-btn" @onclick='() => Exec("insertUnorderedList")' title="Bullet list"><i class="fas fa-list-ul"></i></button>
        <button type="button" class="content-rich-btn" @onclick='() => Exec("insertOrderedList")' title="Numbered list"><i class="fas fa-list-ol"></i></button>
        <button type="button" class="content-rich-btn" @onclick="CreateLink" title="Link"><i class="fas fa-link"></i></button>
        <label class="content-rich-color" title="Text color">
            <i class="fas fa-palette"></i>
            <input type="color" value="@_textColor" @onchange="SetColor" />
        </label>
        <button type="button" class="content-rich-btn" @onclick='() => Exec("removeFormat")' title="Clear formatting"><i class="fas fa-eraser"></i></button>
    </div>
    <div @ref="_editor"
         class="content-rich-surface"
         contenteditable="true"
         data-placeholder="@Placeholder"></div>
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;

    private readonly string _id = $"content-rich-{Guid.NewGuid():N}";
    private DotNetObjectReference<ContentRichTextEditor>? _dotNetRef;
    private ElementReference _editor;
    private string _lastValue = string.Empty;
    private int _fontSizePx = 16;
    private string _textColor = "#0f3460";
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("contentRichTextEditor.init", _id, _editor, _dotNetRef, Value ?? string.Empty);
            _lastValue = Value ?? string.Empty;
            _initialized = true;
            return;
        }

        if (_initialized && !string.Equals(Value ?? string.Empty, _lastValue, StringComparison.Ordinal))
        {
            await JS.InvokeVoidAsync("contentRichTextEditor.setValue", _id, Value ?? string.Empty);
            _lastValue = Value ?? string.Empty;
        }
    }

    private async Task Exec(string command)
    {
        await JS.InvokeVoidAsync("contentRichTextEditor.exec", _id, command);
    }

    private async Task SetFontSize(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var requestedSize))
            requestedSize = 16;

        _fontSizePx = Math.Clamp(requestedSize, 10, 72);
        await JS.InvokeVoidAsync("contentRichTextEditor.setFontSize", _id, _fontSizePx);
    }

    private async Task SetColor(ChangeEventArgs e)
    {
        var color = e.Value?.ToString() ?? "#0f3460";
        _textColor = IsHexColor(color) ? color : "#0f3460";
        await JS.InvokeVoidAsync("contentRichTextEditor.setColor", _id, _textColor);
    }

    private async Task CreateLink()
    {
        await JS.InvokeVoidAsync("contentRichTextEditor.createLink", _id);
    }

    [JSInvokable]
    public async Task OnEditorInput(string html)
    {
        _lastValue = html ?? string.Empty;
        await ValueChanged.InvokeAsync(_lastValue);
    }

    [JSInvokable]
    public void OnFormatChanged(int fontSizePx, string? color)
    {
        if (fontSizePx >= 10 && fontSizePx <= 72)
            _fontSizePx = fontSizePx;

        if (IsHexColor(color))
            _textColor = color!.ToLowerInvariant();

        _ = InvokeAsync(StateHasChanged);
    }

    private static bool IsHexColor(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        System.Text.RegularExpressions.Regex.IsMatch(value, "^#[0-9a-fA-F]{6}$");

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            try
            {
                await JS.InvokeVoidAsync("contentRichTextEditor.dispose", _id);
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }
}
