@page "/content/templates"

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-layer-group"></i> @T("Templates")</h1>
</div>

<div class="admin-card">
    <p class="text-muted">@T("TemplatesComingSoon")</p>
</div>

@code {
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);
}
