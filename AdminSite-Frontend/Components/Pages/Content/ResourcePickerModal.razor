@inject AdminContentService ContentService
@inject IHttpService Http

@if (Open)
{
    <div class="modal-backdrop" @onclick="Close">
        <div class="modal-box content-resource-picker" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>@PickerTitle</span>
                <button type="button" class="btn-admin btn-ghost content-icon-btn" @onclick="Close" title="@T("Close")">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="content-resource-picker__toolbar">
                    <input class="form-control"
                           placeholder="@T("SearchResources")"
                           value="@_search"
                           @oninput="OnSearchChanged" />
                    <a class="btn-admin btn-ghost" href="/content/resources" target="_blank" rel="noopener">
                        <i class="fas fa-up-right-from-square"></i> @T("ResourceLibrary")
                    </a>
                </div>
                <div class="form-hint">@T("ResourcePickerHint")</div>

                @if (_loading)
                {
                    <p class="text-muted">@T("Loading")</p>
                }
                else if (!_resources.Any())
                {
                    <p class="text-muted">@T("NoMatchingResources")</p>
                }
                else
                {
                    <div class="content-resource-picker__grid">
                        @foreach (var resource in _resources)
                        {
                            <article class="content-resource-picker__item" @key="resource.Id">
                                <span class="content-resource-picker__thumb">
                                    @if (ResourceThumbnailUrl(resource) is { Length: > 0 } thumbnail)
                                    {
                                        <img src="@thumbnail" alt="" />
                                    }
                                    else
                                    {
                                        <i class="fas @ResourceIcon(resource)"></i>
                                    }
                                </span>
                                <span class="content-resource-picker__meta">
                                    <strong>@ResourceName(resource)</strong>
                                    <small>@DisplayResourceKind(resource.Kind)</small>
                                    @if (!string.IsNullOrWhiteSpace(ResourceDescription(resource)))
                                    {
                                        <em>@ResourceDescription(resource)</em>
                                    }
                                </span>
                                <button type="button"
                                        class="btn-admin btn-primary"
                                        @onclick="() => Choose(resource)">
                                    @T("Choose")
                                </button>
                            </article>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-admin btn-ghost" @onclick="Close">@T("Cancel")</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string Kind { get; set; } = "file";
    [Parameter] public EventCallback<ManagedResourceModel> ResourceSelected { get; set; }
    [Parameter] public EventCallback Closed { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private bool _wasOpen;
    private bool _loading;
    private string _loadedKind = string.Empty;
    private string _search = string.Empty;
    private List<ManagedResourceModel> _resources = new();

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);
    private string CurrentLang => NormalizeLang(AdminLanguage);
    private string PickerTitle => NormalizeKind(Kind) switch
    {
        "image" => T("ChooseImageResource"),
        "video" => T("ChooseVideoResource"),
        _ => T("ChooseFileResource")
    };

    protected override async Task OnParametersSetAsync()
    {
        var normalizedKind = NormalizeKind(Kind);
        if (Open && (!_wasOpen || !string.Equals(_loadedKind, normalizedKind, StringComparison.OrdinalIgnoreCase)))
        {
            _loadedKind = normalizedKind;
            _search = string.Empty;
            await LoadResources();
        }

        if (!Open)
            _resources = new();

        _wasOpen = Open;
    }

    private async Task LoadResources()
    {
        _loading = true;
        var res = await ContentService.GetResourcesAsync(_loadedKind, _search, includeInactive: false);
        if (res.Success)
            _resources = (res.Data ?? new()).Where(r => r.Active).ToList();
        else
        {
            _resources = new();
            Http.Toast(res.Message, res.StatusCode);
        }
        _loading = false;
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        await LoadResources();
    }

    private async Task Choose(ManagedResourceModel resource)
    {
        await ResourceSelected.InvokeAsync(resource);
        await Close();
    }

    private async Task Close()
    {
        _loading = false;
        await Closed.InvokeAsync();
    }

    private string ResourceName(ManagedResourceModel resource)
    {
        var name = GetValue(resource.Name, CurrentLang, fallback: true);
        if (!string.IsNullOrWhiteSpace(name)) return name;
        if (!string.IsNullOrWhiteSpace(resource.FileName)) return resource.FileName;
        return resource.Url.Split('/').LastOrDefault() ?? T("Resource");
    }

    private string ResourceDescription(ManagedResourceModel resource) =>
        GetValue(resource.Description, CurrentLang, fallback: true);

    private static string ResourceThumbnailUrl(ManagedResourceModel resource) =>
        !string.IsNullOrWhiteSpace(resource.ThumbnailUrl)
            ? resource.ThumbnailUrl!
            : NormalizeKind(resource.Kind) == "image" ? resource.Url : string.Empty;

    private static string ResourceIcon(ManagedResourceModel resource) => NormalizeKind(resource.Kind) switch
    {
        "image" => "fa-image",
        "video" => "fa-play",
        _ => "fa-file"
    };

    private string DisplayResourceKind(string kind) => NormalizeKind(kind) switch
    {
        "image" => T("ImageResource"),
        "video" => T("VideoResource"),
        _ => T("FileResource")
    };

    private static string NormalizeKind(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "image" or "gallery" => "image",
        "video" or "webinar" => "video",
        _ => "file"
    };

    private static string GetValue(Dictionary<string, string> values, string lang, bool fallback = false)
    {
        if (values.TryGetValue(lang, out var value) && !string.IsNullOrWhiteSpace(value))
            return value;
        return fallback && values.TryGetValue("en", out var en) ? en : string.Empty;
    }

    private static string NormalizeLang(string? lang)
    {
        lang = (lang ?? string.Empty).Trim().ToLowerInvariant();
        return string.IsNullOrWhiteSpace(lang)
            ? "en"
            : string.Concat(lang.Where(c => char.IsLetterOrDigit(c) || c == '-'));
    }
}
