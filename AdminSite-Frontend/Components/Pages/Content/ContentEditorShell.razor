    private bool IsNew => string.IsNullOrWhiteSpace(Id);
    private string CurrentLang => NormalizeLang(AdminLanguage);
    private ContentTypeModel? SelectedType => _types.FirstOrDefault(t => string.Equals(t.Key, _edit.ContentTypeKey, StringComparison.OrdinalIgnoreCase));
    private string SelectedBehavior => ResolveBehavior(SelectedType);
    private bool IsPageContent => string.Equals(SelectedBehavior, "page", StringComparison.OrdinalIgnoreCase);
    private bool IsFileResource => string.Equals(SelectedBehavior, "file-resource", StringComparison.OrdinalIgnoreCase);
    private bool IsVideoResource => string.Equals(SelectedBehavior, "video-resource", StringComparison.OrdinalIgnoreCase);
    private bool IsImageResource => string.Equals(SelectedBehavior, "image-resource", StringComparison.OrdinalIgnoreCase);
    private bool IsGalleryResource => string.Equals(SelectedBehavior, "gallery", StringComparison.OrdinalIgnoreCase);
    private string ClickBehavior => SelectedType?.ClickBehavior?.ToLowerInvariant() ?? (IsVideoResource ? "video" : IsFileResource ? "download" : (IsImageResource || IsGalleryResource) ? "image" : "detail");
    private bool ShowsBody => IsPageContent;
    private bool ShowsHero => IsPageContent || SelectedType?.RequiresHeroImage == true;
    private bool ShowsTemplate => IsPageContent;
    private bool ShowsFile => IsFileResource || (!IsPageContent && (SelectedType?.RequiresFile == true || ClickBehavior == "download"));
    private bool ShowsVideo => IsVideoResource || (!IsPageContent && (SelectedType?.RequiresVideoUrl == true || ClickBehavior == "video"));
    private bool ShowsThumbnail => ShowsFile || ShowsVideo || IsImageResource;
    private bool ShowsGallery => IsGalleryResource;
