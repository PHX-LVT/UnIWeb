@page "/content/new"
@page "/content/edit/{Id}"
@inject AdminContentService ContentService
@inject IHttpService Http
@inject NavigationManager Nav
@inject AdminAuthService Auth
@inject IJSRuntime JS

<div class="page-header content-editor-header">
    <h1 class="page-title"><i class="fas fa-pen-nib"></i> @T(IsNew ? "NewContent" : "EditContent")</h1>
    <a class="btn-admin btn-ghost" href="@ReturnUrl">
        <i class="fas fa-arrow-left"></i> @T("Return")
    </a>
</div>

@if (_loading)
{
    <div class="admin-card">
        <p class="text-muted">@T("Loading")</p>
    </div>
}
else
{
    <div class="content-editor-shell">
        <div class="admin-card content-workflow-panel">
            <div class="content-status-line">
                <span class="content-status-dot @StatusClass"></span>
                <div>
                    <div class="text-muted" style="font-size:.78rem">@T("Status")</div>
                    <strong>@DisplayStatus(_status)</strong>
                </div>
            </div>

            <label style="margin-top:1rem">@T("ContentType")</label>
            <select class="form-control" value="@_edit.ContentTypeKey" @onchange="OnTypeChanged">
                @foreach (var type in _types)
                {
                    <option value="@type.Key">@GetLang(type.Name)</option>
                }
            </select>
            <div class="form-hint">@SelectedBehaviorHint</div>

            <label style="margin-top:.75rem">@T("Slug")</label>
            <input class="form-control" value="@_edit.Slug" @oninput="e => _edit.Slug = e.Value?.ToString()" />
            <div class="form-hint">@T("SlugHint")</div>

            <label style="margin-top:.75rem">@T("Tags")</label>
            <div class="content-tag-editor">
                @foreach (var tag in _tags)
                {
                    <span class="content-tag-pill">
                        @tag
                        <button type="button" @onclick="() => RemoveTag(tag)">Ã—</button>
                    </span>
                }
                <input value="@_tagDraft"
                       placeholder="@T("AddTag")"
                       @oninput="e => _tagDraft = e.Value?.ToString() ?? string.Empty"
                       @onkeydown="OnTagKeyDown" />
            </div>

            <label style="display:flex;align-items:center;gap:.5rem;margin-top:.75rem">
                <input type="checkbox" @bind="_edit.Visible" disabled="@(!Auth.CanManageAllContent)" />
                @T("Visible")
            </label>

            @if (ShowsTemplate)
            {
                <label style="margin-top:.75rem">@T("Template")</label>
                <select class="form-control" value="@(_edit.TemplateKey ?? string.Empty)" @onchange="e => _edit.TemplateKey = e.Value?.ToString()">
                    <option value="">@T("DefaultTemplate")</option>
                    <option value="article-default">@T("ArticleDefault")</option>
                    <option value="case-study-default">@T("CaseStudyDefault")</option>
                </select>
            }

            <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem">
                @if (CanSaveDraft)
                {
                    <button class="btn-admin btn-primary" @onclick="Save">
                        <i class="fas fa-save"></i> @T(IsPublished ? "SaveChanges" : "SaveDraft")
                    </button>
                }
                @if (!IsNew)
                {
                    @if (CanSubmit)
                    {
                        <button class="btn-admin btn-ghost" @onclick="Submit">@T(IsRejected ? "SubmitAgain" : "SubmitForReview")</button>
                    }
                    @if (CanReturnToDraft)
                    {
                        <button class="btn-admin btn-ghost" @onclick="ReturnToDraft">@T("Draft")</button>
                    }
                    @if (CanPublish)
                    {
                        <button class="btn-admin btn-ghost" @onclick="Publish">@T(IsPublished ? "PublishChanges" : "Publish")</button>
                    }
                    @if (CanReject)
                    {
                        <button class="btn-admin btn-ghost" @onclick="Reject">@T("Reject")</button>
                    }
                    @if (CanRestore)
                    {
                        <button class="btn-admin btn-ghost" @onclick="Restore">@T("Restore")</button>
                    }
                    @if (CanDelete)
                    {
                        <button class="btn-admin btn-danger" @onclick="Delete">@T("Delete")</button>
                    }
                }
            </div>
        </div>

        <div>
            <div class="admin-card content-editor-card" style="margin-bottom:1rem">
                <div class="content-editor-card-header">
                    <h2 style="font-size:1rem;margin:0">@T("Content")</h2>
                    <div class="content-editor-card-meta">
                        <span class="content-behavior-pill">@SelectedBehaviorLabel</span>
                        <span>@T("EditingLanguage"): @CurrentLang.ToUpperInvariant()</span>
                    </div>
                </div>

                <label>@T("Title")</label>
                <input class="form-control content-editor-input"
                       value="@GetValue(_edit.Title, CurrentLang)"
                       @oninput="e => SetValue(_edit.Title, CurrentLang, e.Value?.ToString())" />

                <label style="margin-top:.75rem">@SummaryLabel</label>
                <textarea class="form-control content-editor-input"
                          rows="4"
                          value="@GetValue(_edit.Summary, CurrentLang)"
                          @oninput="e => SetValue(_edit.Summary, CurrentLang, e.Value?.ToString())"></textarea>

                @if (ShowsHero)
                {
                    <div class="content-editor-media">
                        <h2 style="font-size:1rem;margin:0 0 1rem">@T("CoverImage")</h2>
                        @if (!string.IsNullOrWhiteSpace(_edit.HeroImageUrl))
                        {
                            <img class="content-editor-preview" src="@_edit.HeroImageUrl" alt="" />
                        }
                        <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
                            <InputFile class="content-editor-file-input"
                                       id="content-hero-upload"
                                       OnChange="UploadHero"
                                       accept="image/*" />
                            <label class="btn-admin btn-ghost" for="content-hero-upload">
                                <i class="fas fa-image"></i> @T("UploadNew")
                            </label>
                            <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("image", "hero")'>
                                <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                            </button>
                            @if (!string.IsNullOrWhiteSpace(_edit.HeroImageUrl))
                            {
                                <button class="btn-admin btn-danger" @onclick="RemoveHero">@T("RemoveImage")</button>
                            }
                        </div>
                        <div class="form-hint">@T("Source"): @AssetSourceLabel(_edit.HeroImageResourceSource, _edit.HeroImageResourceId)</div>
                        @if (!string.IsNullOrWhiteSpace(_edit.HeroImageUrl))
                        {
                            <label style="margin-top:.75rem">@T("ImageDescription")</label>
                            <input class="form-control content-editor-input"
                                   value="@_edit.HeroImageAlt"
                                   @oninput="e => _edit.HeroImageAlt = e.Value?.ToString()" />
                        }
                    </div>
                }

                @if (ShowsBody)
                {
                    <div class="content-body-editor">
                        <div class="content-body-editor__header">
                            <label>@T("Body")</label>
                            <span>@_edit.BodyItems.Count/10</span>
                        </div>

                        @foreach (var item in _edit.BodyItems.OrderBy(i => i.Order).ToList())
                        {
                            var expanded = IsBodyItemExpanded(item);
                            <article class="content-body-item">
                                <div class="content-body-item__toolbar">
                                    <button type="button"
                                            class="content-body-item__summary"
                                            @onclick="() => ToggleBodyItem(item)">
                                        <i class="fas @(expanded ? "fa-chevron-down" : "fa-chevron-right")"></i>
                                        <strong>@BodyItemLabel(item.Type) @(item.Order + 1)</strong>
                                        @if (!expanded)
                                        {
                                            <span>@BodyItemPreview(item)</span>
                                        }
                                    </button>
                                    <div>
                                        <button class="btn-admin btn-ghost content-icon-btn" disabled="@(item.Order == 0)" @onclick="() => MoveBodyItem(item, -1)" title="@T("MoveUp")">
                                            <i class="fas fa-arrow-up"></i>
                                        </button>
                                        <button class="btn-admin btn-ghost content-icon-btn" disabled="@(item.Order >= _edit.BodyItems.Count - 1)" @onclick="() => MoveBodyItem(item, 1)" title="@T("MoveDown")">
                                            <i class="fas fa-arrow-down"></i>
                                        </button>
                                        <button class="btn-admin btn-danger content-icon-btn" disabled="@(_edit.BodyItems.Count <= 1)" @onclick="() => RemoveBodyItem(item)" title="@T("Remove")">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>

                                @if (expanded)
                                {
                                    @switch (NormalizeBodyType(item.Type))
                                    {
                                        case "image":
                                            @if (!string.IsNullOrWhiteSpace(item.Url))
                                            {
                                                <img class="content-editor-preview" src="@item.Url" alt="" />
                                            }
                                            <div class="content-body-upload-row">
                                                <InputFile class="content-editor-file-input"
                                                           id="@($"content-body-image-{item.Id}")"
                                                           OnChange="e => UploadBodyImage(item, e)"
                                                           accept="image/*" />
                                                <label class="btn-admin btn-ghost" for="@($"content-body-image-{item.Id}")">
                                                    <i class="fas fa-image"></i> @T("UploadNew")
                                                </label>
                                                <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("image", "body-image", item)'>
                                                    <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                                                </button>
                                                <input class="form-control content-editor-input"
                                                       placeholder="@T("ImageUrl")"
                                                       value="@item.Url"
                                                       @oninput="e => OnBodyMediaUrlChanged(item, e.Value?.ToString())" />
                                            </div>
                                            <div class="form-hint">@T("Source"): @AssetSourceLabel(item.ResourceSource, item.ResourceId)</div>
                                            <input class="form-control content-editor-input"
                                                   style="margin-top:.75rem"
                                                   placeholder="@T("ImageDescription")"
                                                   value="@GetValue(item.Caption, CurrentLang)"
                                                   @oninput="e => SetValue(item.Caption, CurrentLang, e.Value?.ToString())" />
                                            break;
                                        case "video":
                                            <div class="content-body-upload-row">
                                                <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("video", "body-video", item)'>
                                                    <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                                                </button>
                                                <input class="form-control content-editor-input"
                                                       placeholder="@T("VideoUrl")"
                                                       value="@item.Url"
                                                       @oninput="e => OnBodyMediaUrlChanged(item, e.Value?.ToString())" />
                                            </div>
                                            <div class="form-hint">@T("Source"): @AssetSourceLabel(item.ResourceSource, item.ResourceId)</div>
                                            <input class="form-control content-editor-input"
                                                   style="margin-top:.75rem"
                                                   placeholder="@T("Caption")"
                                                   value="@GetValue(item.Caption, CurrentLang)"
                                                   @oninput="e => SetValue(item.Caption, CurrentLang, e.Value?.ToString())" />
                                            break;
                                        case "file":
                                            <div class="content-body-upload-row">
                                                <InputFile class="content-editor-file-input"
                                                           id="@($"content-body-file-{item.Id}")"
                                                           OnChange="e => UploadBodyFile(item, e)"
                                                           accept="application/pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx" />
                                                <label class="btn-admin btn-ghost" for="@($"content-body-file-{item.Id}")">
                                                    <i class="fas fa-file"></i> @T("UploadNew")
                                                </label>
                                                <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("file", "body-file", item)'>
                                                    <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                                                </button>
                                                <input class="form-control content-editor-input"
                                                       placeholder="@T("FileUrl")"
                                                       value="@item.Url"
                                                       @oninput="e => OnBodyMediaUrlChanged(item, e.Value?.ToString())" />
                                            </div>
                                            <div class="form-hint">@T("Source"): @AssetSourceLabel(item.ResourceSource, item.ResourceId)</div>
                                            <input class="form-control content-editor-input"
                                                   style="margin-top:.75rem"
                                                   placeholder="@T("FileName")"
                                                   value="@item.FileName"
                                                   @oninput="e => item.FileName = e.Value?.ToString()" />
                                            break;
                                        case "quote":
                                            <textarea class="form-control content-editor-input"
                                                      rows="4"
                                                      value="@GetBodyText(item.Content, CurrentLang)"
                                                      @oninput="e => SetBodyText(item.Content, CurrentLang, e.Value?.ToString())"></textarea>
                                            break;
                                        case "cta":
                                            <textarea class="form-control content-editor-input"
                                                      rows="4"
                                                      value="@GetValue(item.Content, CurrentLang)"
                                                      @oninput="e => SetValue(item.Content, CurrentLang, e.Value?.ToString())"></textarea>
                                            break;
                                        case "divider":
                                            <div class="content-body-divider-preview"></div>
                                            break;
                                        default:
                                            <ContentRichTextEditor Value="@GetValue(item.Content, CurrentLang)"
                                                                   ValueChanged="html => SetBodyRichText(item.Content, CurrentLang, html)"
                                                                   Placeholder="@T("Body")" />
                                            break;
                                    }
                                }
                            </article>
                        }

                        <div class="content-body-actions">
                            <button class="btn-admin btn-ghost" disabled="@BodyLimitReached" @onclick='() => AddBodyItem("text")'><i class="fas fa-align-left"></i> @T("AddText")</button>
                            <button class="btn-admin btn-ghost" disabled="@BodyLimitReached" @onclick='() => AddBodyItem("image")'><i class="fas fa-image"></i> @T("AddImage")</button>
                            <button class="btn-admin btn-ghost" disabled="@BodyLimitReached" @onclick='() => AddBodyItem("video")'><i class="fas fa-play"></i> @T("AddVideo")</button>
                            <button class="btn-admin btn-ghost" disabled="@BodyLimitReached" @onclick='() => AddBodyItem("file")'><i class="fas fa-file"></i> @T("AddFile")</button>
                            <button class="btn-admin btn-ghost" disabled="@BodyLimitReached" @onclick='() => AddBodyItem("quote")'><i class="fas fa-quote-left"></i> @T("AddQuote")</button>
                            <button class="btn-admin btn-ghost" disabled="@BodyLimitReached" @onclick='() => AddBodyItem("divider")'><i class="fas fa-minus"></i> @T("AddDivider")</button>
                        </div>
                    </div>
                }
            </div>

            @if (ShowsGallery)
            {
                <div class="admin-card content-editor-card" style="margin-bottom:1rem">
                    <div class="content-body-editor__header">
                        <div>
                            <h2 style="font-size:1rem;margin:0 0 .35rem">@T("GalleryItems")</h2>
                            <div class="form-hint">@T("GalleryItemsHint")</div>
                        </div>
                        <span>@_edit.GalleryItems.Count/@MaxGalleryItems</span>
                    </div>

                    @if (_edit.GalleryItems.Count == 0)
                    {
                        <div class="form-hint" style="margin-bottom:.85rem">@T("NoGalleryItemsYet")</div>
                    }

                    @foreach (var item in _edit.GalleryItems.OrderBy(i => i.Order).ToList())
                    {
                        var kind = NormalizeGalleryKind(item.Kind);
                        <article class="content-body-item">
                            <div class="content-body-item__toolbar">
                                <div class="content-body-item__summary">
                                    <i class="fas @(kind == "video" ? "fa-play" : "fa-image")"></i>
                                    <strong>@GalleryItemLabel(item.Kind) @(item.Order + 1)</strong>
                                </div>
                                <div>
                                    <button class="btn-admin btn-ghost content-icon-btn" disabled="@(item.Order == 0)" @onclick="() => MoveGalleryItem(item, -1)" title="@T("MoveUp")">
                                        <i class="fas fa-arrow-up"></i>
                                    </button>
                                    <button class="btn-admin btn-ghost content-icon-btn" disabled="@(item.Order >= _edit.GalleryItems.Count - 1)" @onclick="() => MoveGalleryItem(item, 1)" title="@T("MoveDown")">
                                        <i class="fas fa-arrow-down"></i>
                                    </button>
                                    <button class="btn-admin btn-danger content-icon-btn" @onclick="() => RemoveGalleryItem(item)" title="@T("Remove")">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>

                            @if (kind == "image" && !string.IsNullOrWhiteSpace(item.Url))
                            {
                                <img class="content-editor-preview" src="@item.Url" alt="" />
                            }
                            else if (kind == "video" && !string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                            {
                                <img class="content-editor-preview" src="@item.ThumbnailUrl" alt="" />
                            }

                            <label>@T("Type")</label>
                            <select class="form-control content-editor-input" value="@kind" @onchange="e => OnGalleryKindChanged(item, e.Value?.ToString())">
                                <option value="image">@T("Image")</option>
                                <option value="video">@T("Video")</option>
                            </select>

                            @if (kind == "image")
                            {
                                <div class="content-body-upload-row" style="margin-top:.75rem">
                                    <InputFile class="content-editor-file-input"
                                               id="@($"content-gallery-image-{item.Id}")"
                                               OnChange="e => UploadGalleryImage(item, e)"
                                               accept="image/*" />
                                    <label class="btn-admin btn-ghost" for="@($"content-gallery-image-{item.Id}")">
                                        <i class="fas fa-image"></i> @T("UploadNew")
                                    </label>
                                    <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenGalleryResourcePicker("image", item)'>
                                        <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                                    </button>
                                    <input class="form-control content-editor-input"
                                           placeholder="@T("ImageUrl")"
                                           value="@item.Url"
                                           @oninput="e => OnGalleryItemUrlChanged(item, e.Value?.ToString())" />
                                </div>
                            }
                            else
                            {
                                <div class="content-body-upload-row" style="margin-top:.75rem">
                                    <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenGalleryResourcePicker("video", item)'>
                                        <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                                    </button>
                                    <input class="form-control content-editor-input"
                                           placeholder="@T("VideoUrl")"
                                           value="@item.Url"
                                           @oninput="e => OnGalleryItemUrlChanged(item, e.Value?.ToString())" />
                                </div>
                                <input class="form-control content-editor-input"
                                       style="margin-top:.75rem"
                                       placeholder="@T("ThumbnailUrl")"
                                       value="@item.ThumbnailUrl"
                                       @oninput="e => item.ThumbnailUrl = e.Value?.ToString()" />
                            }

                            <div class="form-hint">@T("Source"): @AssetSourceLabel(item.ResourceSource, item.ResourceId)</div>
                            <input class="form-control content-editor-input"
                                   style="margin-top:.75rem"
                                   placeholder="@T("Caption")"
                                   value="@GetValue(item.Caption, CurrentLang)"
                                   @oninput="e => SetValue(item.Caption, CurrentLang, e.Value?.ToString())" />
                        </article>
                    }

                    <div class="content-body-actions">
                        <button class="btn-admin btn-ghost" disabled="@GalleryLimitReached" @onclick='() => AddGalleryItem("image")'><i class="fas fa-image"></i> @T("AddImage")</button>
                        <button class="btn-admin btn-ghost" disabled="@GalleryLimitReached" @onclick='() => AddGalleryItem("video")'><i class="fas fa-play"></i> @T("AddVideo")</button>
                    </div>
                </div>
            }

            @if (ShowsFile)
            {
                <div class="admin-card content-editor-card" style="margin-bottom:1rem">
                    <h2 style="font-size:1rem;margin:0 0 .35rem">@T("PrimaryFile")</h2>
                    <div class="form-hint" style="margin-bottom:.85rem">@T("PrimaryFileHint")</div>
                    @if (!string.IsNullOrWhiteSpace(_fileUrl))
                    {
                        <div class="content-attachment-row">
                            <i class="fas fa-file-pdf"></i>
                            <div>
                                <strong>@(string.IsNullOrWhiteSpace(_fileName) ? T("PrimaryFile") : _fileName)</strong>
                                <div class="text-muted" style="font-size:.8rem">@FormatBytes(_fileSize)</div>
                            </div>
                            <a class="btn-admin btn-ghost content-icon-btn" href="@_fileUrl" target="_blank" rel="noopener" title="@T("View")">
                                <i class="fas fa-eye"></i>
                            </a>
                            <button class="btn-admin btn-danger content-icon-btn" @onclick="RemoveFile" title="@T("Remove")">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    }
                    <label>@T("FileUrl")</label>
                    <input class="form-control content-editor-input" value="@_fileUrl" @oninput="OnFileUrlChanged" />
                    <label style="margin-top:.75rem">@T("FileName")</label>
                    <input class="form-control content-editor-input" value="@_fileName" @oninput="e => _fileName = e.Value?.ToString() ?? string.Empty" />
                    <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;margin-top:.75rem">
                        <InputFile class="content-editor-file-input"
                                   id="content-file-upload"
                                   OnChange="UploadFile"
                                   accept="application/pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt" />
                        <label class="btn-admin btn-ghost" for="content-file-upload">
                            <i class="fas fa-file-pdf"></i> @T("UploadNew")
                        </label>
                        <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("file", "primary-file")'>
                            <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                        </button>
                    </div>
                    <div class="form-hint">@T("Source"): @AssetSourceLabel(_fileResourceSource, _fileResourceId)</div>
                </div>
            }

            @if (ShowsVideo)
            {
                <div class="admin-card content-editor-card" style="margin-bottom:1rem">
                    <h2 style="font-size:1rem;margin:0 0 .35rem">@T("Video")</h2>
                    <div class="form-hint" style="margin-bottom:.85rem">@T("VideoUrlHint")</div>
                    <label>@T("VideoUrl")</label>
                    <div class="content-body-upload-row">
                        <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("video", "video")'>
                            <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                        </button>
                        <input class="form-control content-editor-input" value="@_edit.VideoUrl" @oninput="OnVideoUrlChanged" />
                    </div>
                    <div class="form-hint">@T("Source"): @AssetSourceLabel(_edit.VideoResourceSource, _edit.VideoResourceId)</div>
                </div>
            }

            @if (ShowsThumbnail)
            {
                <div class="admin-card content-editor-card">
                    <h2 style="font-size:1rem;margin:0 0 .35rem">@T("PreviewImage")</h2>
                    <div class="form-hint" style="margin-bottom:.85rem">@T("PreviewImageHint")</div>
                    @if (!string.IsNullOrWhiteSpace(_edit.ThumbnailUrl))
                    {
                        <img class="content-editor-preview" src="@_edit.ThumbnailUrl" alt="" />
                    }
                    <label>@T("ThumbnailUrl")</label>
                    <input class="form-control content-editor-input" value="@_edit.ThumbnailUrl" @oninput="OnThumbnailUrlChanged" />
                    <div style="margin-top:.75rem">
                        <InputFile class="content-editor-file-input"
                                   id="content-thumbnail-upload"
                                   OnChange="UploadThumbnail"
                                   accept="image/*" />
                        <label class="btn-admin btn-ghost" for="content-thumbnail-upload">
                            <i class="fas fa-image"></i> @T("UploadNew")
                        </label>
                        <button class="btn-admin btn-ghost" type="button" @onclick='() => OpenResourcePicker("image", "thumbnail")'>
                            <i class="fas fa-photo-film"></i> @T("ChooseFromResourceLibrary")
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_edit.ThumbnailUrl))
                        {
                            <button class="btn-admin btn-danger" type="button" @onclick="RemoveThumbnail">@T("RemoveImage")</button>
                        }
                    </div>
                    <div class="form-hint">@T("Source"): @AssetSourceLabel(_edit.ThumbnailResourceSource, _edit.ThumbnailResourceId)</div>
                </div>
            }
        </div>
    </div>
}

<ResourcePickerModal Open="_resourcePickerOpen"
                     Kind="_resourcePickerKind"
                     ResourceSelected="SelectResource"
                     Closed="CloseResourcePicker" />
@code {
    private const string DirectUploadSource = "DirectUpload";
    private const string ManagedResourceSource = "ManagedResource";
    private const int MaxGalleryItems = 30;

    [Parameter] public string? Id { get; set; }
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private List<ContentTypeModel> _types = new();
    private ContentItemRequest _edit = NewRequest();
