    {
        "file-resource" => T("FileResource"),
        "video-resource" => T("VideoResource"),
        "image-resource" => T("ImageResource"),
        "gallery" => T("Gallery"),
        _ => T("PageContent")
    };
    private string SelectedBehaviorHint => SelectedBehavior switch
    {
        "file-resource" => T("FileResourceEditorHint"),
        "video-resource" => T("VideoResourceEditorHint"),
        "image-resource" => T("ImageResourceEditorHint"),
        "gallery" => T("GalleryEditorHint"),
        _ => T("PageContentEditorHint")
    };
    private string SummaryLabel => IsPageContent ? T("Summary") : T("ResourceDescription");
    private string AssetSourceLabel(string? source, string? resourceId) =>
        string.Equals(NormalizeResourceSource(source, resourceId), ManagedResourceSource, StringComparison.OrdinalIgnoreCase)
            ? T("ManagedResource")
            : T("DirectUpload");
    private bool BodyLimitReached => _edit.BodyItems.Count >= 10;
    private bool GalleryLimitReached => _edit.GalleryItems.Count >= MaxGalleryItems;
    private string ReturnUrl => GetReturnUrl();
    private bool IsDraft => string.Equals(_status, "Draft", StringComparison.OrdinalIgnoreCase);
    private bool IsSubmitted => string.Equals(_status, "Submitted", StringComparison.OrdinalIgnoreCase);
    private bool IsPublished => string.Equals(_status, "Published", StringComparison.OrdinalIgnoreCase);
    private bool IsRejected => string.Equals(_status, "Rejected", StringComparison.OrdinalIgnoreCase);
    private bool IsDeleted => string.Equals(_status, "Deleted", StringComparison.OrdinalIgnoreCase);
    private bool CanSaveDraft => (Auth.CanManageAllContent || Auth.IsWriter) && !IsDeleted;
    private bool CanSubmit => (Auth.CanManageAllContent || Auth.IsWriter) && !IsSubmitted && !IsPublished && !IsDeleted;
    private bool CanReturnToDraft => (Auth.CanManageAllContent || Auth.IsWriter) && !IsNew && !IsDraft && !IsDeleted;
    private bool CanPublish => Auth.CanManageAllContent && !IsDeleted && !IsNew;
    private bool CanReject => Auth.CanManageAllContent && IsSubmitted;
    private bool CanDelete => Auth.CanManageAllContent && !IsDeleted && !IsNew;
    private bool CanRestore => Auth.CanManageAllContent && IsDeleted && !IsNew;
    private string StatusClass => _status.ToLowerInvariant() switch
    {
        "submitted" => "is-submitted",
        "published" => "is-published",
        "rejected" => "is-rejected",
        "deleted" => "is-deleted",
        _ => "is-draft"
    };

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);
    private static string ResolveBehavior(ContentTypeModel? type)
    {
        if (type is null) return "page";

        var behavior = NormalizeContentBehavior(type.Behavior);
        if (!string.IsNullOrWhiteSpace(type.Behavior))
            return behavior;

        var clickBehavior = type.ClickBehavior?.Trim().ToLowerInvariant();
        if (clickBehavior == "image") return "image-resource";
        if (type.RequiresVideoUrl || clickBehavior == "video") return "video-resource";
        if (type.RequiresFile || clickBehavior == "download" || !type.RequiresBody) return "file-resource";
        return "page";
    }

    private static string NormalizeContentBehavior(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "file" or "file-resource" or "download" or "resource" => "file-resource",
        "video" or "video-resource" or "webinar" => "video-resource",
        "image" or "image-resource" or "photo" or "picture" => "image-resource",
        "gallery" or "image-gallery" or "photo-gallery" or "media-gallery" => "gallery",
        _ => "page"
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Auth.RefreshSessionAsync();
        var typeRes = await ContentService.GetTypesAsync();
        _types = typeRes.Data ?? new();
        _edit.ContentTypeKey = _types.FirstOrDefault()?.Key ?? "article";

        if (!IsNew)
        {
            var res = await ContentService.GetByIdAsync(Id!);
            if (res.Success && res.Data is not null)
                LoadItem(res.Data);
            else
                Http.Toast(res.Message, res.StatusCode);
        }

        _loading = false;
    }

    private void LoadItem(ContentItemModel item)
    {
        _status = item.Status;
        _edit = new ContentItemRequest
        {
            ContentTypeKey = item.ContentTypeKey,
            Slug = item.Slug,
            Title = EnsureLangs(item.Title),
            Summary = EnsureLangs(item.Summary),
            BodyHtml = EnsureLangs(item.BodyHtml),
            BodyItems = NormalizeBodyItems(item.BodyItems, item.BodyHtml),
            GalleryItems = NormalizeGalleryItems(item.GalleryItems),
            HeroImageUrl = item.HeroImageUrl,
            HeroImageResourceId = item.HeroImageResourceId,
            HeroImageResourceSource = NormalizeResourceSource(item.HeroImageResourceSource, item.HeroImageResourceId),
            HeroImageStorageKey = item.HeroImageStorageKey,
            HeroImageAlt = item.HeroImageAlt,
            ThumbnailUrl = item.ThumbnailUrl,
            ThumbnailResourceId = item.ThumbnailResourceId,
            ThumbnailResourceSource = NormalizeResourceSource(item.ThumbnailResourceSource, item.ThumbnailResourceId),
            ThumbnailStorageKey = item.ThumbnailStorageKey,
            VideoUrl = item.VideoUrl,
            VideoResourceId = item.VideoResourceId,
            VideoResourceSource = NormalizeResourceSource(item.VideoResourceSource, item.VideoResourceId),
            VideoStorageKey = item.VideoStorageKey,
            ExternalUrl = item.ExternalUrl,
            TemplateKey = item.TemplateKey,
            Tags = item.Tags.ToList(),
            Attachments = item.Attachments.ToList(),
            Visible = item.Visible
        };

        _tags = item.Tags.ToList();
        _tagsText = string.Join(", ", _tags);
        var file = item.Attachments.FirstOrDefault();
        _fileUrl = file?.Url ?? string.Empty;
        _fileName = file?.FileName ?? string.Empty;
        _fileContentType = string.IsNullOrWhiteSpace(file?.ContentType) ? "application/pdf" : file.ContentType;
        _fileSize = file?.SizeBytes ?? 0;
        _fileResourceId = file?.ResourceId;
        _fileResourceSource = NormalizeResourceSource(file?.ResourceSource, file?.ResourceId);
        _fileStorageKey = file?.StorageKey;
        _expandedBodyItemIds = _edit.BodyItems.Take(1).Select(i => i.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private async Task Save()
    {
        await SaveCurrentAsync();
    }

    private async Task<bool> SaveCurrentAsync()
    {
        await FlushRichTextEditorsAsync();
        PrepareRequest();
        var res = IsNew
            ? await ContentService.CreateAsync(_edit)
            : await ContentService.UpdateAsync(Id!, _edit);

        Http.Toast(res.Message, res.StatusCode);
        if (!res.Success || res.Data is null) return false;

        if (IsNew)
        {
            Nav.NavigateTo($"/content/edit/{res.Data.Id}?return={Uri.EscapeDataString(ReturnUrl)}");
            return false;
        }
        else
            LoadItem(res.Data);

        return true;
    }

    private async Task FlushRichTextEditorsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("contentRichTextEditor.flushAll");
        }
        catch (JSException)
        {
        }
    }

    private async Task Submit() => await SetStatus("Submitted");
    private async Task ReturnToDraft() => await SetStatus("Draft");
    private async Task Reject() => await SetStatus("Rejected");

    private async Task Publish()
    {
        if (!await SaveCurrentAsync())
            return;

        if (IsNew) return;

        var res = await ContentService.PublishAsync(Id!);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null) LoadItem(res.Data);
    }

    private async Task SetStatus(string status)
    {
        if (!await SaveCurrentAsync())
            return;

        if (IsNew) return;

        var res = await ContentService.SetStatusAsync(Id!, status);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null) LoadItem(res.Data);
    }

    private async Task Delete()
    {
        if (IsNew) return;

        var res = await ContentService.DeleteAsync(Id!);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success) Nav.NavigateTo("/content/deleted");
    }

    private async Task Restore()
    {
        if (IsNew) return;

        var res = await ContentService.RestoreAsync(Id!);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null) LoadItem(res.Data);
    }


    private void OpenResourcePicker(string kind, string target, ContentBodyItemModel? bodyItem = null)
    {
        _resourcePickerKind = NormalizeResourceKind(kind);
        _resourcePickerTarget = target;
        _resourcePickerBodyItem = bodyItem;
        _resourcePickerGalleryItem = null;
        _resourcePickerOpen = true;
    }

    private void OpenGalleryResourcePicker(string kind, ContentGalleryItemModel item)
    {
        _resourcePickerKind = NormalizeResourceKind(kind);
        _resourcePickerTarget = "gallery-item";
        _resourcePickerBodyItem = null;
        _resourcePickerGalleryItem = item;
        _resourcePickerOpen = true;
    }

    private void SelectResource(ManagedResourceModel resource)
    {
        switch (_resourcePickerTarget)
        {
            case "hero":
                _edit.HeroImageUrl = resource.Url;
                _edit.HeroImageResourceId = resource.Id;
                _edit.HeroImageResourceSource = ManagedResourceSource;
                _edit.HeroImageStorageKey = resource.StorageKey;
                if (string.IsNullOrWhiteSpace(_edit.HeroImageAlt))
                    _edit.HeroImageAlt = ResourceName(resource);
                break;
            case "thumbnail":
                _edit.ThumbnailUrl = ResourceThumbnailUrl(resource);
                _edit.ThumbnailResourceId = resource.Id;
                _edit.ThumbnailResourceSource = ManagedResourceSource;
                _edit.ThumbnailStorageKey = resource.StorageKey;
                break;
            case "primary-file":
                SetPrimaryFileFromResource(resource);
                break;
            case "video":
                _edit.VideoUrl = resource.Url;
                _edit.VideoResourceId = resource.Id;
                _edit.VideoResourceSource = ManagedResourceSource;
                _edit.VideoStorageKey = resource.StorageKey;
                if (string.IsNullOrWhiteSpace(_edit.ThumbnailUrl) && !string.IsNullOrWhiteSpace(resource.ThumbnailUrl))
                    _edit.ThumbnailUrl = resource.ThumbnailUrl;
                break;
            case "body-image" when _resourcePickerBodyItem is not null:
                _resourcePickerBodyItem.Url = resource.Url;
                ApplyManagedResource(_resourcePickerBodyItem, resource);
                if (string.IsNullOrWhiteSpace(GetValue(_resourcePickerBodyItem.Caption, CurrentLang)))
                    SetValue(_resourcePickerBodyItem.Caption, CurrentLang, ResourceDescription(resource));
                break;
            case "body-file" when _resourcePickerBodyItem is not null:
                _resourcePickerBodyItem.Url = resource.Url;
                ApplyManagedResource(_resourcePickerBodyItem, resource);
                _resourcePickerBodyItem.FileName = ResourceFileName(resource);
                _resourcePickerBodyItem.ContentType = resource.ContentType;
                _resourcePickerBodyItem.SizeBytes = resource.SizeBytes;
                break;
            case "body-video" when _resourcePickerBodyItem is not null:
                _resourcePickerBodyItem.Url = resource.Url;
                ApplyManagedResource(_resourcePickerBodyItem, resource);
                break;
            case "gallery-item" when _resourcePickerGalleryItem is not null:
                SetGalleryItemFromResource(_resourcePickerGalleryItem, resource);
                break;
        }

        CloseResourcePicker();
    }

    private void CloseResourcePicker()
    {
        _resourcePickerOpen = false;
        _resourcePickerTarget = string.Empty;
        _resourcePickerBodyItem = null;
        _resourcePickerGalleryItem = null;
    }

    private void SetPrimaryFileFromResource(ManagedResourceModel resource)
    {
        _fileUrl = resource.Url;
        _fileName = ResourceFileName(resource);
        _fileContentType = string.IsNullOrWhiteSpace(resource.ContentType) ? "application/octet-stream" : resource.ContentType;
        _fileSize = resource.SizeBytes;
        _fileResourceId = resource.Id;
        _fileResourceSource = ManagedResourceSource;
        _fileStorageKey = resource.StorageKey;
    }

    private void SetGalleryItemFromResource(ContentGalleryItemModel item, ManagedResourceModel resource)
    {
        var kind = NormalizeResourceKind(resource.Kind);
        item.Kind = kind == "video" ? "video" : "image";
        item.Url = resource.Url;
        item.ThumbnailUrl = ResourceThumbnailUrl(resource);
        item.ResourceId = resource.Id;
        item.ResourceSource = ManagedResourceSource;
        item.StorageKey = resource.StorageKey;

        if (string.IsNullOrWhiteSpace(GetValue(item.Caption, CurrentLang)))
            SetValue(item.Caption, CurrentLang, ResourceDescription(resource));
    }

    private void ApplyGalleryThumbnail()
    {
        var first = _edit.GalleryItems
            .OrderBy(i => i.Order)
            .FirstOrDefault(i => i.Visible && !string.IsNullOrWhiteSpace(i.Url));

        if (first is null)
        {
            _edit.ThumbnailUrl = string.Empty;
            _edit.ThumbnailResourceId = string.Empty;
            _edit.ThumbnailResourceSource = DirectUploadSource;
            _edit.ThumbnailStorageKey = string.Empty;
            return;
        }

        _edit.ThumbnailUrl = !string.IsNullOrWhiteSpace(first.ThumbnailUrl) ? first.ThumbnailUrl : first.Url;
        _edit.ThumbnailResourceId = first.ResourceId;
        _edit.ThumbnailResourceSource = NormalizeResourceSource(first.ResourceSource, first.ResourceId);
        _edit.ThumbnailStorageKey = first.StorageKey;
    }

