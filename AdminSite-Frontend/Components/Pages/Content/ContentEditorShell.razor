    private static void ApplyManagedResource(ContentBodyItemModel item, ManagedResourceModel resource)
    {
        item.ResourceId = resource.Id;
        item.ResourceSource = ManagedResourceSource;
        item.StorageKey = resource.StorageKey;
    }

    private static void ApplyDirectUpload(ContentBodyItemModel item, string? storageKey = null)
    {
        item.ResourceId = null;
        item.ResourceSource = DirectUploadSource;
        item.StorageKey = storageKey;
    }

    private void PrepareRequest()
    {
        EnsureEnglishFallback(_edit.Title);
        EnsureEnglishFallback(_edit.Summary);

        if (IsPageContent)
        {
            EnsureEnglishFallback(_edit.BodyHtml);
            EnsureBodyItems();
            foreach (var item in _edit.BodyItems)
            {
                EnsureEnglishFallback(item.Content);
                EnsureEnglishFallback(item.Caption);
            }
            _edit.VideoUrl = string.Empty;
            _edit.VideoResourceId = string.Empty;
            _edit.VideoResourceSource = DirectUploadSource;
            _edit.VideoStorageKey = string.Empty;
            _edit.ThumbnailUrl = string.Empty;
            _edit.ThumbnailResourceId = string.Empty;
            _edit.ThumbnailResourceSource = DirectUploadSource;
            _edit.ThumbnailStorageKey = string.Empty;
            _edit.Attachments = new();
            _edit.GalleryItems = new();
        }
        else
        {
            _edit.BodyHtml = EnsureLangs(null);
            _edit.BodyItems = new();
            _edit.TemplateKey = string.Empty;
            _edit.HeroImageUrl = string.Empty;
            _edit.HeroImageResourceId = string.Empty;
            _edit.HeroImageResourceSource = DirectUploadSource;
            _edit.HeroImageStorageKey = string.Empty;
            _edit.HeroImageAlt = string.Empty;
        }

        AddPendingTag();
        _edit.Tags = _tags.ToList();
        _tagsText = string.Join(", ", _tags);

        if (IsFileResource)
        {
            _edit.VideoUrl = string.Empty;
            _edit.VideoResourceId = string.Empty;
            _edit.VideoResourceSource = DirectUploadSource;
            _edit.VideoStorageKey = string.Empty;
            _edit.GalleryItems = new();
            _edit.Attachments = string.IsNullOrWhiteSpace(_fileUrl)
                ? new()
                : new()
                {
                    new ContentAttachmentModel
                    {
                        FileName = string.IsNullOrWhiteSpace(_fileName) ? "download.pdf" : _fileName,
                        Url = _fileUrl,
                        ResourceId = _fileResourceId,
                        ResourceSource = NormalizeResourceSource(_fileResourceSource, _fileResourceId),
                        StorageKey = _fileStorageKey,
                        ContentType = string.IsNullOrWhiteSpace(_fileContentType) ? "application/pdf" : _fileContentType,
                        SizeBytes = _fileSize
                    }
                };
        }
        else if (IsVideoResource)
        {
            _edit.Attachments = new();
            _edit.GalleryItems = new();
        }
        else if (IsImageResource)
        {
            _edit.VideoUrl = string.Empty;
            _edit.VideoResourceId = string.Empty;
            _edit.VideoResourceSource = DirectUploadSource;
            _edit.VideoStorageKey = string.Empty;
            _edit.Attachments = new();
            _edit.GalleryItems = new();
        }
        else if (IsGalleryResource)
        {
            _edit.VideoUrl = string.Empty;
            _edit.VideoResourceId = string.Empty;
            _edit.VideoResourceSource = DirectUploadSource;
            _edit.VideoStorageKey = string.Empty;
            _edit.Attachments = new();
            _edit.GalleryItems = NormalizeGalleryItems(_edit.GalleryItems);
            foreach (var item in _edit.GalleryItems)
                EnsureEnglishFallback(item.Caption);
            ApplyGalleryThumbnail();
        }
        else
        {
            _edit.Attachments = new();
            _edit.GalleryItems = new();
        }
    }
