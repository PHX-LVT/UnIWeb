    private async Task UploadGalleryImage(ContentGalleryItemModel item, InputFileChangeEventArgs e)
    {
        var managed = await ContentService.UploadResourceAsync(e.File, "image");
        Http.Toast(managed.Message, managed.StatusCode);
        if (managed.Success && managed.Data is not null)
            SetGalleryItemFromResource(item, managed.Data);
    }

    private void AddBodyItem(string type)
    {
        if (BodyLimitReached) return;
        EnsureBodyItems();
        var item = NewBodyItem(type, _edit.BodyItems.Count);
        _edit.BodyItems.Add(item);
        _expandedBodyItemIds.Add(item.Id);
        ReorderBodyItems();
    }

    private void AddGalleryItem(string kind)
    {
        if (GalleryLimitReached) return;
        var item = NewGalleryItem(kind, _edit.GalleryItems.Count);
        _edit.GalleryItems.Add(item);
        ReorderGalleryItems();
    }

    private void RemoveGalleryItem(ContentGalleryItemModel item)
    {
        _edit.GalleryItems.Remove(item);
        ReorderGalleryItems();
    }

    private void MoveGalleryItem(ContentGalleryItemModel item, int direction)
    {
        var ordered = _edit.GalleryItems.OrderBy(i => i.Order).ToList();
        var index = ordered.FindIndex(i => i.Id == item.Id);
        var target = index + direction;
        if (index < 0 || target < 0 || target >= ordered.Count) return;

        (ordered[index], ordered[target]) = (ordered[target], ordered[index]);
        _edit.GalleryItems = ordered;
        ReorderGalleryItems();
    }

    private void ReorderGalleryItems()
    {
        _edit.GalleryItems = _edit.GalleryItems
            .Select((item, index) =>
            {
                item.Order = index;
                return item;
            })
            .ToList();
    }

    private void OnGalleryKindChanged(ContentGalleryItemModel item, string? kind)
    {
        item.Kind = NormalizeGalleryKind(kind);
        item.Url = string.Empty;
        item.ThumbnailUrl = string.Empty;
        item.ResourceId = null;
        item.ResourceSource = DirectUploadSource;
        item.StorageKey = null;
    }

    private static void OnGalleryItemUrlChanged(ContentGalleryItemModel item, string? value)
    {
        item.Url = value;
        if (NormalizeGalleryKind(item.Kind) == "image")
            item.ThumbnailUrl = value;
        item.ResourceId = null;
        item.ResourceSource = DirectUploadSource;
        item.StorageKey = null;
    }

    private void RemoveBodyItem(ContentBodyItemModel item)
    {
        if (_edit.BodyItems.Count <= 1) return;
        _edit.BodyItems.Remove(item);
        _expandedBodyItemIds.Remove(item.Id);
        ReorderBodyItems();
    }

    private void MoveBodyItem(ContentBodyItemModel item, int direction)
    {
        var ordered = _edit.BodyItems.OrderBy(i => i.Order).ToList();
        var index = ordered.FindIndex(i => i.Id == item.Id);
        var target = index + direction;
        if (index < 0 || target < 0 || target >= ordered.Count) return;

        (ordered[index], ordered[target]) = (ordered[target], ordered[index]);
        _edit.BodyItems = ordered;
        ReorderBodyItems();
    }

    private void EnsureBodyItems()
    {
        _edit.BodyItems = NormalizeBodyItems(_edit.BodyItems, _edit.BodyHtml);
    }

    private void ReorderBodyItems()
    {
        _edit.BodyItems = _edit.BodyItems
            .Select((item, index) =>
            {
                item.Order = index;
                return item;
            })
            .ToList();
    }

    private string BodyItemLabel(string type) => NormalizeBodyType(type) switch
    {
        "image" => T("Image"),
        "video" => T("Video"),
        "file" => T("File"),
        "quote" => T("Quote"),
        "cta" => "CTA",
        "divider" => T("Divider"),
        _ => T("Text")
    };

    private string GalleryItemLabel(string kind) => NormalizeGalleryKind(kind) switch
    {
        "video" => T("Video"),
        _ => T("Image")
    };

    private bool IsBodyItemExpanded(ContentBodyItemModel item) =>
        _expandedBodyItemIds.Contains(item.Id);

    private void ToggleBodyItem(ContentBodyItemModel item)
    {
        if (!_expandedBodyItemIds.Add(item.Id))
            _expandedBodyItemIds.Remove(item.Id);
    }

    private string BodyItemPreview(ContentBodyItemModel item)
    {
        var type = NormalizeBodyType(item.Type);
        var value = type switch
        {
            "image" => GetValue(item.Caption, CurrentLang, fallback: true),
            "video" => item.Url ?? GetValue(item.Caption, CurrentLang, fallback: true),
            "file" => item.FileName ?? item.Url ?? string.Empty,
            "divider" => T("Divider"),
            _ => HtmlToEditorText(GetValue(item.Content, CurrentLang, fallback: true))
        };

        if (string.IsNullOrWhiteSpace(value))
            value = T("Empty");

        value = value.ReplaceLineEndings(" ").Trim();
        return value.Length > 90 ? $"{value[..90]}..." : value;
    }

    private void RemoveFile()
    {
        _fileUrl = string.Empty;
        _fileName = string.Empty;
        _fileSize = 0;
        _fileResourceId = null;
        _fileResourceSource = DirectUploadSource;
        _fileStorageKey = null;
    }

    private void OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "," or "Tab")
            AddPendingTag();
    }

    private void AddPendingTag()
    {
        var value = _tagDraft.Trim().Trim(',');
        if (!string.IsNullOrWhiteSpace(value) &&
            !_tags.Any(tag => string.Equals(tag, value, StringComparison.OrdinalIgnoreCase)))
        {
            _tags.Add(value);
        }

        _tagDraft = string.Empty;
    }

    private void RemoveTag(string tag)
    {
        _tags.RemoveAll(t => string.Equals(t, tag, StringComparison.OrdinalIgnoreCase));
    }

    private void RemoveHero()
    {
        _edit.HeroImageUrl = string.Empty;
