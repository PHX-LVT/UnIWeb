    private async Task UploadHero(InputFileChangeEventArgs e)
    {
        var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=content-hero", e.File, maxBytes: 5 * 1024 * 1024);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null)
        {
            _edit.HeroImageUrl = res.Data.Url;
            _edit.HeroImageResourceId = null;
            _edit.HeroImageResourceSource = DirectUploadSource;
            _edit.HeroImageStorageKey = res.Data.StorageKey;
        }
    }

    private async Task UploadThumbnail(InputFileChangeEventArgs e)
    {
        if (IsImageResource)
        {
            var managed = await ContentService.UploadResourceAsync(e.File, "image");
            Http.Toast(managed.Message, managed.StatusCode);
            if (managed.Success && managed.Data is not null)
            {
                _edit.ThumbnailUrl = ResourceThumbnailUrl(managed.Data);
                _edit.ThumbnailResourceId = managed.Data.Id;
                _edit.ThumbnailResourceSource = ManagedResourceSource;
                _edit.ThumbnailStorageKey = managed.Data.StorageKey;
            }
            return;
        }

        var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=content-thumbnails", e.File, maxBytes: 5 * 1024 * 1024);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null)
        {
            _edit.ThumbnailUrl = res.Data.Url;
            _edit.ThumbnailResourceId = null;
            _edit.ThumbnailResourceSource = DirectUploadSource;
            _edit.ThumbnailStorageKey = res.Data.StorageKey;
        }
    }

    private async Task UploadFile(InputFileChangeEventArgs e)
    {
        if (!IsPageContent)
        {
            var managed = await ContentService.UploadResourceAsync(e.File, "file");
            Http.Toast(managed.Message, managed.StatusCode);
            if (managed.Success && managed.Data is not null)
                SetPrimaryFileFromResource(managed.Data);
            return;
        }

        var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=content-files", e.File, maxBytes: 20 * 1024 * 1024);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null)
        {
            _fileUrl = res.Data.Url;
            _fileName = res.Data.FileName;
            _fileContentType = res.Data.ContentType;
            _fileSize = res.Data.Size;
            _fileResourceId = null;
            _fileResourceSource = DirectUploadSource;
            _fileStorageKey = res.Data.StorageKey;
        }
    }

    private async Task UploadBodyImage(ContentBodyItemModel item, InputFileChangeEventArgs e)
    {
        var res = await Http.PostFileAsync<AssetUploadModel>("api/admin/assets/upload?folder=content-body", e.File, maxBytes: 5 * 1024 * 1024);
        Http.Toast(res.Message, res.StatusCode);
        if (res.Success && res.Data is not null)
