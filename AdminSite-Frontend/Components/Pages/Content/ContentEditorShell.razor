    private string GetLang(Dictionary<string, string> values) =>
        GetValue(values, CurrentLang, fallback: true);

    private static string GetValue(Dictionary<string, string> values, string lang, bool fallback = false) =>
        ResourceLibraryUiHelper.GetValue(values, lang, fallback);

    private static string GetBodyText(Dictionary<string, string> values, string lang)
    {
        var value = GetValue(values, lang);
        return HtmlToEditorText(value);
    }

    private static void SetValue(Dictionary<string, string> values, string lang, string? value)
    {
        values[lang] = value ?? string.Empty;
    }

    private static void SetBodyText(Dictionary<string, string> values, string lang, string? value)
    {
        values[lang] = value ?? string.Empty;
    }

    private static void SetBodyRichText(Dictionary<string, string> values, string lang, string html)
    {
        values[lang] = html ?? string.Empty;
    }

    private void EnsureEnglishFallback(Dictionary<string, string> values)
    {
        if (values.TryGetValue("en", out var en) && !string.IsNullOrWhiteSpace(en))
            return;

        var current = GetValue(values, CurrentLang);
        if (!string.IsNullOrWhiteSpace(current))
            values["en"] = current;
    }

    private static Dictionary<string, string> EnsureLangs(Dictionary<string, string>? source)
    {
        var result = source is null ? new() : new Dictionary<string, string>(source, StringComparer.OrdinalIgnoreCase);
        foreach (var lang in new[] { "en", "vi", "cn" })
            result.TryAdd(lang, string.Empty);
        return result;
    }

    private static string HtmlToEditorText(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var text = value
            .Replace("\r", string.Empty)
            .Replace("<br>", "\n", StringComparison.OrdinalIgnoreCase)
            .Replace("<br/>", "\n", StringComparison.OrdinalIgnoreCase)
            .Replace("<br />", "\n", StringComparison.OrdinalIgnoreCase);

        text = System.Text.RegularExpressions.Regex.Replace(text, @"</p>\s*<p[^>]*>", "\n\n", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^\s*<p[^>]*>", string.Empty, System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"</p>\s*$", string.Empty, System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"<[^>]+>", string.Empty);

        return System.Net.WebUtility.HtmlDecode(text).Trim();
    }

    private static List<ContentBodyItemModel> NormalizeBodyItems(List<ContentBodyItemModel>? source, Dictionary<string, string>? fallbackBodyHtml)
    {
        var items = (source ?? new())
            .OrderBy(i => i.Order)
            .Take(10)
            .Select((item, index) =>
            {
                item.Id = string.IsNullOrWhiteSpace(item.Id) ? Guid.NewGuid().ToString("N") : item.Id;
                item.Type = NormalizeBodyType(item.Type);
                item.Content = EnsureLangs(item.Content);
                item.Caption = EnsureLangs(item.Caption);
                item.ResourceSource = NormalizeResourceSource(item.ResourceSource, item.ResourceId);
                item.Visible = true;
                item.Order = index;
                return item;
            })
            .ToList();

        if (items.Count == 0)
        {
            var fallback = EnsureLangs(fallbackBodyHtml);
            items.Add(new ContentBodyItemModel
            {
                Id = Guid.NewGuid().ToString("N"),
                Type = "text",
                Content = fallback,
                Caption = EnsureLangs(null),
                Visible = true,
                Order = 0
            });
        }

        return items;
    }

    private static ContentBodyItemModel NewBodyItem(string type, int order) => new()
    {
        Id = Guid.NewGuid().ToString("N"),
        Type = NormalizeBodyType(type),
        Content = EnsureLangs(null),
        Caption = EnsureLangs(null),
        ResourceSource = DirectUploadSource,
        Visible = true,
        Order = order
    };

    private static List<ContentGalleryItemModel> NormalizeGalleryItems(List<ContentGalleryItemModel>? source)
    {
        return (source ?? new())
            .OrderBy(i => i.Order)
            .Take(MaxGalleryItems)
            .Where(i => !string.IsNullOrWhiteSpace(i.Url))
            .Select((item, index) =>
            {
                item.Id = string.IsNullOrWhiteSpace(item.Id) ? Guid.NewGuid().ToString("N") : item.Id;
                item.Kind = NormalizeGalleryKind(item.Kind);
                item.Caption = EnsureLangs(item.Caption);
                item.ResourceSource = NormalizeResourceSource(item.ResourceSource, item.ResourceId);
                item.Visible = true;
                item.Order = index;
                return item;
            })
            .ToList();
    }

    private static ContentGalleryItemModel NewGalleryItem(string kind, int order) => new()
    {
        Id = Guid.NewGuid().ToString("N"),
        Kind = NormalizeGalleryKind(kind),
        Caption = EnsureLangs(null),
        ResourceSource = DirectUploadSource,
        Visible = true,
        Order = order
    };

    private static string NormalizeResourceSource(string? source, string? resourceId)
    {
        if (!string.IsNullOrWhiteSpace(resourceId))
            return ManagedResourceSource;

        return string.Equals(source, ManagedResourceSource, StringComparison.OrdinalIgnoreCase)
            ? ManagedResourceSource
            : DirectUploadSource;
    }

    private static string NormalizeBodyType(string? type)
    {
        var value = (type ?? string.Empty).Trim().ToLowerInvariant();
        return value switch
        {
            "image" => "image",
            "video" => "video",
            "file" => "file",
            "quote" => "quote",
            "cta" => "cta",
            "divider" => "divider",
            _ => "text"
        };
    }

    private static string NormalizeGalleryKind(string? kind)
    {
        var value = (kind ?? string.Empty).Trim().ToLowerInvariant();
        return value is "video" or "webinar" ? "video" : "image";
    }

    private static string NormalizeLang(string? lang) =>
        ResourceLibraryUiHelper.NormalizeLang(lang);

    private string GetReturnUrl()
    {
        var uri = new Uri(Nav.Uri);
        var query = uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
        foreach (var part in query)
        {
            var pair = part.Split('=', 2);
            if (pair.Length == 2 && string.Equals(Uri.UnescapeDataString(pair[0]), "return", StringComparison.OrdinalIgnoreCase))
            {
                var value = Uri.UnescapeDataString(pair[1]);
                if (value.StartsWith("/content/", StringComparison.OrdinalIgnoreCase))
                    return value;
            }
        }

        return "/content/all";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes <= 0) return "0 KB";
        if (bytes < 1024 * 1024) return $"{Math.Max(1, bytes / 1024)} KB";
        return $"{bytes / 1024d / 1024d:0.0} MB";
    }

    private static ContentItemRequest NewRequest() => new()
    {
        Title = EnsureLangs(null),
        Summary = EnsureLangs(null),
        BodyHtml = EnsureLangs(null),
        BodyItems = new() { NewBodyItem("text", 0) },
        GalleryItems = new(),
        Visible = true
    };
