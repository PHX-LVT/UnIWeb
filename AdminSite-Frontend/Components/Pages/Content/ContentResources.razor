    private MarkupString ResourceVisual(ManagedResourceModel resource, string style, bool large = false)
    {
        var kind = NormalizeKind(resource.Kind);
        if (kind == "image" && !string.IsNullOrWhiteSpace(resource.Url))
        {
            var url = HtmlAttr(resource.Url);
            return (MarkupString)$"<img src='{url}' alt='' style='{HtmlAttr(style)}' />";
        }

        var icon = ResourceIconClass(resource);
        var frameStyle = large ? "width:100%;height:100%;font-size:2rem;" : HtmlAttr(style);
        return (MarkupString)$"<span style='display:inline-flex;{frameStyle};align-items:center;justify-content:center;border-radius:8px;background:#fff7e6;color:#0f2742'><i class='fas {icon}'></i></span>";
    }

    private static string ResourceIconClass(ManagedResourceModel resource)
    {
        var kind = NormalizeKind(resource.Kind);
        if (kind == "video") return "fa-play";
        if (kind == "image") return "fa-image";

        var fileName = resource.FileName ?? string.Empty;
        var contentType = resource.ContentType ?? string.Empty;
        var extension = System.IO.Path.GetExtension(fileName).ToLowerInvariant();
        if (extension == ".pdf" || contentType.Contains("pdf", StringComparison.OrdinalIgnoreCase)) return "fa-file-pdf";
        if (extension is ".doc" or ".docx" || contentType.Contains("word", StringComparison.OrdinalIgnoreCase)) return "fa-file-word";
        if (extension is ".xls" or ".xlsx" || contentType.Contains("excel", StringComparison.OrdinalIgnoreCase) || contentType.Contains("spreadsheet", StringComparison.OrdinalIgnoreCase)) return "fa-file-excel";
        if (extension is ".ppt" or ".pptx" || contentType.Contains("powerpoint", StringComparison.OrdinalIgnoreCase) || contentType.Contains("presentation", StringComparison.OrdinalIgnoreCase)) return "fa-file-powerpoint";
        if (extension is ".txt" or ".csv") return "fa-file-lines";
        if (extension is ".zip" or ".rar" or ".7z") return "fa-file-zipper";
        return "fa-file";
    }

    private static string HtmlAttr(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

    private string DisplayKind(string kind) => NormalizeKind(kind) switch
    {
        "image" => T("ImageResource"),
        "video" => T("VideoResource"),
        _ => T("FileResource")
    };

    private string ResourceName(ManagedResourceModel resource) =>
        ResourceLibraryUiHelper.ResourceName(resource, CurrentLang);

    private string ResourceDescription(ManagedResourceModel resource) =>
        ResourceLibraryUiHelper.ResourceDescription(resource, CurrentLang);

    private static string ResourceFileName(ManagedResourceModel resource) =>
        ResourceLibraryUiHelper.ResourceFileName(resource);

    private string ResourceHint(ManagedResourceModel resource)
    {
        var kind = NormalizeKind(resource.Kind);
        if (kind == "file") return ResourceFileName(resource);
        return DisplayKind(resource.Kind);
    }

    private string UploadedByLabel(ManagedResourceModel resource)
    {
        if (string.IsNullOrWhiteSpace(resource.CreatedById)) return "-";

        if (Auth.CurrentUser is not null &&
            string.Equals(resource.CreatedById, Auth.CurrentUser.AdminId, StringComparison.OrdinalIgnoreCase))
        {
            return AdminDisplayName(Auth.CurrentUser.FullName, Auth.CurrentUser.Email);
        }

        var user = _adminUsers.FirstOrDefault(u => string.Equals(u.Id, resource.CreatedById, StringComparison.OrdinalIgnoreCase));
        return user is null
            ? resource.CreatedById
            : AdminDisplayName(user.FullName, user.Email);
    }

    private static string AdminDisplayName(string? fullName, string? email)
    {
        var cleanName = (fullName ?? string.Empty).Trim();
        var cleanEmail = (email ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(cleanName)) return EmptyDash(cleanEmail);
        if (string.IsNullOrWhiteSpace(cleanEmail) || string.Equals(cleanName, cleanEmail, StringComparison.OrdinalIgnoreCase))
            return cleanName;

        return $"{cleanName} ({cleanEmail})";
    }

    private string UsageText(ManagedResourceModel resource) =>
        resource.UsageCount <= 0
            ? T("UsageNotUsed")
            : string.Format(T("UsageUsedInPlaces"), resource.UsageCount, resource.UsageCount == 1 ? string.Empty : "s");

    private static string UsageStyle(ManagedResourceModel resource) =>
        resource.UsageCount <= 0
            ? "display:inline-flex;padding:.2rem .45rem;border-radius:999px;background:#ecfdf5;color:#166534;font-size:.8rem"
            : "display:inline-flex;padding:.2rem .45rem;border-radius:999px;background:#fff7ed;color:#9a3412;font-size:.8rem";

    private string DeleteTitle(ManagedResourceModel resource) =>
        resource.IsInUse ? T("DeleteResourceInUseBlocked") : T("Delete");

    private static string UsageReferenceText(ManagedResourceUsageReferenceModel reference)
    {
        var title = string.IsNullOrWhiteSpace(reference.Title) ? reference.ItemId : reference.Title;
        var detail = string.IsNullOrWhiteSpace(reference.Detail) ? string.Empty : $" - {reference.Detail}";
        return $"{reference.Source}: {title} / {reference.Field}{detail}";
    }

    private static string UsageReferenceTitle(ManagedResourceUsageReferenceModel reference) =>
        string.IsNullOrWhiteSpace(reference.Title) ? reference.ItemId : reference.Title;

    private static string UsageReferenceMeta(ManagedResourceUsageReferenceModel reference)
    {
        var parts = new[]
        {
            reference.Source,
            reference.Field,
            reference.Status,
            reference.Detail
        }.Where(part => !string.IsNullOrWhiteSpace(part));

        return string.Join(" / ", parts);
    }

    private static string FormatBytes(long bytes) =>
        ResourceLibraryUiHelper.FormatBytes(bytes);

    private static string EmptyDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private string MainPanelTitle =>
        SelectedAlbum is not null
            ? SelectedAlbum.Name
            : ShowingAlbumRoot
                ? T("Albums")
                : T("Resources");

    private bool MatchesAlbumFilters(ResourceAlbumModel album)
    {
        var expectedScope = AlbumScopeForKindFilter();
        if (!string.IsNullOrWhiteSpace(expectedScope) &&
            !string.Equals(album.Scope, expectedScope, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_search)) return true;
        return album.Name.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private bool CanAssignExistingResourceToSelectedAlbum(ManagedResourceModel resource)
    {
        var album = SelectedAlbum;
        if (album is null) return false;
        if (string.Equals(resource.AlbumId, album.Id, StringComparison.OrdinalIgnoreCase)) return false;
        return string.Equals(AlbumScopeForKind(resource.Kind), NormalizeAlbumScope(album.Scope), StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesAlbumExistingSearch(ManagedResourceModel resource)
    {
        if (string.IsNullOrWhiteSpace(_albumExistingSearch)) return true;
        var term = _albumExistingSearch.Trim();
        return ResourceName(resource).Contains(term, StringComparison.OrdinalIgnoreCase) ||
               ResourceFileName(resource).Contains(term, StringComparison.OrdinalIgnoreCase) ||
               resource.ContentType.Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private IEnumerable<ResourceAlbumModel> AlbumsForKind(string? kind)
    {
        var scope = AlbumScopeForKind(kind);
        return _albums
            .Where(a => string.Equals(a.Scope, scope, StringComparison.OrdinalIgnoreCase))
            .OrderBy(a => a.Name, StringComparer.OrdinalIgnoreCase);
    }

    private void EnsureSelectedAlbumMatchesKind()
    {
        if (SelectedAlbum is null) return;
        var expectedScope = AlbumScopeForKindFilter();
        if (string.IsNullOrWhiteSpace(expectedScope)) return;
        if (!string.Equals(SelectedAlbum.Scope, expectedScope, StringComparison.OrdinalIgnoreCase))
        {
            _selectedAlbumId = null;
            _selectedResource = null;
            _selectedResourceIds.Clear();
        }
    }

    private string AlbumScopeForKindFilter() => NormalizeKind(_kindFilter) switch
    {
        "file" when !string.IsNullOrWhiteSpace(_kindFilter) => "file",
        "image" or "video" => "media",
        _ => string.Empty
    };

    private static string AlbumScopeForKind(string? kind) =>
        NormalizeKind(kind) == "file" ? "file" : "media";

    private string DefaultAlbumScope() =>
        AlbumScopeForKindFilter() is { Length: > 0 } scope ? scope : "media";

    private static string NormalizeAlbumScope(string? scope) =>
        string.Equals(scope, "file", StringComparison.OrdinalIgnoreCase) ? "file" : "media";

    private string AlbumScopeLabel(string scope) =>
        NormalizeAlbumScope(scope) == "file" ? T("FileAlbum") : T("MediaAlbum");

    private string DeleteAlbumTitle(ResourceAlbumModel album) =>
        album.ResourceCount > 0 ? T("DeleteAlbumInUseBlocked") : T("Delete");

    private static string? EmptyToNull(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private string DefaultUploadKind()
    {
        if (SelectedAlbum is not null)
            return NormalizeAlbumScope(SelectedAlbum.Scope) == "file"
                ? "file"
                : NormalizeKind(_kindFilter) == "video" ? "video" : "image";

        var filteredKind = NormalizeKind(_kindFilter);
        return string.IsNullOrWhiteSpace(_kindFilter) ? "image" : filteredKind;
    }

    private void ApplyUploadAlbumConstraints()
    {
        if (SelectedAlbum is not null)
            _uploadAlbumId = SelectedAlbum.Id;

        var album = UploadAlbum;
        if (album is null) return;

        var expectedScope = NormalizeAlbumScope(album.Scope);
        if (expectedScope == "file")
        {
            _uploadKind = "file";
            return;
        }

        if (_uploadKind == "file")
            _uploadKind = "image";
    }

    private static string UploadAcceptForKind(string kind) => NormalizeKind(kind) switch
    {
        "image" => "image/jpeg,image/png,image/webp,image/gif,.jpg,.jpeg,.png,.webp,.gif",
        "video" => "video/mp4,video/webm,video/quicktime,.mp4,.webm,.mov",
        _ => ".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation"
    };

    private string ValidateQueuedFile(IBrowserFile file, string kind)
    {
        var normalizedKind = NormalizeKind(kind);
        var album = UploadAlbum;
        if (album is not null &&
            !string.Equals(album.Scope, AlbumScopeForKind(normalizedKind), StringComparison.OrdinalIgnoreCase))
        {
            return T("UploadAlbumKindMismatch");
        }

        var maxBytes = MaxUploadBytesForKind(normalizedKind);
        if (file.Size > maxBytes)
            return string.Format(T("FileTooLarge"), FormatBytes(maxBytes));

        if (!UploadFileMatchesKind(file, normalizedKind))
            return T("InvalidFileTypeForResource");

        return string.Empty;
    }

    private static long MaxUploadBytesForKind(string kind) => NormalizeKind(kind) switch
    {
        "image" => MaxImageUploadBytes,
        "video" => MaxVideoUploadBytes,
        _ => MaxFileUploadBytes
    };

    private static bool UploadFileMatchesKind(IBrowserFile file, string kind)
    {
        var ext = System.IO.Path.GetExtension(file.Name).ToLowerInvariant();
        var contentType = (file.ContentType ?? string.Empty).Trim().ToLowerInvariant();
        return NormalizeKind(kind) switch
        {
            "image" => contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) ||
                       ext is ".jpg" or ".jpeg" or ".png" or ".webp" or ".gif",
            "video" => contentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase) ||
                       ext is ".mp4" or ".webm" or ".mov",
            _ => ext is ".pdf" or ".doc" or ".docx" or ".xls" or ".xlsx" or ".ppt" or ".pptx" or ".txt"
        };
    }

    private static string DefaultResourceName(string fileName)
    {
        var name = System.IO.Path.GetFileNameWithoutExtension(fileName);
        return string.IsNullOrWhiteSpace(name) ? fileName : name;
    }

    private static string CleanQueueResourceName(ResourceUploadQueueItem item)
    {
        var clean = (item.ResourceName ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(clean) ? DefaultResourceName(item.OriginalFileName) : clean;
    }

    private string UploadQueueIconClass(ResourceUploadQueueItem item)
    {
        var kind = NormalizeKind(_uploadKind);
        if (kind == "image") return "fa-image";
        if (kind == "video") return "fa-play";

        var extension = System.IO.Path.GetExtension(item.OriginalFileName).ToLowerInvariant();
        return extension switch
        {
            ".pdf" => "fa-file-pdf",
            ".doc" or ".docx" => "fa-file-word",
            ".xls" or ".xlsx" => "fa-file-excel",
            ".ppt" or ".pptx" => "fa-file-powerpoint",
            ".txt" => "fa-file-lines",
            _ => "fa-file"
        };
    }

    private string UploadQueueStatusText(ResourceUploadQueueItem item) => item.Status switch
    {
        UploadQueueStatus.Uploading => T("Uploading"),
        UploadQueueStatus.Done => T("Done"),
        UploadQueueStatus.Failed => T("Failed"),
        UploadQueueStatus.Blocked => T("Blocked"),
        _ => T("Queued")
    };

    private static string UploadQueueStatusStyle(ResourceUploadQueueItem item) => item.Status switch
    {
        UploadQueueStatus.Done => "display:inline-flex;padding:.18rem .45rem;border-radius:999px;background:#ecfdf5;color:#166534;font-size:.78rem",
        UploadQueueStatus.Failed or UploadQueueStatus.Blocked => "display:inline-flex;padding:.18rem .45rem;border-radius:999px;background:#fef2f2;color:#b91c1c;font-size:.78rem",
        UploadQueueStatus.Uploading => "display:inline-flex;padding:.18rem .45rem;border-radius:999px;background:#eff6ff;color:#1d4ed8;font-size:.78rem",
        _ => "display:inline-flex;padding:.18rem .45rem;border-radius:999px;background:#f1f5f9;color:#334155;font-size:.78rem"
    };

    private static bool IsPdf(ManagedResourceModel resource) =>
        string.Equals(resource.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase) ||
        resource.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ||
        resource.Url.Contains(".pdf", StringComparison.OrdinalIgnoreCase);

    private string KindButtonClass(string kind) =>
        $"btn-admin {(string.Equals(_kindFilter, kind, StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-ghost")}";

    private string ViewButtonClass(string mode) =>
        $"btn-admin {(string.Equals(_viewMode, mode, StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-ghost")}";

    private string ModeButtonClass(string mode) =>
        $"btn-admin {(string.Equals(_libraryMode, mode, StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-ghost")}";

    private string GetValue(Dictionary<string, string> values, string lang, bool fallback = false) =>
        ResourceLibraryUiHelper.GetValue(values, lang, fallback);

    private static void SetValue(Dictionary<string, string> values, string lang, string? value)
    {
        values[lang] = value ?? string.Empty;
    }

    private Dictionary<string, string> EnsureLangs(Dictionary<string, string>? source)
    {
        var result = source is null ? new() : new Dictionary<string, string>(source, StringComparer.OrdinalIgnoreCase);
        foreach (var lang in _languages)
            result.TryAdd(lang, string.Empty);
        return result;
    }

    private static string NormalizeKind(string? value) =>
        ResourceLibraryUiHelper.NormalizeKind(value);

    private static string NormalizeLang(string? lang) =>
        ResourceLibraryUiHelper.NormalizeLang(lang);

    private ManagedResourceRequest NewRequest(string kind = "file") => new()
    {
        Kind = NormalizeKind(kind),
        Name = EnsureLangs(null),
        Description = EnsureLangs(null),
        Source = "managed-upload",
        Active = true
    };

    private static class UploadQueueStatus
    {
        public const string Queued = "Queued";
        public const string Uploading = "Uploading";
        public const string Done = "Done";
        public const string Failed = "Failed";
        public const string Blocked = "Blocked";
    }

    private sealed class ResourceUploadQueueItem
    {
        public string Id { get; } = Guid.NewGuid().ToString("N");
        public IBrowserFile File { get; set; } = default!;
        public string OriginalFileName { get; set; } = string.Empty;
        public string ResourceName { get; set; } = string.Empty;
        public string Status { get; set; } = UploadQueueStatus.Queued;
        public string? Error { get; set; }
        public ManagedResourceModel? Resource { get; set; }
        public bool IsComplete => string.Equals(Status, UploadQueueStatus.Done, StringComparison.OrdinalIgnoreCase);
        public bool IsFailed => string.Equals(Status, UploadQueueStatus.Failed, StringComparison.OrdinalIgnoreCase);
        public bool CanUpload =>
            string.Equals(Status, UploadQueueStatus.Queued, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(Status, UploadQueueStatus.Failed, StringComparison.OrdinalIgnoreCase);
    }
}
