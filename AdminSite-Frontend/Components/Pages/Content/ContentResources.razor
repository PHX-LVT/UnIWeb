@page "/content/resources"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@inject AdminContentService ContentService
@inject AdminUserService Users
@inject AdminLanguageService AdminLanguageState
@inject AdminAuthService Auth
@inject IHttpService Http

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
    <h1 class="page-title"><i class="fas fa-photo-film"></i> @T("ResourceLibrary")</h1>
    @if (CanManageResources || CanUploadResources)
    {
        <div style="display:flex;gap:.5rem;flex-wrap:wrap">
            @if (CanManageResources)
            {
                <button class="btn-admin btn-ghost" @onclick="() => OpenAlbumEditor(null)">
                    <i class="fas fa-folder-plus"></i> @T("AddAlbum")
                </button>
            }
            @if (CanUploadResources)
            {
                <button class="btn-admin btn-primary" @onclick="NewResource">
                    <i class="fas fa-upload"></i> @T("UploadResources")
                </button>
            }
        </div>
    }
</div>

@if (!CanViewResourceLibrary)
{
    <div class="admin-card">
        <p class="text-muted">@T("NoPermission")</p>
    </div>
}
else
{
    <div class="admin-card" style="margin-bottom:1rem">
        <div style="display:flex;gap:.75rem;align-items:center;justify-content:space-between;flex-wrap:wrap">
            <div style="flex:1;min-width:240px">
                <input class="form-control" placeholder="@T("SearchResources")" value="@_search" @oninput="OnSearchChanged" />
            </div>

            <div>
                <div style="display:flex;gap:.35rem;flex-wrap:wrap">
                    <button type="button" class="@KindButtonClass(string.Empty)" @onclick='() => SetKindFilter(string.Empty)'>@T("All")</button>
                    <button type="button" class="@KindButtonClass("image")" @onclick='() => SetKindFilter("image")'>@T("ImageResource")</button>
                    <button type="button" class="@KindButtonClass("video")" @onclick='() => SetKindFilter("video")'>@T("VideoResource")</button>
                    <button type="button" class="@KindButtonClass("file")" @onclick='() => SetKindFilter("file")'>@T("FileResource")</button>
                </div>
            </div>

            <div>
                <div style="display:flex;gap:.35rem;flex-wrap:wrap">
                    <button type="button" class="@ModeButtonClass("resources")" @onclick='() => SetLibraryMode("resources")'>@T("ResourceView")</button>
                    <button type="button" class="@ModeButtonClass("albums")" @onclick='() => SetLibraryMode("albums")'>@T("AlbumView")</button>
                </div>
            </div>

            <div>
                <div style="display:flex;gap:.35rem">
                    <button type="button" class="@ViewButtonClass("grid")" title="@T("GridView")" @onclick='() => SetViewMode("grid")'>
                        <i class="fas fa-grid-2"></i>
                    </button>
                    <button type="button" class="@ViewButtonClass("list")" title="@T("ListView")" @onclick='() => SetViewMode("list")'>
                        <i class="fas fa-list"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:minmax(260px,320px) minmax(0,1fr);gap:1rem;align-items:start">
        <aside class="admin-card" style="position:sticky;top:1rem">
            @if (_selectedResource is null)
            {
                <div style="min-height:260px;display:grid;place-items:center;text-align:center">
                    <p class="text-muted">@T("NoResourceSelected")</p>
                </div>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:.75rem">
                    <button type="button"
                            style="width:100%;height:132px;border:1px solid #d8e0ea;border-radius:8px;background:#f8fafc;overflow:hidden;display:grid;place-items:center;padding:0;cursor:pointer"
                            title="@T("PreviewResource")"
                            @onclick="() => PreviewResource(_selectedResource)">
                        @ResourceVisual(_selectedResource, "width:100%;height:100%;object-fit:cover", large: true)
                    </button>

                    <div>
                        <h2 style="font-size:1.02rem;margin:0 0 .25rem;line-height:1.25;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@ResourceName(_selectedResource)</h2>
                        @if (!string.IsNullOrWhiteSpace(ResourceDescription(_selectedResource)))
                        {
                            <p class="text-muted" style="margin:.25rem 0 0;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@ResourceDescription(_selectedResource)</p>
                        }
                    </div>

                    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                        <button class="btn-admin btn-primary" @onclick="() => PreviewResource(_selectedResource)">
                            <i class="fas fa-eye"></i> @T("Preview")
                        </button>
                        @if (CanManageResources)
                        {
                            <button class="btn-admin btn-ghost content-icon-btn" title="@T("Edit")" @onclick="() => EditResource(_selectedResource)">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-admin btn-danger content-icon-btn"
                                    disabled="@_selectedResource.IsInUse"
                                    title="@DeleteTitle(_selectedResource)"
                                    @onclick="() => AskDeleteResource(_selectedResource)">
                                <i class="fas fa-trash"></i>
                            </button>
                        }
                    </div>

                    <dl style="display:grid;gap:.45rem;margin:0">
                        <div>
                            <dt style="font-size:.75rem;text-transform:uppercase;color:#64748b">@T("Usage")</dt>
                            <dd style="margin:0"><span style="@UsageStyle(_selectedResource)">@UsageText(_selectedResource)</span></dd>
                        </div>
                        <div>
                            <dt style="font-size:.75rem;text-transform:uppercase;color:#64748b">@T("FileSize")</dt>
                            <dd style="margin:0">@FormatBytes(_selectedResource.SizeBytes)</dd>
                        </div>
                        <div>
                            <dt style="font-size:.75rem;text-transform:uppercase;color:#64748b">@T("MimeType")</dt>
                            <dd style="margin:0;word-break:break-word">@EmptyDash(_selectedResource.ContentType)</dd>
                        </div>
                        <div>
                            <dt style="font-size:.75rem;text-transform:uppercase;color:#64748b">@T("UploadedBy")</dt>
                            <dd style="margin:0;word-break:break-word">@UploadedByLabel(_selectedResource)</dd>
                        </div>
                        <div>
                            <dt style="font-size:.75rem;text-transform:uppercase;color:#64748b">@T("Created")</dt>
                            <dd style="margin:0">@_selectedResource.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
                        </div>
                        <div>
                            <dt style="font-size:.75rem;text-transform:uppercase;color:#64748b">@T("Updated")</dt>
                            <dd style="margin:0">@_selectedResource.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
                        </div>
                    </dl>

                    <div style="border-top:1px solid #e5e7eb;padding-top:1rem">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;margin-bottom:.65rem">
                            <strong>@T("UsageDetails")</strong>
                            @if (_selectedResource.UsageCount > 0)
                            {
                                <button type="button"
                                        class="btn-admin btn-ghost content-icon-btn"
                                        title="@T("RefreshUsage")"
                                        disabled="@IsUsageLoading(_selectedResource)"
                                        @onclick="() => LoadUsageDetails(_selectedResource, force: true)">
                                    <i class="fas fa-rotate"></i>
                                </button>
                            }
                        </div>

                        @if (_selectedResource.UsageCount <= 0)
                        {
                            <p class="text-muted" style="margin:0">@T("NotUsedAnywhereSafeToDelete")</p>
                        }
                        else if (IsUsageLoading(_selectedResource))
                        {
                            <p class="text-muted" style="margin:0">@T("UsageLoading")</p>
                        }
                        else if (SelectedUsage is { References.Count: > 0 } usage)
                        {
                            <ul style="display:grid;gap:.5rem;margin:.5rem 0 0;padding:0;list-style:none;max-height:260px;overflow:auto">
                                @foreach (var reference in usage.References)
                                {
                                    <li style="padding:.55rem;border:1px solid #e5e7eb;border-radius:8px;background:#f8fafc">
                                        <div style="font-weight:600">@UsageReferenceTitle(reference)</div>
                                        <div class="text-muted" style="font-size:.82rem">@UsageReferenceMeta(reference)</div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <button type="button" class="btn-admin btn-ghost" @onclick="() => LoadUsageDetails(_selectedResource, force: true)">
                                <i class="fas fa-list-check"></i> @T("LoadUsageDetails")
                            </button>
                        }
                    </div>
                </div>
            }
        </aside>

        <section class="admin-card">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
                <div>
                    @if (SelectedAlbum is not null)
                    {
                        <button type="button" class="btn-admin btn-ghost" style="margin-right:.5rem" @onclick="BackToAlbums">
                            <i class="fas fa-arrow-left"></i> @T("BackToAlbums")
                        </button>
                    }
                    <strong>@MainPanelTitle</strong>
                    <span class="text-muted" style="margin-left:.5rem">@VisibleItemCount</span>
                </div>
                @if (CanUploadResources && SelectedAlbum is not null)
                {
                    <button class="btn-admin btn-primary" @onclick="NewResource">
                        <i class="fas fa-upload"></i> @T("UploadToAlbum")
                    </button>
                }
                @if (!_loading && VisibleItemCount > 0)
                {
                    <span class="text-muted">
                        @string.Format(T("ShowingRange"), PageStart, PageEnd, VisibleItemCount)
                    </span>
                }
            </div>

            @if (_loading || _albumLoading)
            {
                <p class="text-muted">@T("Loading")</p>
            }
            else if (VisibleItemCount == 0)
            {
                <div style="min-height:280px;display:grid;place-items:center;text-align:center">
                    <div>
                        <p class="text-muted">@T(ShowingAlbumRoot ? "NoAlbumsYet" : "NoResourcesYet")</p>
                        @if (CanUploadResources && SelectedAlbum is not null)
                        {
                            <button class="btn-admin btn-primary" @onclick="NewResource">
                                <i class="fas fa-upload"></i> @T("UploadToAlbum")
                            </button>
                        }
                    </div>
                </div>
            }
            else if (!ShowingAlbumRoot && CanManageResources && _selectedResourceIds.Any())
            {
                <div class="alert alert-info" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
                    <span>
                        @string.Format(T("SelectedCount"), _selectedResourceIds.Count)
                        @if (SelectedBlockedCount > 0)
                        {
                            <span> - @string.Format(T("BulkDeleteResourcesBlocked"), SelectedBlockedCount)</span>
                        }
                    </span>
                    <span style="display:flex;gap:.5rem;flex-wrap:wrap">
                        <button class="btn-admin btn-ghost" type="button" @onclick="ClearSelection">@T("ClearSelection")</button>
                        <button class="btn-admin btn-danger"
                                type="button"
                                disabled="@(!BulkDeleteResources.Any())"
                                @onclick="AskBulkDeleteResources">
                            <i class="fas fa-trash"></i> @T("BulkDeleteResources")
                        </button>
                    </span>
                </div>
            }

            @if (!_loading && !_albumLoading && ShowingAlbumRoot && VisibleItemCount > 0 && _viewMode == "list")
            {
                <div style="overflow:auto">
                    <table class="table content-table" style="width:100%">
                        <thead>
                            <tr>
                                <th>@T("Album")</th>
                                <th>@T("Type")</th>
                                <th>@T("Resources")</th>
                                @if (CanManageResources)
                                {
                                    <th></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var album in PagedAlbums)
                            {
                                <tr style="cursor:pointer" @onclick="() => OpenAlbum(album)">
                                    <td>
                                        <div style="display:flex;align-items:center;gap:.75rem;min-width:260px">
                                            <span style="display:inline-flex;width:56px;height:42px;align-items:center;justify-content:center;border-radius:8px;background:#eef2ff;color:#0f2742">
                                                <i class="fas fa-folder"></i>
                                            </span>
                                            <strong>@album.Name</strong>
                                        </div>
                                    </td>
                                    <td>@AlbumScopeLabel(album.Scope)</td>
                                    <td>@album.ResourceCount</td>
                                    @if (CanManageResources)
                                    {
                                        <td style="width:96px">
                                            <div style="display:flex;gap:.35rem;justify-content:flex-end">
                                                <button class="btn-admin btn-ghost content-icon-btn"
                                                        title="@T("Edit")"
                                                        @onclick="() => OpenAlbumEditor(album)"
                                                        @onclick:stopPropagation="true">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn-admin btn-danger content-icon-btn"
                                                        title="@DeleteAlbumTitle(album)"
                                                        @onclick="() => AskDeleteAlbum(album)"
                                                        @onclick:stopPropagation="true">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (!_loading && !_albumLoading && ShowingAlbumRoot && VisibleItemCount > 0)
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.85rem">
                    @foreach (var album in PagedAlbums)
                    {
                        <div class="admin-card" style="position:relative;padding:.6rem;text-align:left;border-color:#d8e0ea;box-shadow:none">
                            @if (CanManageResources)
                            {
                                <div style="position:absolute;top:.5rem;right:.5rem;display:flex;gap:.25rem;z-index:1">
                                    <button class="btn-admin btn-ghost content-icon-btn"
                                            title="@T("Edit")"
                                            @onclick="() => OpenAlbumEditor(album)">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn-admin btn-danger content-icon-btn"
                                            title="@DeleteAlbumTitle(album)"
                                            @onclick="() => AskDeleteAlbum(album)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            }
                            <button type="button"
                                    style="width:100%;border:0;background:transparent;padding:0;text-align:left;cursor:pointer"
                                    @onclick="() => OpenAlbum(album)">
                                <span style="display:flex;aspect-ratio:4/3;border-radius:8px;overflow:hidden;background:#eef2ff;border:1px solid #e5e7eb;margin-bottom:.55rem;align-items:center;justify-content:center;color:#0f2742;font-size:2rem">
                                    <i class="fas fa-folder"></i>
                                </span>
                                <strong style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@album.Name</strong>
                                <small class="text-muted" style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                    @AlbumScopeLabel(album.Scope) &middot; @string.Format(T("ResourceCount"), album.ResourceCount)
                                </small>
                            </button>
                        </div>
                    }
                </div>
            }
            else if (!_loading && FilteredResourceCount > 0 && _viewMode == "list")
            {
                <div style="overflow:auto">
                    <table class="table content-table" style="width:100%">
                        <thead>
                            <tr>
                                @if (CanManageResources)
                                {
                                    <th style="width:38px">
                                        <input type="checkbox"
                                               checked="@AllPagedBulkSelected"
                                               title="@T("SelectPage")"
                                               @onchange="ToggleAllPagedBulk" />
                                    </th>
                                }
                                <th colspan="2">@T("Name")</th>
                                <th>@T("Type")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var resource in PagedResources)
                            {
                                <tr class="@(IsSelected(resource) ? "is-selected" : string.Empty)"
                                    style="cursor:pointer"
                                    @onclick="() => SelectResource(resource)">
                                    @if (CanManageResources)
                                    {
                                        <td>
                                            <input type="checkbox"
                                                   checked="@IsBulkSelected(resource)"
                                                   disabled="@resource.IsInUse"
                                                   title="@BulkSelectTitle(resource)"
                                                   @onclick:stopPropagation="true"
                                                   @onchange="e => ToggleBulkSelected(resource, e)" />
                                        </td>
                                    }
                                    <td colspan="2">
                                        <div style="display:flex;align-items:center;gap:.75rem;min-width:260px">
                                            @ResourceVisual(resource, "width:56px;height:42px;object-fit:cover;border-radius:6px")
                                            <div style="min-width:0">
                                                <strong style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@ResourceName(resource)</strong>
                                                <div class="text-muted" style="font-size:.8rem;max-width:420px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@ResourceHint(resource)</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@DisplayKind(resource.Kind)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (!_loading && FilteredResourceCount > 0)
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.85rem">
                    @foreach (var resource in PagedResources)
                    {
                        <div class="admin-card @(IsSelected(resource) ? "is-selected" : string.Empty)"
                             style="position:relative;padding:.6rem;text-align:left;border-color:@(IsSelected(resource) ? "#0f2742" : "#d8e0ea");box-shadow:none">
                            @if (CanManageResources)
                            {
                                <input type="checkbox"
                                       checked="@IsBulkSelected(resource)"
                                       disabled="@resource.IsInUse"
                                       title="@BulkSelectTitle(resource)"
                                       style="position:absolute;top:.55rem;right:.55rem;z-index:1"
                                       @onchange="e => ToggleBulkSelected(resource, e)" />
                            }
                            <button type="button"
                                    style="width:100%;border:0;background:transparent;padding:0;text-align:left;cursor:pointer"
                                    @onclick="() => SelectResource(resource)">
                                <span style="display:block;aspect-ratio:4/3;border-radius:8px;overflow:hidden;background:#f8fafc;border:1px solid #e5e7eb;margin-bottom:.55rem">
                                    @ResourceVisual(resource, "width:100%;height:100%;object-fit:cover")
                                </span>
                                <strong style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@ResourceName(resource)</strong>
                                <small class="text-muted" style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                    @ResourceHint(resource)
                                </small>
                            </button>
                        </div>
                    }
                </div>
            }

            @if (TotalPages > 1)
            {
                <div class="admin-pagination" style="margin-top:1rem">
                    <span>@string.Format(T("ShowingRange"), PageStart, PageEnd, FilteredResourceCount)</span>
                    <div class="admin-pagination__buttons">
                        <button class="btn-admin btn-ghost" disabled="@(_page <= 1)" @onclick="PreviousPage">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <span class="btn-admin btn-ghost">@_page / @TotalPages</span>
                        <button class="btn-admin btn-ghost" disabled="@(_page >= TotalPages)" @onclick="NextPage">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        </section>
    </div>
}

@if (CanUploadResources && _showUploadModal)
{
    <div class="modal-backdrop" @onclick="CloseUploadModal">
        <div class="modal-box" style="max-width:min(960px,96vw);width:96vw" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>@T("UploadResources")</span>
                <button class="btn-admin btn-ghost content-icon-btn" @onclick="CloseUploadModal" title="@T("Close")">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.85rem;margin-bottom:1rem">
                    <div>
                        <label>@T("UploadType")</label>
                        <select class="form-control"
                                value="@_uploadKind"
                                disabled="@(_uploadingQueue || _uploadQueue.Any() || IsUploadKindLocked)"
                                @onchange="OnUploadKindChanged">
                            @foreach (var kind in AvailableUploadKinds)
                            {
                                <option value="@kind">@DisplayKind(kind)</option>
                            }
                        </select>
                        <div class="form-hint">@UploadLimitHint</div>
                    </div>
                    <div>
                        <label>@T("Album")</label>
                        <select class="form-control"
                                value="@_uploadAlbumId"
                                disabled="@(_uploadingQueue || _uploadQueue.Any() || IsUploadAlbumLocked)"
                                @onchange="OnUploadAlbumChanged">
                            <option value="">@T("NoAlbum")</option>
                            @foreach (var album in AlbumsForKind(_uploadKind))
                            {
                                <option value="@album.Id">@album.Name</option>
                            }
                        </select>
                        @if (SelectedAlbum is not null)
                        {
                            <div class="form-hint">@T("UploadAlbumPreselectedHint")</div>
                        }
                    </div>
                </div>

                <div style="position:relative;border:2px dashed #cbd5e1;border-radius:10px;background:#f8fafc;padding:1.4rem;min-height:140px;display:grid;place-items:center;text-align:center;margin-bottom:1rem">
                    <InputFile OnChange="QueueUploadFiles"
                               multiple
                               accept="@UploadAcceptForKind(_uploadKind)"
                               disabled="@_uploadingQueue"
                               style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer" />
                    <div style="pointer-events:none">
                        <i class="fas fa-cloud-arrow-up" style="font-size:2rem;color:#0f2742"></i>
                        <strong style="display:block;margin-top:.5rem">@T("DragDropOrSelectFiles")</strong>
                        <span class="text-muted">@string.Format(T("UploadQueueTypeHint"), DisplayKind(_uploadKind))</span>
                    </div>
                </div>

                @if (SelectedAlbum is not null)
                {
                    <div style="border:1px solid #d8e0ea;border-radius:10px;background:#fff;padding:1rem;margin-bottom:1rem">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap;margin-bottom:.75rem">
                            <div>
                                <strong>@T("ChooseExistingResources")</strong>
                                <div class="form-hint">@T("ChooseExistingResourcesHint")</div>
                            </div>
                            <div style="display:flex;gap:.4rem;flex-wrap:wrap">
                                <button type="button"
                                        class="btn-admin btn-ghost"
                                        disabled="@(_albumExistingLoading || !AlbumExistingCandidates.Any())"
                                        @onclick="SelectAllAlbumExistingCandidates">
                                    @T("SelectAllShown")
                                </button>
                                <button type="button"
                                        class="btn-admin btn-ghost"
                                        disabled="@(!_albumExistingSelectedIds.Any())"
                                        @onclick="ClearAlbumExistingSelection">
                                    @T("ClearSelection")
                                </button>
                            </div>
                        </div>

                        <div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;margin-bottom:.75rem">
                            <input class="form-control"
                                   style="flex:1;min-width:220px"
                                   placeholder="@T("SearchResources")"
                                   value="@_albumExistingSearch"
                                   @oninput="OnAlbumExistingSearchChanged" />
                            <button type="button"
                                    class="btn-admin btn-primary"
                                    disabled="@(_albumExistingAssigning || !_albumExistingSelectedIds.Any())"
                                    @onclick="AssignExistingResourcesToAlbum">
                                <i class="fas fa-folder-plus"></i>
                                @(_albumExistingAssigning ? T("Saving") : string.Format(T("AddSelectedToAlbum"), AlbumExistingSelectedCount))
                            </button>
                        </div>

                        @if (_albumExistingLoading)
                        {
                            <p class="text-muted" style="margin:.5rem 0">@T("Loading")</p>
                        }
                        else if (!AlbumExistingCandidates.Any())
                        {
                            <div style="padding:.85rem;border:1px dashed #d8e0ea;border-radius:8px;background:#f8fafc;text-align:center">
                                <span class="text-muted">@T("NoExistingResourcesForAlbum")</span>
                            </div>
                        }
                        else
                        {
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.55rem;max-height:260px;overflow:auto;padding-right:.15rem">
                                @foreach (var resource in AlbumExistingCandidates.Take(80))
                                {
                                    <label @key="resource.Id" style="display:grid;grid-template-columns:auto 42px minmax(0,1fr);gap:.55rem;align-items:center;border:1px solid #e5e7eb;border-radius:8px;background:#f8fafc;padding:.5rem;cursor:pointer">
                                        <input type="checkbox"
                                               checked="@_albumExistingSelectedIds.Contains(resource.Id)"
                                               @onchange="e => ToggleAlbumExistingResource(resource, e)" />
                                        @ResourceVisual(resource, "width:42px;height:38px;object-fit:cover")
                                        <span style="min-width:0">
                                            <strong style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@ResourceName(resource)</strong>
                                            <small class="text-muted" style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@ResourceFileName(resource)</small>
                                        </span>
                                    </label>
                                }
                            </div>
                        }
                    </div>
                }

                <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:.65rem">
                    <strong>@T("UploadQueue")</strong>
                    <span class="text-muted">@string.Format(T("QueuedFileCount"), _uploadQueue.Count)</span>
                </div>

                @if (!_uploadQueue.Any())
                {
                    <div style="padding:1rem;border:1px solid #e5e7eb;border-radius:8px;background:#fff;text-align:center">
                        <span class="text-muted">@T("QueueEmpty")</span>
                    </div>
                }
                else
                {
                    <div style="display:grid;gap:.55rem;max-height:42vh;overflow:auto;padding-right:.15rem">
                        @foreach (var item in _uploadQueue)
                        {
                            <div @key="item.Id" style="display:grid;grid-template-columns:48px minmax(150px,1.2fr) minmax(160px,1fr) minmax(110px,.65fr) auto;gap:.65rem;align-items:center;border:1px solid #e5e7eb;border-radius:8px;background:#fff;padding:.55rem">
                                <span style="width:48px;height:42px;border-radius:7px;background:#fff7e6;color:#0f2742;display:inline-flex;align-items:center;justify-content:center">
                                    <i class="fas @UploadQueueIconClass(item)"></i>
                                </span>
                                <div style="min-width:0">
                                    <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@item.OriginalFileName">@item.OriginalFileName</div>
                                    <small class="text-muted">@FormatBytes(item.File.Size)</small>
                                </div>
                                <input class="form-control"
                                       value="@item.ResourceName"
                                       disabled="@(_uploadingQueue || item.IsComplete)"
                                       @oninput="e => item.ResourceName = e.Value?.ToString() ?? string.Empty" />
                                <div>
                                    <span style="@UploadQueueStatusStyle(item)">@UploadQueueStatusText(item)</span>
                                    @if (!string.IsNullOrWhiteSpace(item.Error))
                                    {
                                        <small style="display:block;color:#b91c1c;margin-top:.25rem">@item.Error</small>
                                    }
                                </div>
                                <div style="display:flex;gap:.35rem;justify-content:flex-end">
                                    @if (item.IsFailed)
                                    {
                                        <button type="button"
                                                class="btn-admin btn-ghost content-icon-btn"
                                                title="@T("Retry")"
                                                disabled="@_uploadingQueue"
                                                @onclick="() => RetryUpload(item)">
                                            <i class="fas fa-rotate"></i>
                                        </button>
                                    }
                                    <button type="button"
                                            class="btn-admin btn-ghost content-icon-btn"
                                            title="@T("Remove")"
                                            disabled="@_uploadingQueue"
                                            @onclick="() => RemoveUploadQueueItem(item)">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-admin btn-ghost" disabled="@_uploadingQueue" @onclick="CloseUploadModal">@T("Close")</button>
                <button class="btn-admin btn-ghost" disabled="@(_uploadingQueue || !_uploadQueue.Any(i => i.IsComplete))" @onclick="ClearCompletedUploads">
                    @T("ClearCompleted")
                </button>
                <button class="btn-admin btn-primary" disabled="@(_uploadingQueue || !UploadableQueueItems.Any())" @onclick="UploadQueuedResources">
                    <i class="fas fa-upload"></i> @(_uploadingQueue ? T("Uploading") : T("UploadSelectedFiles"))
                </button>
            </div>
        </div>
    </div>
}

@if (CanManageResources && _showEditor)
{
    <div class="modal-backdrop" @onclick="CloseEditor">
        <div class="modal-box" style="max-width:720px" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>@T(_editingId is null ? "NewResource" : "EditResource")</span>
                <button class="btn-admin btn-ghost content-icon-btn" @onclick="CloseEditor" title="@T("Close")">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
