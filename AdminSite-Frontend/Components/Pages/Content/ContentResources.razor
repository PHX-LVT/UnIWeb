    private Task QueueUploadFiles(InputFileChangeEventArgs e)
    {
        if (!EnsureCanUploadResources()) return Task.CompletedTask;

        IReadOnlyList<IBrowserFile> files;
        try
        {
            files = e.GetMultipleFiles(MaxQueuedFiles);
        }
        catch (InvalidOperationException)
        {
            Http.Toast(string.Format(T("TooManyQueuedFiles"), MaxQueuedFiles), 422);
            return Task.CompletedTask;
        }

        foreach (var file in files)
        {
            var item = new ResourceUploadQueueItem
            {
                File = file,
                OriginalFileName = file.Name,
                ResourceName = DefaultResourceName(file.Name)
            };

            var validationError = ValidateQueuedFile(file, _uploadKind);
            if (!string.IsNullOrWhiteSpace(validationError))
            {
                item.Status = UploadQueueStatus.Blocked;
                item.Error = validationError;
            }

            _uploadQueue.Add(item);
        }

        return Task.CompletedTask;
    }

    private async Task UploadQueuedResources()
    {
        if (!EnsureCanUploadResources()) return;

        var items = UploadableQueueItems;
        if (items.Count == 0)
        {
            Http.Toast(T("NoQueuedFiles"), 422);
            return;
        }

        await UploadQueueItemsAsync(items);
    }

    private async Task RetryUpload(ResourceUploadQueueItem item)
    {
        if (_uploadingQueue || item.IsComplete) return;

        item.Status = UploadQueueStatus.Queued;
        item.Error = ValidateQueuedFile(item.File, _uploadKind);
        if (!string.IsNullOrWhiteSpace(item.Error))
        {
            item.Status = UploadQueueStatus.Blocked;
            return;
        }

        await UploadQueueItemsAsync([item]);
    }

    private async Task UploadQueueItemsAsync(List<ResourceUploadQueueItem> items)
    {
        if (items.Count == 0) return;

        _uploadingQueue = true;
        foreach (var item in items)
        {
            item.Status = UploadQueueStatus.Uploading;
            item.Error = null;
        }

        try
        {
            var files = items.Select(item => item.File).ToList();
            var names = items.Select(CleanQueueResourceName).ToList();
            var res = await ContentService.UploadResourcesAsync(files, _uploadKind, EmptyToNull(_uploadAlbumId), names);
            Http.Toast(res.Message, res.StatusCode);

            if (!res.Success || res.Data is null)
            {
                foreach (var item in items)
                {
                    item.Status = UploadQueueStatus.Failed;
                    item.Error = string.IsNullOrWhiteSpace(res.Message) ? T("UploadFailed") : res.Message;
                }
                return;
            }

            foreach (var result in res.Data.Results)
            {
                var item = items.ElementAtOrDefault(result.Index);
                if (item is null) continue;

                if (result.Success && result.Resource is not null)
                {
                    item.Status = UploadQueueStatus.Done;
                    item.Error = null;
                    item.Resource = result.Resource;
                    continue;
                }

                item.Status = UploadQueueStatus.Failed;
                item.Error = string.IsNullOrWhiteSpace(result.Error) ? T("UploadFailed") : result.Error;
            }

            await LoadAlbums();
            await LoadResources();

            var lastUploadedId = res.Data.Results
                .LastOrDefault(result => result.Success && result.Resource is not null)
                ?.Resource
                ?.Id;
            if (!string.IsNullOrWhiteSpace(lastUploadedId))
                _selectedResource = _resources.FirstOrDefault(r => r.Id == lastUploadedId) ?? _selectedResource;
        }
        finally
        {
            _uploadingQueue = false;
        }
    }

    private void RemoveUploadQueueItem(ResourceUploadQueueItem item)
