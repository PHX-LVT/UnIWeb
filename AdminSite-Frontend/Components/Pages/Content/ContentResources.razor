@code {
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private const int PageSize = 30;
    private const int MaxQueuedFiles = 200;
    private const long MaxImageUploadBytes = 20L * 1024 * 1024;
    private const long MaxFileUploadBytes = 100L * 1024 * 1024;
    private const long MaxVideoUploadBytes = 250L * 1024 * 1024;

    private List<string> _languages = new() { "en" };
    private List<ManagedResourceModel> _resources = new();
    private List<ResourceAlbumModel> _albums = new();
    private ManagedResourceModel? _selectedResource;
    private ManagedResourceRequest _edit = new();
    private string? _editingId;
    private string _search = string.Empty;
    private string _kindFilter = string.Empty;
    private string _libraryMode = "resources";
    private string? _selectedAlbumId;
    private string _viewMode = "grid";
    private int _page = 1;
    private bool _loading = true;
    private bool _albumLoading;
    private bool _showUploadModal;
    private bool _showEditor;
    private bool _showAlbumEditor;
    private bool _showBulkDelete;
    private string _uploadKind = "image";
    private string _uploadAlbumId = string.Empty;
    private bool _uploadingQueue;
    private readonly List<ResourceUploadQueueItem> _uploadQueue = new();
    private readonly List<ManagedResourceModel> _albumExistingResources = new();
    private readonly HashSet<string> _albumExistingSelectedIds = new(StringComparer.OrdinalIgnoreCase);
    private string _albumExistingSearch = string.Empty;
    private bool _albumExistingLoading;
    private bool _albumExistingAssigning;
    private ManagedResourceModel? _previewResource;
    private ManagedResourceModel? _deleteResource;
    private ResourceAlbumModel? _deleteAlbum;
    private ResourceAlbumModel? _editingAlbum;
    private ResourceAlbumRequest _albumEdit = new();
    private List<string> _deleteAlbumResourceNames = new();
    private ManagedResourceUsageModel? _deleteUsage;
    private bool _deleteLoading;
    private bool _deleteAlbumLoading;
    private bool _bulkDeleteLoading;
    private bool _replaceUploading;
    private readonly List<AdminUserResponse> _adminUsers = new();
    private readonly HashSet<string> _selectedResourceIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, ManagedResourceUsageModel> _usageByResourceId = new(StringComparer.OrdinalIgnoreCase);
    private string? _usageLoadingResourceId;

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);
    private string CurrentLang => NormalizeLang(AdminLanguage);
    private bool CanViewResourceLibrary => Auth.CanManageAllContent || Auth.IsWriter;
    private bool CanUploadResources => Auth.CanManageAllContent || Auth.IsWriter;
    private bool CanManageResources => Auth.CanManageAllContent;

    private bool IsAlbumMode => string.Equals(_libraryMode, "albums", StringComparison.OrdinalIgnoreCase);
    private bool ShowingAlbumRoot => IsAlbumMode && string.IsNullOrWhiteSpace(_selectedAlbumId);
    private ResourceAlbumModel? SelectedAlbum =>
        string.IsNullOrWhiteSpace(_selectedAlbumId)
            ? null
            : _albums.FirstOrDefault(a => string.Equals(a.Id, _selectedAlbumId, StringComparison.OrdinalIgnoreCase));
    private string? ActiveAlbumId => IsAlbumMode ? _selectedAlbumId : null;
    private IEnumerable<ManagedResourceModel> FilteredResources => _resources;
    private IEnumerable<ResourceAlbumModel> FilteredAlbums => _albums.Where(MatchesAlbumFilters);
    private int FilteredResourceCount => FilteredResources.Count();
    private int FilteredAlbumCount => FilteredAlbums.Count();
    private int VisibleItemCount => ShowingAlbumRoot ? FilteredAlbumCount : FilteredResourceCount;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(VisibleItemCount / (double)PageSize));
    private int PageStart => VisibleItemCount == 0 ? 0 : ((_page - 1) * PageSize) + 1;
    private int PageEnd => Math.Min(VisibleItemCount, _page * PageSize);
    private IEnumerable<ManagedResourceModel> PagedResources => FilteredResources.Skip((_page - 1) * PageSize).Take(PageSize);
    private IEnumerable<ResourceAlbumModel> PagedAlbums => FilteredAlbums.Skip((_page - 1) * PageSize).Take(PageSize);
    private IEnumerable<ManagedResourceModel> DeletablePagedResources => PagedResources.Where(r => !r.IsInUse);
    private List<ManagedResourceModel> BulkDeleteResources =>
        CanManageResources
            ? _resources.Where(r => _selectedResourceIds.Contains(r.Id) && !r.IsInUse).ToList()
            : new();
    private int SelectedBlockedCount =>
        CanManageResources
            ? _resources.Count(r => _selectedResourceIds.Contains(r.Id) && r.IsInUse)
            : 0;
    private bool AllPagedBulkSelected =>
        CanManageResources &&
        DeletablePagedResources.Any() &&
        DeletablePagedResources.All(r => _selectedResourceIds.Contains(r.Id));
    private ManagedResourceUsageModel? SelectedUsage =>
        _selectedResource is null ? null : _usageByResourceId.GetValueOrDefault(_selectedResource.Id);
    private string UploadAccept => NormalizeKind(_edit.Kind) switch
    {
        "image" => "image/jpeg,image/png,image/webp,image/gif,.jpg,.jpeg,.png,.webp,.gif",
        "video" => "video/mp4,video/webm,video/quicktime,.mp4,.webm,.mov",
        _ => ".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation"
    };
    private List<ResourceUploadQueueItem> UploadableQueueItems =>
        _uploadQueue.Where(item => item.CanUpload).ToList();
    private IEnumerable<ManagedResourceModel> AlbumExistingCandidates =>
        _albumExistingResources
            .Where(CanAssignExistingResourceToSelectedAlbum)
            .Where(MatchesAlbumExistingSearch)
            .OrderBy(ResourceName, StringComparer.OrdinalIgnoreCase);
    private int AlbumExistingSelectedCount =>
        AlbumExistingCandidates.Count(resource => _albumExistingSelectedIds.Contains(resource.Id));
    private ResourceAlbumModel? UploadAlbum =>
        string.IsNullOrWhiteSpace(_uploadAlbumId)
            ? null
            : _albums.FirstOrDefault(a => string.Equals(a.Id, _uploadAlbumId, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<string> AvailableUploadKinds
    {
        get
        {
            var album = SelectedAlbum ?? UploadAlbum;
            if (album is not null)
                return NormalizeAlbumScope(album.Scope) == "file"
                    ? ["file"]
                    : ["image", "video"];

            return ["image", "video", "file"];
        }
    }
    private bool IsUploadKindLocked => AvailableUploadKinds.Count() == 1;
    private bool IsUploadAlbumLocked => SelectedAlbum is not null;
    private string UploadLimitHint =>
        _uploadKind switch
        {
            "image" => string.Format(T("UploadMaxHint"), FormatBytes(MaxImageUploadBytes)),
            "video" => string.Format(T("UploadMaxHint"), FormatBytes(MaxVideoUploadBytes)),
            _ => string.Format(T("UploadMaxHint"), FormatBytes(MaxFileUploadBytes))
        };
    private bool IsSaveDisabled =>
        _editingId is null &&
        string.IsNullOrWhiteSpace(_edit.StorageKey);

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Auth.RefreshSessionAsync();
        await AdminLanguageState.LoadSettingsAsync();
        _languages = AdminLanguageState.SupportedLanguages.ToList();
        _edit = NewRequest();
        if (!CanViewResourceLibrary)
        {
            _loading = false;
            return;
        }

        await LoadAdminUsers();
        await LoadAlbums();
        await LoadResources();
    }

    private async Task LoadAdminUsers()
    {
        _adminUsers.Clear();
        if (!Auth.CanManageUsers) return;

        var res = await Users.GetUsersAsync();
        if (res.Success && res.Data is not null)
            _adminUsers.AddRange(res.Data);
    }

    private async Task LoadResources()
    {
        if (!CanViewResourceLibrary)
        {
            _resources = new();
            _selectedResource = null;
            _loading = false;
            return;
        }

        _loading = true;
        var previousSelectedId = _selectedResource?.Id;
        var res = await ContentService.GetResourcesAsync(_kindFilter, _search, includeInactive: true, albumId: ActiveAlbumId);
        _resources = res.Data ?? new();
        PruneSelection();
        ClampPage();
        _selectedResource = FilteredResources.FirstOrDefault(r => r.Id == previousSelectedId)
            ?? PagedResources.FirstOrDefault()
