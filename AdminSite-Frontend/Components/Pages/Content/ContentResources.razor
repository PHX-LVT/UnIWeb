@if (CanManageResources && _deleteResource is not null)
{
    <div class="modal-backdrop" @onclick="CancelDeleteResource">
        <div class="modal-card" style="max-width:560px" @onclick:stopPropagation="true">
            <div class="modal-header">@T("DeleteResource")</div>
            <div style="padding:1rem">
                <p style="margin-top:0">
                    @string.Format(T("DeleteResourcePrompt"), GetValue(_deleteResource.Name, CurrentLang, fallback: true))
                </p>
                @if (_deleteLoading)
                {
                    <p class="text-muted">@T("UsageLoading")</p>
                }
                else if ((_deleteUsage?.UsageCount ?? 0) > 0)
                {
                    <div class="alert alert-warning" style="margin-bottom:.75rem">
                        @string.Format(T("UsageUsedInPlaces"), _deleteUsage!.UsageCount, _deleteUsage.UsageCount == 1 ? string.Empty : "s")
                    </div>
                    <ul style="margin:.5rem 0 0;padding-left:1.2rem">
                        @foreach (var reference in _deleteUsage!.References.Take(6))
                        {
                            <li>@UsageReferenceText(reference)</li>
                        }
                    </ul>
                    @if (_deleteUsage.References.Count > 6)
                    {
                        <div class="text-muted" style="font-size:.85rem;margin-top:.5rem">
                            @string.Format(T("MoreCount"), _deleteUsage.References.Count - 6)
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">@T("NotUsedAnywhereSafeToDelete")</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-admin btn-ghost" @onclick="CancelDeleteResource">@T("Cancel")</button>
                <button class="btn-admin btn-danger"
                        disabled="@(_deleteLoading || (_deleteUsage?.UsageCount ?? 0) > 0)"
                        @onclick="ConfirmDeleteResource">
                    @T("Delete")
                </button>
            </div>
        </div>
    </div>
}

@if (CanManageResources && _showBulkDelete)
