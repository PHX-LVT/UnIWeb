@page "/users/audit"
@inject AdminUserService Users
@inject AdminAuthService Auth
@inject IHttpService Http

<div class="page-header">
    <h1 class="page-title"><i class="fas fa-clipboard-list"></i> @T("AuditLogs")</h1>
    @if (Auth.IsAdminAdmin && _logs.Any())
    {
        <button class="btn-admin btn-danger"
                disabled="@(!_selectedAuditIds.Any() || _deleting)"
                @onclick="DeleteSelectedAuditLogs">
            <i class="fas fa-trash"></i> @T("DeleteSelectedLogs")
        </button>
    }
</div>

<div class="admin-card">
    @if (!Auth.CanViewLogs)
    {
        <p class="text-muted">@T("NoPermission")</p>
    }
    else if (_loading)
    {
        <p class="text-muted">@T("Loading")</p>
    }
    else if (!_logs.Any())
    {
        <p class="text-muted">@T("NoAuditLogs")</p>
    }
    else
    {
        <div style="overflow:auto">
            <table class="table" style="width:100%">
                <thead>
                    <tr>
                        @if (Auth.IsAdminAdmin)
                        {
                            <th style="width:42px">
                                <input type="checkbox" checked="@AllAuditLogsSelected" @onchange="ToggleAllAuditLogs" />
                            </th>
                        }
                        <th>@T("Time")</th>
                        <th>@T("Area")</th>
                        <th>@T("Action")</th>
                        <th>@T("Actor")</th>
                        <th>@T("Target")</th>
                        <th>@T("Message")</th>
                        <th>@T("IpAddress")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _logs)
                    {
                        <tr>
                            @if (Auth.IsAdminAdmin)
                            {
                                <td>
                                    <input type="checkbox"
                                           checked="@_selectedAuditIds.Contains(item.Id)"
                                           @onchange="e => ToggleAuditLog(item.Id, e)" />
                                </td>
                            }
                            <td>@FormatDate(item.CreatedAt)</td>
                            <td><span class="content-type-badge">@item.Area</span></td>
                            <td>@item.Action</td>
                            <td>@item.ActorEmail</td>
                            <td>@(string.IsNullOrWhiteSpace(item.TargetEmail) ? "-" : item.TargetEmail)</td>
                            <td>@item.Message</td>
                            <td>@item.IpAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="admin-pagination">
            <span class="text-muted">@ShowingText</span>
            <div class="admin-pagination__buttons">
                <button class="btn-admin btn-ghost" disabled="@(_page <= 1)" @onclick="() => SetPage(_page - 1)" aria-label="Previous page">&lsaquo;</button>
                @foreach (var page in VisiblePages)
                {
                    var pageNumber = page;
                    <button class="btn-admin @(_page == pageNumber ? "btn-primary" : "btn-ghost")" @onclick="() => SetPage(pageNumber)">@pageNumber</button>
                }
                <button class="btn-admin btn-ghost" disabled="@(_page >= _totalPages)" @onclick="() => SetPage(_page + 1)" aria-label="Next page">&rsaquo;</button>
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter(Name = "AdminLanguage")] public string AdminLanguage { get; set; } = "en";

    private readonly List<AdminAuditLogResponse> _logs = new();
    private readonly HashSet<string> _selectedAuditIds = new(StringComparer.OrdinalIgnoreCase);
    private bool _loading = true;
    private bool _deleting;
    private const int PageSize = 20;
    private int _page = 1;
    private int _totalPages = 1;
    private long _totalCount;

    private bool AllAuditLogsSelected =>
        _logs.Any() && _logs.All(item => _selectedAuditIds.Contains(item.Id));

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Auth.RefreshSessionAsync();

        if (Auth.CanViewLogs)
        {
            await LoadAsync();
        }

        _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var res = await Users.GetAuditLogsAsync(_page, PageSize);
        if (res.Success && res.Data is not null)
        {
            _logs.Clear();
            _logs.AddRange(res.Data.Items);
            _page = res.Data.Page;
            _totalPages = res.Data.TotalPages;
            _totalCount = res.Data.TotalCount;
            _selectedAuditIds.RemoveWhere(id => _logs.All(item => item.Id != id));
        }
        else
        {
            Http.Toast(res.Message, res.StatusCode);
        }
        _loading = false;
    }

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var start = Math.Max(1, _page - 2);
            var end = Math.Min(_totalPages, start + 4);
            start = Math.Max(1, end - 4);
            return Enumerable.Range(start, end - start + 1);
        }
    }

    private string ShowingText
    {
        get
        {
            if (_totalCount == 0) return string.Format(T("ShowingRange"), 0, 0, 0);
            var start = ((_page - 1) * PageSize) + 1;
            var end = Math.Min(start + _logs.Count - 1, _totalCount);
            return string.Format(T("ShowingRange"), start, end, _totalCount);
        }
    }

    private async Task SetPage(int page)
    {
        var next = Math.Clamp(page, 1, _totalPages);
        if (next == _page) return;
        _page = next;
        _selectedAuditIds.Clear();
        await LoadAsync();
    }

    private void ToggleAuditLog(string id, ChangeEventArgs e)
    {
        var selected = e.Value is bool value && value;
        if (selected)
            _selectedAuditIds.Add(id);
        else
            _selectedAuditIds.Remove(id);
    }

    private void ToggleAllAuditLogs(ChangeEventArgs e)
    {
        var selected = e.Value is bool value && value;
        _selectedAuditIds.Clear();
        if (selected)
        {
            foreach (var item in _logs)
                _selectedAuditIds.Add(item.Id);
        }
    }

    private async Task DeleteSelectedAuditLogs()
    {
        if (!_selectedAuditIds.Any()) return;

        _deleting = true;
        var res = await Users.DeleteAuditLogsAsync(_selectedAuditIds);
        Http.Toast(res.Message, res.StatusCode);
        _deleting = false;
        if (!res.Success) return;

        _selectedAuditIds.Clear();
        await LoadAsync();
    }

    private string T(string key) => AdminUiLocalizer.T(key, AdminLanguage);

    private static string FormatDate(DateTime value) =>
        value.ToLocalTime().ToString("dd MMM yyyy HH:mm");
}
