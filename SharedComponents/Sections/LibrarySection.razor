@using Contracts.Public
@using SharedComponents.Helpers
@using SharedComponents.Blocks
@inject NavigationManager Navigation

<section data-section-id="@Section.Id"
         class="@StyleHelper.GetSectionClass(Section.Style)"
         style="@StyleHelper.GetSectionStyle(Section.Style)">
    <div class="sc-section-overlay"
         style="@StyleHelper.GetOverlayStyle(Section.Style)"></div>

    <div style="position: relative; z-index: 1" class="sc-library sc-library--@LayoutClass">
        @{
            var eyebrow = StyleHelper.Lang(Section.Eyebrow, Lang);
            var title = StyleHelper.Lang(Section.SectionTitle, Lang);
            var subheading = StyleHelper.Lang(Section.Subheading, Lang);
            var pageItems = VisibleItems.ToList();
        }
        @if (!string.IsNullOrWhiteSpace(eyebrow) || !string.IsNullOrWhiteSpace(title) || !string.IsNullOrWhiteSpace(subheading))
        {
            <div class="sc-library__header">
                @if (!string.IsNullOrWhiteSpace(eyebrow))
                {
                    <div class="sc-library__eyebrow">@eyebrow</div>
                }
                @if (!string.IsNullOrWhiteSpace(title))
                {
                    <h2 class="sc-library__title">@title</h2>
                }
                @if (!string.IsNullOrWhiteSpace(subheading))
                {
                    <p class="sc-library__subheading">@subheading</p>
                }
            </div>
        }

        @if (TabsEnabled)
        {
            <div class="sc-library__tabs" role="tablist" aria-label="Library content types">
                @foreach (var tab in SourceTypes)
                {
                    <button type="button"
                            role="tab"
                            class="@TabClass(tab)"
                            aria-selected="@string.Equals(_activeTab, tab, StringComparison.OrdinalIgnoreCase)"
                            @onclick="() => SetActiveTab(tab)">
                        @TypeLabel(tab)
                    </button>
                }
            </div>
        }

        @if (Section.ShowSearchBar == true || Section.ShowFilters == true)
        {
            <div class="@ControlsClass">
                @if (Section.ShowFilters == true && FilterOptions.Any())
                {
                    <select class="sc-library__filter-select" value="@_filter" @onchange="OnFilterChanged" aria-label="Filter library items">
                        <option value="">All Types</option>
                        @foreach (var option in FilterOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </select>
                }
                @if (Section.ShowFilters == true && YearOptions.Any())
                {
                    <select class="sc-library__filter-select" value="@_yearFilter" @onchange="OnYearFilterChanged" aria-label="Filter library items by year">
                        <option value="">All Years</option>
                        @foreach (var year in YearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                }
                @if (Section.ShowSearchBar == true)
                {
                    <input type="text"
                           class="sc-library__search-input"
                           placeholder="@SearchPlaceholder"
                           @bind="_search" @bind:event="oninput" />
                }
            </div>
        }

        <div class="@ItemsClass(pageItems.Count)">
            @foreach (var item in pageItems)
            {
                var galleryItems = GalleryMediaItems(item).ToList();
                var primaryGalleryItem = galleryItems.FirstOrDefault();
                if (LayoutClass == "lists")
                {
                    <article @key="item.Id" class="sc-library__item">
                        <div class="sc-library__list-main">
                            @if (ShowTime)
                            {
                                <span class="sc-library__meta">@ItemDate(item)</span>
                            }
                            <h3 class="sc-library__item-title">
                                @ItemTitle(item)
                            </h3>
                        </div>
                        @if (Section.ShowButton != false)
                        {
                            @if (IsGallery(item) && primaryGalleryItem is not null)
                            {
                                @if (GalleryItemIsVideo(primaryGalleryItem))
                                {
                                    <button type="button"
                                            class="@ButtonClass"
                                            data-sc-library-video
                                            data-video-url="@GalleryItemUrl(primaryGalleryItem)"
                                            data-video-title="@GalleryItemTitle(primaryGalleryItem, item)">
                                        @ButtonText(item)
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="@ButtonClass"
                                            data-sc-library-image
                                            data-image-url="@GalleryItemUrl(primaryGalleryItem)"
                                            data-image-title="@GalleryItemTitle(primaryGalleryItem, item)">
                                        @ButtonText(item)
                                    </button>
                                }
                            }
                            else if (IsVideo(item))
                            {
                                <button type="button"
                                        class="@ButtonClass"
                                        data-sc-library-video
                                        data-video-url="@ItemHref(item)"
                                        data-video-title="@ItemTitle(item)">
                                    @ButtonText(item)
                                </button>
                            }
                            else if (CanOpenImageLightbox(item))
                            {
                                <button type="button"
                                        class="@ButtonClass"
                                        data-sc-library-image
                                        data-image-url="@ImageUrl(item)"
                                        data-image-title="@ItemTitle(item)">
                                    @ButtonText(item)
                                </button>
                            }
                            else
                            {
                                <a class="@ButtonClass"
                                   href="@ItemHref(item)"
                                   target="@Target(item)"
                                   rel="@Rel(item)"
                                   data-sc-download="@DownloadMetricFlag(item)">
                                    @ButtonText(item)
                                </a>
                            }
                        }
                    </article>
                }
                else
                {
                    var tag = ItemTag(item);
                    var isVideo = IsVideo(item);
                    var isGallery = IsGallery(item);
                    var imageUrl = ImageUrl(item);
                    var canOpenImage = CanOpenImageLightbox(item);
                    var summary = StyleHelper.Lang(item.Summary, Lang);
                    <article @key="item.Id" class="sc-library__item">
                        @if (ShowTag && !string.IsNullOrWhiteSpace(tag))
                        {
                            <span class="sc-library__tag">@tag</span>
                        }
                        @if (CanShowImage && ((isGallery && galleryItems.Count > 0) || !string.IsNullOrWhiteSpace(imageUrl)))
                        {
                            if (isGallery && galleryItems.Count > 0)
                            {
                                <div class="sc-library__media sc-library__media--gallery-strip" aria-label="@($"{ItemTitle(item)} gallery")">
                                    <div class="sc-library__gallery-strip">
                                        @foreach (var galleryItem in galleryItems)
                                        {
                                            var mediaUrl = GalleryItemUrl(galleryItem);
                                            var mediaTitle = GalleryItemTitle(galleryItem, item);
                                            var thumbUrl = GalleryItemThumbnailUrl(galleryItem);

                                            @if (GalleryItemIsVideo(galleryItem))
                                            {
                                                <button type="button"
                                                        class="sc-library__gallery-tile sc-library__gallery-tile--video"
                                                        data-sc-library-video
                                                        data-video-url="@mediaUrl"
                                                        data-video-title="@mediaTitle"
                                                        aria-label="Watch @mediaTitle">
                                                    @if (!string.IsNullOrWhiteSpace(thumbUrl))
                                                    {
                                                        <img src="@thumbUrl" alt="@mediaTitle" />
                                                    }
                                                    else
                                                    {
                                                        <span class="sc-library__gallery-placeholder">Video</span>
                                                    }
                                                    <span class="sc-library__play" aria-hidden="true"></span>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="sc-library__gallery-tile"
                                                        data-sc-library-image
                                                        data-image-url="@mediaUrl"
                                                        data-image-title="@mediaTitle"
                                                        aria-label="View @mediaTitle">
                                                    @if (!string.IsNullOrWhiteSpace(thumbUrl))
                                                    {
                                                        <img src="@thumbUrl" alt="@mediaTitle" />
                                                    }
                                                    else
                                                    {
                                                        <span class="sc-library__gallery-placeholder">Image</span>
                                                    }
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                            else if (isVideo)
                            {
                                <button type="button"
                                        class="sc-library__media sc-library__media--video"
                                        data-sc-library-video
                                        data-video-url="@ItemHref(item)"
                                        data-video-title="@ItemTitle(item)"
                                        aria-label="Watch @ItemTitle(item)">
                                    <img src="@imageUrl" alt="@ItemTitle(item)" />
                                    <span class="sc-library__play" aria-hidden="true"></span>
                                </button>
                            }
                            else if (canOpenImage)
                            {
                                <button type="button"
                                        class="sc-library__media sc-library__media--image"
                                        data-sc-library-image
                                        data-image-url="@imageUrl"
                                        data-image-title="@ItemTitle(item)">
                                    <img src="@imageUrl" alt="@ItemTitle(item)" />
                                </button>
                            }
                            else
                            {
                                <div class="sc-library__media">
                                    <img src="@imageUrl" alt="@ItemTitle(item)" />
                                </div>
                            }
                        }
                        else if (CanShowImage)
                        {
                            if (isVideo)
                            {
                                <button type="button"
                                        class="sc-library__media sc-library__media--placeholder sc-library__media--video"
                                        data-sc-library-video
                                        data-video-url="@ItemHref(item)"
                                        data-video-title="@ItemTitle(item)"
                                        aria-label="Watch @ItemTitle(item)">
                                    <span>@PlaceholderLabel(item)</span>
                                    <span class="sc-library__play" aria-hidden="true"></span>
                                </button>
                            }
                            else
                            {
                                <div class="sc-library__media sc-library__media--placeholder" aria-label="@ItemTitle(item)">
                                    <span>@PlaceholderLabel(item)</span>
                                </div>
                            }
                        }
                        <div class="sc-library__body">
                            @if (ShowTagInBody && !string.IsNullOrWhiteSpace(tag))
                            {
                                <span class="sc-library__tag">@tag</span>
                            }
                            @if (ShowTime)
                            {
                                <div class="sc-library__meta">
                                    <span>@ItemDate(item)</span>
                                </div>
                            }
                            <h3 class="sc-library__item-title">
                                @ItemTitle(item)
                            </h3>
                            @if (Section.ShowSummary != false && LayoutClass != "lists" && !string.IsNullOrWhiteSpace(summary))
                            {
                                <p class="sc-library__summary">@summary</p>
                            }
                            @if (Section.ShowButton != false)
                            {
                                @if (isGallery && primaryGalleryItem is not null)
                                {
                                    @if (GalleryItemIsVideo(primaryGalleryItem))
                                    {
                                        <button type="button"
                                                class="sc-library__link sc-btn sc-btn--filled"
                                                data-sc-library-video
                                                data-video-url="@GalleryItemUrl(primaryGalleryItem)"
                                                data-video-title="@GalleryItemTitle(primaryGalleryItem, item)">
                                            @ButtonText(item)
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="@ButtonClass"
                                                data-sc-library-image
                                                data-image-url="@GalleryItemUrl(primaryGalleryItem)"
                                                data-image-title="@GalleryItemTitle(primaryGalleryItem, item)">
                                            @ButtonText(item)
                                        </button>
                                    }
                                }
                                else if (isVideo)
                                {
                                    <button type="button"
                                            class="sc-library__link sc-btn sc-btn--filled"
                                            data-sc-library-video
                                            data-video-url="@ItemHref(item)"
                                            data-video-title="@ItemTitle(item)">
                                        @ButtonText(item)
                                    </button>
                                }
                                else if (CanOpenImageLightbox(item))
                            {
                                <button type="button"
                                        class="@ButtonClass"
                                        data-sc-library-image
                                        data-image-url="@ImageUrl(item)"
                                        data-image-title="@ItemTitle(item)">
                                    @ButtonText(item)
                                </button>
                            }
                            else
                            {
                                <a class="@ButtonClass"
                                   href="@ItemHref(item)"
                                   target="@Target(item)"
                                   rel="@Rel(item)"
                                   data-sc-download="@DownloadMetricFlag(item)">
                                    @ButtonText(item)
                                </a>
                            }
                            }
                        </div>
                    </article>
                }
            }
        </div>

        @if (PaginationEnabled && TotalPages > 1)
        {
            <div class="sc-library__pagination" aria-label="Library pagination">
                <button type="button" class="sc-library__page-button" disabled="@(_page <= 1)" @onclick="PreviousPage">Prev</button>
                @for (var page = 1; page <= TotalPages; page++)
                {
                    var pageNumber = page;
                    <button type="button" class="@PageButtonClass(pageNumber)" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                }
                <button type="button" class="sc-library__page-button" disabled="@(_page >= TotalPages)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>

    <SectionBlocks Blocks="Section.Blocks" SectionId="@Section.Id" Style="Section.Style" Lang="@Lang" ShowInvisible="@ShowInvisible" OnSubmit="OnSubmit" />
</section>

@code {
    [Parameter, EditorRequired] public PublicLibrarySectionDto Section { get; set; } = default!;
    [Parameter] public string Lang { get; set; } = "en";
    [Parameter] public bool ShowInvisible { get; set; }
    [Parameter] public Func<string, Dictionary<string, string>, Task<bool>>? OnSubmit { get; set; }

    private string _search = string.Empty;
    private string _filter = string.Empty;
    private string _yearFilter = string.Empty;
    private string _activeTab = string.Empty;
    private int _page = 1;

    protected override void OnParametersSet()
    {
        var requestedType = RequestedContentType();

        if (TabsEnabled && !SourceTypes.Contains(_activeTab, StringComparer.OrdinalIgnoreCase))
            _activeTab = SourceTypes.Contains(requestedType, StringComparer.OrdinalIgnoreCase)
                ? requestedType
                : SourceTypes.FirstOrDefault() ?? string.Empty;

        if (TabsEnabled && SourceTypes.Contains(requestedType, StringComparer.OrdinalIgnoreCase))
            _activeTab = requestedType;

        if (!TabsEnabled)
            _activeTab = string.Empty;

        ClampPage();
    }

    private string LayoutClass => NormalizeLayout(Section.Layout);
    private int Columns => LayoutClass == "rows"
        ? Math.Clamp(Section.Columns ?? 2, 1, 2)
        : Math.Clamp(Section.Columns ?? 3, 1, 6);
    private int Rows => Math.Clamp(Section.Rows ?? 3, 1, 12);
    private int Limit => Math.Clamp(Section.Limit ?? 6, 1, 24);
    private bool TabsEnabled => Section.EnableTabs == true && SourceTypes.Count > 1;
    private bool PaginationEnabled => Section.EnablePagination == true;
    private bool ShowTime => Section.ShowTime != false;
    private int ItemsPerPage => Math.Clamp(Columns * Rows, 1, 48);
    private bool CanShowImage => Section.ShowImage != false && LayoutClass is "card" or "grid" or "gallery";
    private bool ShowTag => LayoutClass == "card";
    private bool ShowTagInBody => LayoutClass == "grid";
    private string ButtonClass => $"sc-library__link sc-btn sc-btn--{ButtonStyle}";
    private string ControlsClass =>
        Section.ShowFilters == true && Section.ShowSearchBar == true
            ? "sc-library__controls sc-library__controls--filters-search"
            : "sc-library__controls sc-library__controls--single";
    private string ButtonStyle => Section.ButtonStyle switch
    {
        "outline" => "outline",
        "ghost" => "ghost",
        _ => "filled"
    };

    private string ItemsClass(int itemCount) => LayoutClass switch
    {
        "lists" => "sc-library__items sc-library__disclosure-list",
        "rows" => $"sc-library__items sc-library__rows sc-library__grid--{EffectiveColumns(itemCount)}",
        "grid" => $"sc-library__items sc-library__grid sc-library__resource-grid sc-library__grid--{EffectiveColumns(itemCount)}",
        "gallery" => "sc-library__items sc-library__gallery",
        _ => $"sc-library__items sc-library__grid sc-library__grid--{EffectiveColumns(itemCount)}"
    };

    private int EffectiveColumns(int itemCount) => Math.Clamp(Math.Min(Columns, Math.Max(itemCount, 1)), 1, Columns);

    private List<string> SourceTypes =>
        (Section.ContentTypes ?? new())
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Select(t => t.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

    private IEnumerable<PublicLibraryItemDto> ActiveItems
    {
        get
        {
            var sourceTypes = SourceTypes;
            var activeType = TabsEnabled ? _activeTab : sourceTypes.FirstOrDefault();

            return (Section.Items ?? new())
                .Where(i => string.IsNullOrWhiteSpace(activeType) || string.Equals(i.ContentTypeKey, activeType, StringComparison.OrdinalIgnoreCase));
        }
    }

    private List<string> FilterOptions =>
        ActiveItems
            .SelectMany(i => i.Tags ?? new())
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Select(t => t.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t)
            .ToList();

    private List<string> YearOptions =>
        ActiveItems
            .Select(i => (i.PublishedAt ?? i.UpdatedAt).ToLocalTime().Year.ToString())
            .Where(y => !string.IsNullOrWhiteSpace(y))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(y => y)
            .ToList();

    private IEnumerable<PublicLibraryItemDto> FilteredItems =>
        ActiveItems
            .Where(i => string.IsNullOrWhiteSpace(_filter) || (i.Tags ?? new()).Any(t => string.Equals(t, _filter, StringComparison.OrdinalIgnoreCase)))
            .Where(i => string.IsNullOrWhiteSpace(_yearFilter) || string.Equals((i.PublishedAt ?? i.UpdatedAt).ToLocalTime().Year.ToString(), _yearFilter, StringComparison.OrdinalIgnoreCase))
            .Where(i => string.IsNullOrWhiteSpace(_search) ||
                ItemTitle(i).Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                StyleHelper.Lang(i.Summary, Lang).Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                (i.Tags ?? new()).Any(t => t.Contains(_search, StringComparison.OrdinalIgnoreCase)));

    private IEnumerable<PublicLibraryItemDto> VisibleItems =>
        PaginationEnabled
            ? FilteredItems.Skip((_page - 1) * ItemsPerPage).Take(ItemsPerPage)
            : FilteredItems.Take(Limit);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredItems.Count() / (double)ItemsPerPage));

    private string SearchPlaceholder =>
        StyleHelper.Lang(Section.SearchPlaceholder, Lang) is { Length: > 0 } text ? text : "Search...";

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
        _filter = string.Empty;
        _yearFilter = string.Empty;
        _page = 1;
    }

    private void OnFilterChanged(ChangeEventArgs e)
    {
        _filter = e.Value?.ToString() ?? string.Empty;
        _page = 1;
    }

    private void OnYearFilterChanged(ChangeEventArgs e)
    {
        _yearFilter = e.Value?.ToString() ?? string.Empty;
        _page = 1;
    }

    private void GoToPage(int page)
    {
        _page = Math.Clamp(page, 1, TotalPages);
    }

    private void PreviousPage() => GoToPage(_page - 1);
    private void NextPage() => GoToPage(_page + 1);

    private void ClampPage()
    {
        if (_page > TotalPages)
            _page = TotalPages;
        if (_page < 1)
            _page = 1;
    }

    private string TabClass(string tab) =>
        string.Equals(_activeTab, tab, StringComparison.OrdinalIgnoreCase)
            ? "sc-library__tab sc-library__tab--active"
            : "sc-library__tab";

    private string PageButtonClass(int page) =>
        _page == page
            ? "sc-library__page-button sc-library__page-button--active"
            : "sc-library__page-button";

    private static string NormalizeLayout(string? layout) => layout switch
    {
        "grid" or "resource-grid" => "grid",
        "rows" => "rows",
        "lists" or "compact-list" or "resource-list" => "lists",
        "gallery" or "media-gallery" => "gallery",
        _ => "card"
    };

    private static string ImageUrl(PublicLibraryItemDto item)
    {
        if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl)) return item.ThumbnailUrl!;
        if (!string.IsNullOrWhiteSpace(item.HeroImageUrl)) return item.HeroImageUrl!;

        var galleryImage = GalleryMediaItems(item).FirstOrDefault(i => !GalleryItemIsVideo(i));
        return galleryImage is null ? string.Empty : GalleryItemThumbnailUrl(galleryImage);
    }

    private static string PlaceholderLabel(PublicLibraryItemDto item) =>
        IsGallery(item)
            ? "Gallery"
            : item.ClickBehavior switch
            {
                "download" => "PDF",
                "video" => "Video",
                "image" => "Image",
                _ => "Report"
            };

    private string ItemTitle(PublicLibraryItemDto item) =>
        StyleHelper.Lang(item.Title, Lang) is { Length: > 0 } text ? text : item.Slug;

    private static string ItemTag(PublicLibraryItemDto item) =>
        item.Tags?.FirstOrDefault(t => !string.IsNullOrWhiteSpace(t))?.Trim() ?? string.Empty;

    private static string ItemDate(PublicLibraryItemDto item) =>
        (item.PublishedAt ?? item.UpdatedAt).ToLocalTime().ToString("dd MMM yyyy");

    private string ButtonText(PublicLibraryItemDto item)
    {
        var configured = StyleHelper.Lang(Section.ButtonLabel, Lang);
        if (IsGallery(item) && IsGenericDetailLabel(configured))
            return "View Gallery";

        if (IsVideo(item) && IsGenericDetailLabel(configured))
            return "Watch";

        if (CanOpenImageLightbox(item) && IsGenericDetailLabel(configured))
            return "View";

        if (!string.IsNullOrWhiteSpace(configured))
            return configured;

        return item.ClickBehavior switch
        {
            "download" => "Download",
            "video" => "Watch",
            "image" => "View",
            _ => "Read More"
        };
    }

    private static string ItemHref(PublicLibraryItemDto item)
    {
        if (IsGallery(item))
            return GalleryMediaItems(item).FirstOrDefault() is { } galleryItem
                ? GalleryItemUrl(galleryItem)
                : "#";

        if (IsVideo(item))
            return item.VideoUrl ?? "#";

        if (IsImage(item))
            return ImageUrl(item);

        return item.ClickBehavior switch
        {
            "download" => item.Attachments.FirstOrDefault()?.Url ?? "#",
            "external" => item.ExternalUrl ?? "#",
            _ => $"/insights/{ContentTypeRoute(item.ContentTypeKey)}/{item.Slug}"
        };
    }

    private static string Target(PublicLibraryItemDto item) =>
        item.ClickBehavior is "download" or "external" ? "_blank" : "_self";

    private static string? Rel(PublicLibraryItemDto item) =>
        item.ClickBehavior is "download" or "external" ? "noopener" : null;

    private static string? DownloadMetricFlag(PublicLibraryItemDto item) =>
        string.Equals(item.ClickBehavior, "download", StringComparison.OrdinalIgnoreCase) ? "true" : null;

    private static bool IsVideo(PublicLibraryItemDto item) =>
        string.Equals(item.ClickBehavior, "video", StringComparison.OrdinalIgnoreCase)
        || string.Equals(item.ContentBehavior, "video-resource", StringComparison.OrdinalIgnoreCase)
        || IsVideoLibraryType(item.ContentTypeKey);

    private bool CanOpenImageLightbox(PublicLibraryItemDto item) =>
        !IsGallery(item) && !string.IsNullOrWhiteSpace(ImageUrl(item)) && (LayoutClass == "gallery" || IsImage(item));

    private static bool IsGallery(PublicLibraryItemDto item) =>
        string.Equals(item.ContentBehavior, "gallery", StringComparison.OrdinalIgnoreCase);

    private static bool IsImage(PublicLibraryItemDto item)
    {
        if (IsGallery(item)) return false;

        return string.Equals(item.ClickBehavior, "image", StringComparison.OrdinalIgnoreCase)
            || string.Equals(item.ContentBehavior, "image-resource", StringComparison.OrdinalIgnoreCase)
            || IsImageLibraryType(item.ContentTypeKey);
    }

    private static IEnumerable<PublicLibraryGalleryItemDto> GalleryMediaItems(PublicLibraryItemDto item) =>
        (item.GalleryItems ?? new())
            .Where(i => !string.IsNullOrWhiteSpace(i.Url))
            .OrderBy(i => i.Order);

    private static bool GalleryItemIsVideo(PublicLibraryGalleryItemDto item) =>
        string.Equals(item.Kind, "video", StringComparison.OrdinalIgnoreCase);

    private static string GalleryItemUrl(PublicLibraryGalleryItemDto item) => item.Url;

    private static string GalleryItemThumbnailUrl(PublicLibraryGalleryItemDto item) =>
        !string.IsNullOrWhiteSpace(item.ThumbnailUrl)
            ? item.ThumbnailUrl!
            : GalleryItemIsVideo(item) ? string.Empty : item.Url;

    private string GalleryItemTitle(PublicLibraryGalleryItemDto galleryItem, PublicLibraryItemDto parent)
    {
        var caption = StyleHelper.Lang(galleryItem.Caption, Lang);
        return !string.IsNullOrWhiteSpace(caption) ? caption : ItemTitle(parent);
    }

    private static bool IsVideoLibraryType(string? key)
    {
        if (string.IsNullOrWhiteSpace(key)) return false;
        var normalized = key.Trim().ToLowerInvariant();
        return normalized.Contains("video", StringComparison.OrdinalIgnoreCase) ||
               normalized.Contains("webinar", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsImageLibraryType(string? key)
    {
        if (string.IsNullOrWhiteSpace(key)) return false;
        var normalized = key.Trim().ToLowerInvariant();
        return normalized.Contains("image", StringComparison.OrdinalIgnoreCase) ||
               normalized.Contains("gallery", StringComparison.OrdinalIgnoreCase) ||
               normalized.Contains("photo", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsGenericDetailLabel(string? label)
    {
        if (string.IsNullOrWhiteSpace(label)) return true;
        var normalized = label.Trim().ToLowerInvariant();
        return normalized is "view details" or "read more" or "learn more";
    }

    private static string TypeLabel(string type)
    {
        if (string.IsNullOrWhiteSpace(type))
            return "Content";

        return string.Join(" ", type
            .Replace("_", "-")
            .Split('-', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => char.ToUpperInvariant(part[0]) + part[1..]));
    }

    private static string ContentTypeRoute(string type) => type switch
    {
        "article" => "articles",
        "case-study" => "case-studies",
        "whitepaper" => "whitepapers",
        "video" => "videos",
        "webinar" => "webinars",
        "webinars" => "webinars",
        "video-webinar" => "webinars",
        "videos-webinars" => "webinars",
        "tool" => "tools",
        "technology" => "technology",
        _ => type
    };

    private string RequestedContentType()
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query.TrimStart('?');
        if (string.IsNullOrWhiteSpace(query))
            return string.Empty;

        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var pair = part.Split('=', 2);
            if (pair.Length != 2 || !string.Equals(Uri.UnescapeDataString(pair[0]), "type", StringComparison.OrdinalIgnoreCase))
                continue;

            return NormalizeContentTypeQuery(Uri.UnescapeDataString(pair[1]));
        }

        return string.Empty;
    }

    private static string NormalizeContentTypeQuery(string value)
    {
        var normalized = value.Trim().ToLowerInvariant();
        return normalized switch
        {
            "articles" => "article",
            "case-studies" => "case-study",
            "whitepapers" => "whitepaper",
            "reports" => "whitepaper",
            "videos" => "video",
            "webinars" => "video",
            "tools" => "tool",
            _ => normalized
        };
    }
}
