@using Contracts.Public
@using SharedComponents.Helpers
@using SharedComponents.Blocks

<section data-section-id="@Section.Id"
         class="@StyleHelper.GetSectionClass(Section.Style)"
         style="@StyleHelper.GetSectionStyle(Section.Style)">
    <div class="sc-section-overlay"
         style="@StyleHelper.GetOverlayStyle(Section.Style)"></div>
    <div style="position: relative; z-index: 1" class="sc-stats">
        @if (Section.SectionTitle is not null)
        {
            <h2 class="sc-stats__title">@StyleHelper.Lang(Section.SectionTitle, Lang)</h2>
        }

        <div class="sc-stats__grid sc-stats__grid--@(Math.Clamp(Section.Columns ?? 4, 1, 5))"
             data-sc-stats
             data-duration="@(Section.DurationMs ?? 1200)">
            @foreach (var item in Section.Items?.OrderBy(i => i.Order) ?? Enumerable.Empty<PublicStatItemDto>())
            {
                <div class="sc-stat">
                    <div class="sc-stat__value">
                        <span>@item.Prefix</span><span data-sc-counter data-value="@item.Value">0</span><span>@item.Suffix</span>
                    </div>
                    <div class="sc-stat__label">@StyleHelper.Lang(item.Label, Lang)</div>
                </div>
            }
        </div>
    </div>
    <SectionBlocks Blocks="Section.Blocks" SectionId="@Section.Id" Style="Section.Style" Lang="@Lang" ShowInvisible="@ShowInvisible" OnSubmit="OnSubmit" />
</section>

@code {
    [Parameter, EditorRequired] public PublicStatsSectionDto Section { get; set; } = default!;
    [Parameter] public string Lang { get; set; } = "en";
    [Parameter] public bool ShowInvisible { get; set; }
    [Parameter] public Func<string, Dictionary<string, string>, Task<bool>>? OnSubmit { get; set; }
}
