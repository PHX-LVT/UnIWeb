@using Contracts.Public
@using Contracts.Forms
@using SharedComponents.Helpers

<div class="@FormClass">
    @if (!string.IsNullOrWhiteSpace(NameText) || !string.IsNullOrWhiteSpace(IntroductionText))
    {
        <div class="sc-form-block__header">
            @if (!string.IsNullOrWhiteSpace(NameText))
            {
                <h3>@NameText</h3>
            }
            @if (!string.IsNullOrWhiteSpace(IntroductionText))
            {
                <p>@IntroductionText</p>
            }
        </div>
    }

    <input class="sc-form-honeypot"
           type="text"
           tabindex="-1"
           autocomplete="off"
           aria-hidden="true"
           @bind="_honeypot" />

    <div class="sc-form-block__fields">
        @foreach (var field in Block.Fields?.OrderBy(item => item.Order) ?? Enumerable.Empty<PublicFormFieldDto>())
        {
            var key = FieldKey(field);
            var label = StyleHelper.Lang(field.Label, Lang);
            var placeholder = StyleHelper.Lang(field.Placeholder, Lang);

            <div class="@FieldClass(field)">
                <label class="sc-form-label" for="@InputId(key)">
                    @label
                    @if (field.Required)
                    {
                        <span class="sc-required">*</span>
                    }
                </label>

                @switch (field.Type)
                {
                    case "textarea":
                        <textarea id="@InputId(key)"
                                  class="@InputClass(field)"
                                  name="@key"
                                  placeholder="@placeholder"
                                  maxlength="@MaxLengthAttribute(field)"
                                  required="@field.Required"
                                  aria-invalid="@HasError(key)"
                                  value="@_data.GetValueOrDefault(key)"
                                  @oninput="eventArgs => RevalidateIfInvalid(field, eventArgs.Value)"
                                  @onchange="eventArgs => SetField(field, eventArgs.Value)"></textarea>
                        break;

                    case "select":
                        <select id="@InputId(key)"
                                class="@InputClass(field)"
                                name="@key"
                                value="@_data.GetValueOrDefault(key)"
                                required="@field.Required"
                                aria-invalid="@HasError(key)"
                                @onchange="eventArgs => SetField(field, eventArgs.Value)">
                            <option value="">@placeholder</option>
                            @foreach (var option in field.Options.OrderBy(item => item.Order))
                            {
                                <option value="@option.Value">@StyleHelper.Lang(option.Label, Lang)</option>
                            }
                        </select>
                        break;

                    case "checkbox":
                        <label class="sc-form-checkbox" for="@InputId(key)">
                            <input id="@InputId(key)"
                                   type="checkbox"
                                   name="@key"
                                   required="@field.Required"
                                   aria-invalid="@HasError(key)"
                                   checked="@IsChecked(key)"
                                   @onchange="eventArgs => SetField(field, eventArgs.Value)" />
                            <span>@placeholder</span>
                        </label>
                        break;

                    default:
                        <input id="@InputId(key)"
                               type="@InputType(field.Type)"
                               inputmode="@InputMode(field.Type)"
                               class="@InputClass(field)"
                               name="@key"
                               placeholder="@placeholder"
                               maxlength="@MaxLengthAttribute(field)"
                               required="@field.Required"
                               aria-invalid="@HasError(key)"
                               value="@_data.GetValueOrDefault(key)"
                               @oninput="eventArgs => RevalidateIfInvalid(field, eventArgs.Value)"
                               @onchange="eventArgs => SetField(field, eventArgs.Value)" />
                        break;
                }

                @if (_fieldErrors.TryGetValue(key, out var fieldError))
                {
                    <span class="sc-form-field__error" role="alert">@fieldError</span>
                }
            </div>
        }
    </div>

    <button type="button" class="sc-btn sc-btn--filled sc-form-block__submit" @onclick="Submit">
        @SubmitLabelText
    </button>

    @if (_submitted)
    {
        <p class="sc-form-success">Thank you, your message has been sent.</p>
    }
    @if (_error)
    {
        <p class="sc-form-error">@(_errorMessage ?? "Something went wrong. Please try again.")</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public PublicFormBlockDto Block { get; set; } = default!;
    [Parameter] public string Lang { get; set; } = "en";
    [Parameter] public Func<Dictionary<string, string>, Task<bool>>? OnSubmit { get; set; }

    private Dictionary<string, string> _data = new();
    private Dictionary<string, string> _fieldErrors = new(StringComparer.OrdinalIgnoreCase);
    private bool _submitted;
    private bool _error;
    private string? _errorMessage;
    private string _honeypot = string.Empty;

    private string NameText => StyleHelper.Lang(Block.Name, Lang);
    private string IntroductionText => StyleHelper.Lang(Block.Introduction, Lang);
    private string SubmitLabelText => StyleHelper.Lang(Block.SubmitButtonLabel, Lang) is { Length: > 0 } value
        ? value
        : "Submit";
    private string FormClass => Block.FormLayoutMode == "two-columns"
        ? "sc-block sc-block--form sc-form-block sc-form-block--two-columns"
        : "sc-block sc-block--form sc-form-block sc-form-block--stacked";

    protected override void OnParametersSet()
    {
        var next = new Dictionary<string, string>();
        foreach (var field in Block.Fields ?? Enumerable.Empty<PublicFormFieldDto>())
        {
            var key = FieldKey(field);
            next[key] = _data.TryGetValue(key, out var existing) ? existing : string.Empty;
        }

        _data = next;
        _fieldErrors = _fieldErrors
            .Where(error => next.ContainsKey(error.Key))
            .ToDictionary(error => error.Key, error => error.Value, StringComparer.OrdinalIgnoreCase);
    }

    private async Task Submit()
    {
        _submitted = false;
        _error = false;
        _errorMessage = null;

        _fieldErrors.Clear();
        foreach (var field in Block.Fields ?? Enumerable.Empty<PublicFormFieldDto>())
            ValidateField(field);

        if (_fieldErrors.Count > 0)
        {
            return;
        }

        if (OnSubmit is null) return;
        var payload = new Dictionary<string, string>(_data, StringComparer.OrdinalIgnoreCase)
        {
            ["__website"] = _honeypot
        };
        var success = await OnSubmit(payload);
        if (success)
        {
            _submitted = true;
            _honeypot = string.Empty;
            _fieldErrors.Clear();
            _data = (Block.Fields ?? Enumerable.Empty<PublicFormFieldDto>())
                .ToDictionary(FieldKey, _ => string.Empty);
        }
        else
        {
            _error = true;
        }
    }

    private void SetField(PublicFormFieldDto field, object? value)
    {
        var key = FieldKey(field);
        _data[key] = value switch
        {
            bool booleanValue => booleanValue ? "true" : "false",
            null => string.Empty,
            _ => value.ToString() ?? string.Empty
        };
        ValidateField(field);
    }

    private void RevalidateIfInvalid(PublicFormFieldDto field, object? value)
    {
        var key = FieldKey(field);
        if (!_fieldErrors.ContainsKey(key)) return;
        SetField(field, value);
    }

    private void ValidateField(PublicFormFieldDto field)
    {
        var key = FieldKey(field);
        var error = FormInputValueValidator.Validate(
            field.Type,
            _data.GetValueOrDefault(key),
            field.Required,
            field.Options.Select(option => option.Value).ToList());

        if (error == FormInputValidationError.None)
        {
            _fieldErrors.Remove(key);
            return;
        }

        var label = StyleHelper.Lang(field.Label, Lang);
        _fieldErrors[key] = ValidationMessage(error, string.IsNullOrWhiteSpace(label) ? key : label);
    }

    private string ValidationMessage(FormInputValidationError error, string label)
    {
        var language = Lang?.Trim().ToLowerInvariant() ?? "en";
        if (language.StartsWith("vi", StringComparison.Ordinal))
        {
            return error switch
            {
                FormInputValidationError.Required => $"{label} l\u00e0 tr\u01b0\u1eddng b\u1eaft bu\u1ed9c.",
                FormInputValidationError.Email => "Nh\u1eadp email \u0111\u1ea7y \u0111\u1ee7, v\u00ed d\u1ee5 ten@congty.com.",
                FormInputValidationError.Phone => "Nh\u1eadp s\u1ed1 \u0111i\u1ec7n tho\u1ea1i h\u1ee3p l\u1ec7 c\u00f3 t\u1eeb 6 \u0111\u1ebfn 15 ch\u1eef s\u1ed1.",
                FormInputValidationError.Number => "Ch\u1ec9 nh\u1eadp m\u1ed9t s\u1ed1 h\u1ee3p l\u1ec7.",
                FormInputValidationError.Date => "Ch\u1ecdn m\u1ed9t ng\u00e0y h\u1ee3p l\u1ec7.",
                FormInputValidationError.Url => "Nh\u1eadp \u0111\u1ecba ch\u1ec9 http ho\u1eb7c https \u0111\u1ea7y \u0111\u1ee7.",
                FormInputValidationError.Option => "Ch\u1ecdn m\u1ed9t gi\u00e1 tr\u1ecb c\u00f3 trong danh s\u00e1ch.",
                FormInputValidationError.Checkbox => "Gi\u00e1 tr\u1ecb l\u1ef1a ch\u1ecdn kh\u00f4ng h\u1ee3p l\u1ec7.",
                _ => $"{label} kh\u00f4ng h\u1ee3p l\u1ec7."
            };
        }

        if (language.StartsWith("zh", StringComparison.Ordinal))
        {
            return error switch
            {
                FormInputValidationError.Required => $"{label}\u4e3a\u5fc5\u586b\u9879\u3002",
                FormInputValidationError.Email => "\u8bf7\u8f93\u5165\u5b8c\u6574\u7684\u7535\u5b50\u90ae\u4ef6\u5730\u5740\uff0c\u4f8b\u5982 name@company.com\u3002",
                FormInputValidationError.Phone => "\u8bf7\u8f93\u5165\u5305\u542b 6 \u5230 15 \u4f4d\u6570\u5b57\u7684\u6709\u6548\u7535\u8bdd\u53f7\u7801\u3002",
                FormInputValidationError.Number => "\u8bf7\u8f93\u5165\u6709\u6548\u6570\u5b57\u3002",
                FormInputValidationError.Date => "\u8bf7\u9009\u62e9\u6709\u6548\u65e5\u671f\u3002",
                FormInputValidationError.Url => "\u8bf7\u8f93\u5165\u5b8c\u6574\u7684 http \u6216 https \u5730\u5740\u3002",
                FormInputValidationError.Option => "\u8bf7\u4ece\u5217\u8868\u4e2d\u9009\u62e9\u4e00\u4e2a\u503c\u3002",
                _ => $"{label}\u7684\u503c\u65e0\u6548\u3002"
            };
        }

        return error switch
        {
            FormInputValidationError.Required => $"{label} is required.",
            FormInputValidationError.Email => "Enter a complete email address, such as name@company.com.",
            FormInputValidationError.Phone => "Enter a valid phone number containing 6 to 15 digits.",
            FormInputValidationError.Number => "Enter a valid number.",
            FormInputValidationError.Date => "Choose a valid date.",
            FormInputValidationError.Url => "Enter a complete http or https URL.",
            FormInputValidationError.Option => "Choose a value from the available options.",
            FormInputValidationError.Checkbox => "This checkbox value is invalid.",
            _ => $"{label} has an invalid value."
        };
    }

    private bool IsChecked(string key) => _data.GetValueOrDefault(key) == "true";
    private string InputId(string key) => $"form-{Block.Id}-{key}";
    private static string FieldKey(PublicFormFieldDto field) =>
        !string.IsNullOrWhiteSpace(field.Name) ? field.Name : $"field_{field.Order}";
    private static string FieldClass(PublicFormFieldDto field) => NormalizedType(field.Type) is "textarea" or "checkbox"
        ? "sc-form-field sc-form-field--wide"
        : "sc-form-field";

    private string InputClass(PublicFormFieldDto field)
    {
        var size = FormInputTypeCatalog.NormalizeInputBoxSize(field.Type, field.InputBoxSize);
        var baseClass = NormalizedType(field.Type) == "textarea"
            ? $"sc-form-input sc-form-input--size-{size}"
            : "sc-form-input";
        return HasError(FieldKey(field)) ? $"{baseClass} sc-form-input--invalid" : baseClass;
    }

    private bool HasError(string key) => _fieldErrors.ContainsKey(key);

    private static int? MaxLengthAttribute(PublicFormFieldDto field)
    {
        if (field.MaxLength <= 0) return null;
        return Math.Clamp(field.MaxLength, 1, FormInputTypeCatalog.MaxCharactersLimit);
    }

    private static string NormalizedType(string? type) => FormInputTypeCatalog.NormalizeType(type);

    private static string InputType(string? type) => NormalizedType(type) switch
    {
        "tel" => "tel",
        "number" => "text",
        "date" => "date",
        "url" => "url",
        "email" => "email",
        _ => "text"
    };

    private static string? InputMode(string? type) => NormalizedType(type) switch
    {
        "number" => "decimal",
        "tel" => "tel",
        "email" => "email",
        "url" => "url",
        _ => null
    };
}
