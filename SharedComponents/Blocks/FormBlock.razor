@using Contracts.Public
@using Contracts.Forms
@using SharedComponents.Helpers

<div class="@FormClass">
    @if (!string.IsNullOrWhiteSpace(NameText) || !string.IsNullOrWhiteSpace(IntroductionText))
    {
        <div class="sc-form-block__header">
            @if (!string.IsNullOrWhiteSpace(NameText))
            {
                <h3>@NameText</h3>
            }
            @if (!string.IsNullOrWhiteSpace(IntroductionText))
            {
                <p>@IntroductionText</p>
            }
        </div>
    }

    <input class="sc-form-honeypot"
           type="text"
           tabindex="-1"
           autocomplete="off"
           aria-hidden="true"
           @bind="_honeypot" />

    <div class="sc-form-block__fields">
        @foreach (var field in Block.Fields?.OrderBy(item => item.Order) ?? Enumerable.Empty<PublicFormFieldDto>())
        {
            var key = FieldKey(field);
            var label = StyleHelper.Lang(field.Label, Lang);
            var placeholder = StyleHelper.Lang(field.Placeholder, Lang);

            <div class="@FieldClass(field)">
                <label class="sc-form-label" for="@InputId(key)">
                    @label
                    @if (field.Required)
                    {
                        <span class="sc-required">*</span>
                    }
                </label>

                @switch (field.Type)
                {
                    case "textarea":
                        <textarea id="@InputId(key)"
                                  class="@InputClass(field)"
                                  name="@key"
                                  placeholder="@placeholder"
                                  maxlength="@MaxLengthAttribute(field)"
                                  required="@field.Required"
                                  value="@_data.GetValueOrDefault(key)"
                                  @onchange="eventArgs => SetField(key, eventArgs.Value)"></textarea>
                        break;

                    case "select":
                        <select id="@InputId(key)"
                                class="sc-form-input"
                                name="@key"
                                value="@_data.GetValueOrDefault(key)"
                                required="@field.Required"
                                @onchange="eventArgs => SetField(key, eventArgs.Value)">
                            <option value="">@placeholder</option>
                            @foreach (var option in field.Options.OrderBy(item => item.Order))
                            {
                                <option value="@option.Value">@StyleHelper.Lang(option.Label, Lang)</option>
                            }
                        </select>
                        break;

                    case "checkbox":
                        <label class="sc-form-checkbox" for="@InputId(key)">
                            <input id="@InputId(key)"
                                   type="checkbox"
                                   name="@key"
                                   required="@field.Required"
                                   checked="@IsChecked(key)"
                                   @onchange="eventArgs => SetField(key, eventArgs.Value)" />
                            <span>@placeholder</span>
                        </label>
                        break;

                    default:
                        <input id="@InputId(key)"
                               type="@InputType(field.Type)"
                               class="@InputClass(field)"
                               name="@key"
                               placeholder="@placeholder"
                               maxlength="@MaxLengthAttribute(field)"
                               required="@field.Required"
                               value="@_data.GetValueOrDefault(key)"
                               @onchange="eventArgs => SetField(key, eventArgs.Value)" />
                        break;
                }
            </div>
        }
    </div>

    <button type="button" class="sc-btn sc-btn--filled sc-form-block__submit" @onclick="Submit">
        @SubmitLabelText
    </button>

    @if (_submitted)
    {
        <p class="sc-form-success">Thank you, your message has been sent.</p>
    }
    @if (_error)
    {
        <p class="sc-form-error">@(_errorMessage ?? "Something went wrong. Please try again.")</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public PublicFormBlockDto Block { get; set; } = default!;
    [Parameter] public string Lang { get; set; } = "en";
    [Parameter] public Func<Dictionary<string, string>, Task<bool>>? OnSubmit { get; set; }

    private Dictionary<string, string> _data = new();
    private bool _submitted;
    private bool _error;
    private string? _errorMessage;
    private string _honeypot = string.Empty;

    private string NameText => StyleHelper.Lang(Block.Name, Lang);
    private string IntroductionText => StyleHelper.Lang(Block.Introduction, Lang);
    private string SubmitLabelText => StyleHelper.Lang(Block.SubmitButtonLabel, Lang) is { Length: > 0 } value
        ? value
        : "Submit";
    private string FormClass => Block.FormLayoutMode == "two-columns"
        ? "sc-block sc-block--form sc-form-block sc-form-block--two-columns"
        : "sc-block sc-block--form sc-form-block sc-form-block--stacked";

    protected override void OnParametersSet()
    {
        var next = new Dictionary<string, string>();
        foreach (var field in Block.Fields ?? Enumerable.Empty<PublicFormFieldDto>())
        {
            var key = FieldKey(field);
            next[key] = _data.TryGetValue(key, out var existing) ? existing : string.Empty;
        }

        _data = next;
    }

    private async Task Submit()
    {
        _submitted = false;
        _error = false;
        _errorMessage = null;

        var missingRequired = (Block.Fields ?? Enumerable.Empty<PublicFormFieldDto>())
            .Any(field => field.Required && string.IsNullOrWhiteSpace(_data.GetValueOrDefault(FieldKey(field))));

        if (missingRequired)
        {
            _error = true;
            _errorMessage = "Please complete all required fields.";
            return;
        }

        if (OnSubmit is null) return;
        var payload = new Dictionary<string, string>(_data, StringComparer.OrdinalIgnoreCase)
        {
            ["__website"] = _honeypot
        };
        var success = await OnSubmit(payload);
        if (success)
        {
            _submitted = true;
            _honeypot = string.Empty;
            _data = (Block.Fields ?? Enumerable.Empty<PublicFormFieldDto>())
                .ToDictionary(FieldKey, _ => string.Empty);
        }
        else
        {
            _error = true;
        }
    }

    private void SetField(string key, object? value)
    {
        _data[key] = value switch
        {
            bool booleanValue => booleanValue ? "true" : "false",
            null => string.Empty,
            _ => value.ToString() ?? string.Empty
        };
    }

    private bool IsChecked(string key) => _data.GetValueOrDefault(key) == "true";
    private string InputId(string key) => $"form-{Block.Id}-{key}";
    private static string FieldKey(PublicFormFieldDto field) =>
        !string.IsNullOrWhiteSpace(field.Name) ? field.Name : $"field_{field.Order}";
    private static string FieldClass(PublicFormFieldDto field) => NormalizedType(field.Type) is "textarea" or "checkbox"
        ? "sc-form-field sc-form-field--wide"
        : "sc-form-field";

    private static string InputClass(PublicFormFieldDto field)
    {
        var size = FormInputTypeCatalog.NormalizeInputBoxSize(field.Type, field.InputBoxSize);
        return NormalizedType(field.Type) == "textarea"
            ? $"sc-form-input sc-form-input--size-{size}"
            : "sc-form-input";
    }

    private static int? MaxLengthAttribute(PublicFormFieldDto field)
    {
        var capability = FormInputTypeCatalog.Get(field.Type);
        if (!capability.SupportsMaxCharacters) return null;

        return FormInputTypeCatalog.NormalizeMaxCharacters(field.Type, field.MaxLength);
    }

    private static string NormalizedType(string? type) => FormInputTypeCatalog.NormalizeType(type);

    private static string InputType(string? type) => NormalizedType(type) switch
    {
        "tel" => "tel",
        "number" => "number",
        "date" => "date",
        "url" => "url",
        "email" => "email",
        _ => "text"
    };
}
