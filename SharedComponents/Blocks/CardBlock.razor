@using Contracts.Public
@using SharedComponents.Helpers

<div class="sc-block sc-design-block sc-card-block">
    @if (!string.IsNullOrWhiteSpace(Block.ImageUrl))
    {
        <div class="sc-card-block__media">
            <img src="@Block.ImageUrl"
                 alt="@StyleHelper.Lang(Block.Title, Lang)" />
        </div>
    }
    <div class="sc-card-block__body">
        @if (!string.IsNullOrWhiteSpace(Block.Icon))
        {
            <i class="@Block.Icon sc-design-icon"></i>
        }
        <h3>@StyleHelper.Lang(Block.Title, Lang)</h3>
        <p>@StyleHelper.Lang(Block.Description, Lang)</p>
        @if (!string.IsNullOrWhiteSpace(Block.Href))
        {
            <a class="sc-btn sc-btn--outline" href="@Block.Href">
                @StyleHelper.Lang(Block.ButtonLabel, Lang)
            </a>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PublicCardBlockDto Block { get; set; } = default!;
    [Parameter] public string Lang { get; set; } = "en";
}
