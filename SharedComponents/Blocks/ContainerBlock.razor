@using Contracts.Public
@using SharedComponents.Helpers

<div class="@GetContainerClass()">
    @if (!string.IsNullOrWhiteSpace(TitleText))
    {
        <div class="sc-container-block__header">
            <h3>@TitleText</h3>
        </div>
    }

    <SectionBlocks Blocks="Block.Children"
                   Style="@NestedStyle"
                   SectionId="@SectionId"
                   ParentBlockId="@Block.Id"
                   DataZoneId="@($"container-{Block.Id}")"
                   ForceFreeform="@(NormalizeLayout(Block.LayoutMode) == "freeform")"
                   PatternRadius="@PatternRadius"
                   PatternStartAngle="@PatternStartAngle"
                   PatternEndAngle="@PatternEndAngle"
                   Lang="@Lang"
                   ShowInvisible="@ShowInvisible"
                   OnSubmit="@OnSubmit" />
</div>

@code {
    [Parameter, EditorRequired] public PublicContainerBlockDto Block { get; set; } = default!;
    [Parameter] public string? SectionId { get; set; }
    [Parameter] public string Lang { get; set; } = "en";
    [Parameter] public bool ShowInvisible { get; set; }
    [Parameter] public Func<string, Dictionary<string, string>, Task<bool>>? OnSubmit { get; set; }

    private string TitleText => StyleHelper.Lang(Block.Title, Lang);

    private PublicSectionStyleDto NestedStyle => new()
    {
        BlockLayoutMode = NormalizeLayout(Block.LayoutMode),
        BlockGridColumns = 1,
        BlockGap = NormalizeGap(Block.Gap)
    };

    private string GetContainerClass()
    {
        var layout = NormalizeLayout(Block.LayoutMode);
        var gap = NormalizeGap(Block.Gap);
        return $"sc-block sc-design-block sc-container-block sc-container-block--{layout} sc-container-block--gap-{gap}";
    }

    private int PatternRadius => NormalizeLayout(Block.LayoutMode) == "semicircle"
        ? Math.Clamp(Block.SemicircleRadius, 80, 480)
        : Math.Clamp(Block.OrbitRadius, 80, 480);

    private int PatternStartAngle => NormalizeLayout(Block.LayoutMode) == "semicircle"
        ? Math.Clamp(Block.SemicircleStartAngle, -360, 360)
        : Math.Clamp(Block.OrbitStartAngle, -360, 360);

    private int PatternEndAngle => NormalizeLayout(Block.LayoutMode) == "semicircle"
        ? Math.Clamp(Block.SemicircleEndAngle, -360, 360)
        : PatternStartAngle + 360;

    private static string NormalizeLayout(string? layout) => layout switch
    {
        "row" => "row",
        "orbit" => "orbit",
        "semicircle" => "semicircle",
        "freeform" => "freeform",
        "grid" or "split" => "row",
        _ => "stack"
    };

    private static string NormalizeGap(string? gap) => gap switch
    {
        "none" => "none",
        "small" => "small",
        "large" => "large",
        _ => "medium"
    };
}
