@using Contracts.Public

@if (ShouldRenderContainer)
{
    <div class="@GetContainerClass()"
         data-block-zone="@NormalizeZone(DataZoneId ?? BlockZone)"
         style="@GetContainerStyle()">
        @{ var renderedBlocks = ZoneBlocks.OrderBy(block => block.Order).ToList(); }
        @for (var index = 0; index < renderedBlocks.Count; index++)
        {
            var block = renderedBlocks[index];
            <div class="@GetBlockClass(block)"
                 data-block-id="@block.Id"
                 data-block-section-id="@GetSectionId()"
                 data-block-zone="@NormalizeZone(block.ZoneId ?? block.BlockZone)"
                 data-block-position-mode="@EffectivePositionMode(block)"
                 style="@GetBlockStyle(block, index, renderedBlocks.Count)">
                @RenderBlock(block)
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<PublicBlockDto>? Blocks { get; set; }
    [Parameter] public PublicSectionStyleDto? Style { get; set; }
    [Parameter] public string? SectionId { get; set; }
    [Parameter] public string BlockZone { get; set; } = "default";
    [Parameter] public string? DataZoneId { get; set; }
    [Parameter] public bool IncludeDefaultZone { get; set; }
    [Parameter] public bool ForceFreeform { get; set; }
    [Parameter] public int PatternRadius { get; set; } = 180;
    [Parameter] public int PatternStartAngle { get; set; } = -90;
    [Parameter] public int PatternEndAngle { get; set; } = 270;
    [Parameter] public string? ParentBlockId { get; set; }
    [Parameter] public string Lang { get; set; } = "en";
    [Parameter] public bool ShowInvisible { get; set; }
    [Parameter] public Func<string, Dictionary<string, string>, Task<bool>>? OnSubmit { get; set; }

    private IEnumerable<PublicBlockDto> ZoneBlocks =>
        (Blocks ?? new())
            .Where(b => ShowInvisible || b.Visible)
            .Where(b => string.IsNullOrWhiteSpace(ParentBlockId)
                ? string.IsNullOrWhiteSpace(b.ParentBlockId)
                : string.Equals(b.ParentBlockId, ParentBlockId, StringComparison.Ordinal))
            .Where(b => ZoneMatches(b));

    private bool ShouldRenderContainer => ZoneBlocks.Any() || LayoutMode == "freeform";

    private bool ZoneMatches(PublicBlockDto block)
    {
        var requested = NormalizeZone(BlockZone);
        var actual = NormalizeZone(block.ZoneId ?? block.BlockZone);

        return actual == requested || (IncludeDefaultZone && actual == "default");
    }

    private string LayoutMode => Style?.BlockLayoutMode switch
    {
        "grid" => "grid",
        "split" => "split",
        "row" => "row",
        "orbit" => "orbit",
        "semicircle" => "semicircle",
        "freeform" => "freeform",
        _ => "stack"
    };

    private string GetContainerClass()
    {
        var gap = Style?.BlockGap switch
        {
            "none" => "none",
            "small" => "small",
            "large" => "large",
            _ => "medium"
        };

        var forced = ForceFreeform ? " sc-section-blocks--force-freeform" : string.Empty;
        return $"sc-section-blocks sc-block-zone sc-section-blocks--{LayoutMode} sc-section-blocks--gap-{gap}{forced}";
    }

    private string GetContainerStyle()
    {
        var columns = LayoutMode == "split"
            ? 2
            : Math.Clamp(Style?.BlockGridColumns ?? 12, 1, 12);
        var styles = new List<string>
        {
            $"--sc-block-grid-columns: {columns}"
        };

        if (LayoutMode == "freeform")
        {
            var height = Math.Clamp(Style?.CustomMinHeightPx ?? 640, 120, 3000);
            styles.Add($"--sc-freeform-min-height: {height}px");
        }

        else if (LayoutMode is "orbit" or "semicircle")
        {
            var radius = Math.Clamp(PatternRadius, 80, 480);
            var height = LayoutMode == "orbit" ? radius * 2 + 180 : radius + 200;
            styles.Add($"--sc-pattern-radius: {radius}px");
            styles.Add($"--sc-pattern-min-height: {height}px");
        }

        return string.Join("; ", styles);
    }

    private string GetBlockClass(PublicBlockDto block)
    {
        var layout = block.Layout ?? new PublicBlockLayoutDto();
        var span = Math.Clamp(layout.ColumnSpan, 1, 12);

        return string.Join(" ", new[]
        {
            "sc-block-frame",
            $"sc-block-frame--position-{EffectivePositionMode(block)}",
            $"sc-block-frame--span-{span}",
            $"sc-block-frame--width-{Normalize(layout.Width, "auto")}",
            $"sc-block-frame--align-{Normalize(layout.Align, "stretch")}",
            $"sc-block-frame--justify-{Normalize(layout.Justify, "start")}",
            $"sc-block-frame--pad-{Normalize(layout.Padding, "none")}",
            $"sc-block-frame--margin-{Normalize(layout.Margin, "none")}",
            $"sc-block-frame--radius-{Normalize(layout.BorderRadius, "none")}"
        });
    }

    private string GetBlockStyle(PublicBlockDto block, int index, int count)
    {
        var layout = block.Layout ?? new PublicBlockLayoutDto();
        var left = FormatNumber(FreeformLeftPercent(layout));
        var width = FormatNumber(FreeformWidthPercent(layout));
        var parts = new List<string>
        {
            $"--sc-block-column-span: {Math.Clamp(layout.ColumnSpan, 1, 12)}",
            $"--sc-block-left: {left}%",
            $"--sc-block-width: {width}%",
            $"--sc-block-top: {FormatNumber(FreeformTopPx(layout))}px",
            $"--sc-block-min-height: {FormatNumber(FreeformHeightPx(layout))}px",
            $"--sc-pattern-angle: {PatternAngle(index, count).ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)}deg",
            $"z-index: {Math.Clamp(layout.ZIndex, 0, 1000)}"
        };

        if (!string.IsNullOrWhiteSpace(layout.BackgroundColor))
            parts.Add($"background-color: {layout.BackgroundColor}");

        return string.Join("; ", parts);
    }

    private static string Normalize(string? value, string fallback) =>
        string.IsNullOrWhiteSpace(value) ? fallback : value;

    private static string NormalizePositionMode(string? value) =>
        string.Equals(value, "freeform", StringComparison.OrdinalIgnoreCase) ? "freeform" : "flow";

    private string EffectivePositionMode(PublicBlockDto block) =>
        ForceFreeform ? "freeform" : NormalizePositionMode(block.PositionMode);

    private static double FreeformLeftPercent(PublicBlockLayoutDto layout) =>
        Math.Clamp(layout.LeftPercent ?? (Math.Clamp(layout.X, 0, 11) / 12d * 100), 0, 100);

    private static double FreeformWidthPercent(PublicBlockLayoutDto layout) =>
        Math.Clamp(layout.WidthPercent ?? (Math.Clamp(layout.W, 1, 12) / 12d * 100), 1, 100);

    private static double FreeformTopPx(PublicBlockLayoutDto layout) =>
        Math.Clamp(layout.TopPx ?? (Math.Clamp(layout.Y, 0, 60) * 48d), 0, 10000);

    private static double FreeformHeightPx(PublicBlockLayoutDto layout) =>
        Math.Clamp(layout.HeightPx ?? (Math.Clamp(layout.H, 1, 40) * 48d), 24, 10000);

    private static string FormatNumber(double value) =>
        value.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture);

    private double PatternAngle(int index, int count)
    {
        if (LayoutMode == "orbit")
            return PatternStartAngle + (count <= 1 ? 0 : index * (360d / count));

        if (LayoutMode == "semicircle")
            return count <= 1
                ? (PatternStartAngle + PatternEndAngle) / 2d
                : PatternStartAngle + index * ((PatternEndAngle - PatternStartAngle) / (double)(count - 1));

        return 0;
    }

    private string GetSectionId() => SectionId ?? string.Empty;

    private static string NormalizeZone(string? zone) =>
        string.IsNullOrWhiteSpace(zone) ? "default" : zone.Trim().ToLowerInvariant();

    private RenderFragment RenderBlock(PublicBlockDto block)
    {
        return block switch
        {
            PublicTextBlockDto textBlock =>
                @<TextBlock Block="textBlock" Lang="@Lang" />,

            PublicImageBlockDto imageBlock =>
                @<ImageBlock Block="imageBlock" Lang="@Lang" />,

            PublicVideoBlockDto videoBlock =>
                @<VideoBlock Block="videoBlock" Lang="@Lang" />,

            PublicFileBlockDto fileBlock =>
                @<FileBlock Block="fileBlock" Lang="@Lang" />,

            PublicMapBlockDto mapBlock =>
                @<MapBlock Block="mapBlock" Lang="@Lang" />,

            PublicFormBlockDto formBlock =>
                @<FormBlock Block="formBlock" Lang="@Lang"
                    OnSubmit="OnSubmit is null ? null : data => OnSubmit(formBlock.Id, data)" />,

            PublicCardBlockDto cardBlock =>
                @<CardBlock Block="cardBlock" Lang="@Lang" />,

            PublicButtonBlockDto buttonBlock =>
                @<ButtonBlock Block="buttonBlock" Lang="@Lang" />,

            PublicMetricBlockDto metricBlock =>
                @<MetricBlock Block="metricBlock" Lang="@Lang" />,

            PublicBulletListBlockDto bulletListBlock =>
                @<BulletListBlock Block="bulletListBlock" Lang="@Lang" />,

            PublicStepBlockDto stepBlock =>
                @<StepBlock Block="stepBlock" Lang="@Lang" />,

            PublicIconBlockDto iconBlock =>
                @<IconBlock Block="iconBlock" Lang="@Lang" />,

            PublicContainerBlockDto containerBlock =>
                @<ContainerBlock Block="containerBlock"
                                 SectionId="@SectionId"
                                 Lang="@Lang"
                                 ShowInvisible="@ShowInvisible"
                                 OnSubmit="@OnSubmit" />,

            _ =>
                @<text></text>
        };
    }
}
